# LiteLLM 环境变量配置
# 复制此文件为 .env 并填入你的 API 密钥

# OpenAI API 密钥
# 从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=sk-xxxxx

# Google Gemini API 密钥
# 从 https://makersuite.google.com/app/apikey 获取
GOOGLE_API_KEY=AIzaSyxxxxx

# LiteLLM 主密钥 (用于 Claude Code 连接认证)
LITELLM_MASTER_KEY=sk-litellm-master-key
