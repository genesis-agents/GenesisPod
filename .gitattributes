# Genesis.ai — line-ending policy
# Repo stores text as LF; Windows checkouts may render CRLF in editor but
# git normalizes back to LF on add/commit. Cures the constant
# "LF will be replaced by CRLF" noise on Windows clones.

# Default: detect text vs binary, store text as LF
* text=auto eol=lf

# Windows-only scripts must keep CRLF in the working tree to run correctly
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Explicit binaries (don't try to LF-convert these)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.bmp   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.7z    binary
*.mp3   binary
*.mp4   binary
*.webm  binary
