### GenesisPod Public API — runnable request collection
#
# Usage:
#   - VS Code REST Client extension, or JetBrains HTTP Client.
#   - Set @baseUrl and @apiKey below (or via environment vars).
#   - Click "Send Request" above each request.
#
# Every path/header/field is verified against the live controllers/DTOs:
#   public-api.controller.ts, a2a-rpc.controller.ts, a2a-server.controller.ts,
#   mcp-api-key.guard.ts, main.ts (global prefix "api/v1").

@baseUrl = http://localhost:4000
@apiKey = your-mcp-api-key

### Service status (public, no API key required)
GET {{baseUrl}}/api/v1/public/status

### List capabilities (auth required)
GET {{baseUrl}}/api/v1/public/capabilities
Authorization: Bearer {{apiKey}}

### Chat — POST /api/v1/public/chat
POST {{baseUrl}}/api/v1/public/chat
Authorization: Bearer {{apiKey}}
Content-Type: application/json

{
  "messages": [
    { "role": "system", "content": "You are a concise assistant." },
    { "role": "user", "content": "Explain vector databases in one sentence." }
  ]
}

### Quick Q&A — POST /api/v1/public/ask
POST {{baseUrl}}/api/v1/public/ask
Authorization: Bearer {{apiKey}}
Content-Type: application/json

{
  "question": "What is retrieval-augmented generation?"
}

### Deep research (synchronous) — POST /api/v1/public/research
POST {{baseUrl}}/api/v1/public/research
Authorization: Bearer {{apiKey}}
Content-Type: application/json

{
  "query": "State of small language models for on-device inference in 2026",
  "depth": "standard",
  "language": "en",
  "dimensions": ["hardware constraints", "leading open models", "benchmarks"]
}

### Team debate — POST /api/v1/public/teams/debate
POST {{baseUrl}}/api/v1/public/teams/debate
Authorization: Bearer {{apiKey}}
Content-Type: application/json

{
  "topic": "Should AI agents be allowed to autonomously execute code?",
  "rounds": 2
}

### Writing assist — POST /api/v1/public/writing/assist
POST {{baseUrl}}/api/v1/public/writing/assist
Authorization: Bearer {{apiKey}}
Content-Type: application/json

{
  "content": "this are a draft sentence with grammer issues.",
  "assistType": "proofread"
}

### Content analysis — POST /api/v1/public/content/analyze
POST {{baseUrl}}/api/v1/public/content/analyze
Authorization: Bearer {{apiKey}}
Content-Type: application/json

{
  "content": "Long-form text to analyze goes here...",
  "analysisType": "summary"
}

### A2A discovery (public, no prefix, no API key)
GET {{baseUrl}}/.well-known/agent.json

### A2A v0.3 JSON-RPC — message/send  (POST /api/v1/a2a/v1)
POST {{baseUrl}}/api/v1/a2a/v1
Authorization: Bearer {{apiKey}}
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": "1",
  "method": "message/send",
  "params": {
    "message": {
      "kind": "message",
      "messageId": "11111111-1111-1111-1111-111111111111",
      "role": "user",
      "parts": [
        { "kind": "text", "text": "Research the impact of RISC-V on edge AI." }
      ],
      "metadata": { "skillId": "research" }
    }
  }
}

### A2A v0.3 JSON-RPC — tasks/get  (POST /api/v1/a2a/v1)
# Replace <TASK_ID> with the task id returned by message/send (data.result.id).
POST {{baseUrl}}/api/v1/a2a/v1
Authorization: Bearer {{apiKey}}
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": "2",
  "method": "tasks/get",
  "params": { "id": "<TASK_ID>" }
}
</content>
