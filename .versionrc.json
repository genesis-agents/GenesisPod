{
  "header": "# Changelog\n\nGenesisPod 版本变更记录。\n",
  "types": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "refactor", "section": "Refactoring" },
    { "type": "perf", "section": "Performance" },
    { "type": "docs", "hidden": true },
    { "type": "style", "hidden": true },
    { "type": "test", "hidden": true },
    { "type": "chore", "hidden": true },
    { "type": "ci", "hidden": true },
    { "type": "build", "hidden": true }
  ],
  "bumpFiles": [
    { "filename": "package.json", "type": "json" },
    { "filename": "backend/package.json", "type": "json" },
    { "filename": "frontend/package.json", "type": "json" }
  ],
  "infile": "frontend/CHANGELOG.md",
  "tagPrefix": "v",
  "commitAll": true,
  "scripts": {
    "postchangelog": "node frontend/scripts/generate-changelog.js && git add -f frontend/lib/generated/changelog.json"
  }
