{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Capability Index",
  "description": "全栈公共可复用能力索引。由 scripts/utils/generate-capabilities.ts 自动生成，勿手改。",
  "type": "object",
  "required": ["sources", "totals", "capabilities"],
  "properties": {
    "$schema": { "type": "string" },
    "note": { "type": "string" },
    "sources": {
      "type": "array",
      "items": { "type": "string" },
      "description": "抽取来源（facade 文件 + 前端 glob）"
    },
    "totals": {
      "type": "object",
      "required": ["all", "byLayer", "byDomain"],
      "properties": {
        "all": { "type": "integer" },
        "byLayer": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "byDomain": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind", "layer", "domain", "source", "import"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "导出符号名" },
          "kind": { "enum": ["value", "type", "namespace"] },
          "layer": { "enum": ["frontend", "harness", "engine", "platform"] },
          "domain": {
            "type": "string",
            "description": "子域（后端取真实声明文件在 ai-harness/ai-engine/platform 下的聚合段，前端取 ui 子目录 / hooks / design-tokens）"
          },
          "source": {
            "type": "string",
            "description": "声明所在源文件（相对仓库根）"
          },
          "import": { "type": "string", "description": "可直接使用的导入语句" }
        }
      }
    }
  }
}
