flowchart TB
  %% Frontend
  subgraph FE[Frontend - Next.js]
    UIList[AI Writing 列表页<br/>frontend/app/ai-writing/page.tsx]
    UIDetail[项目详情页<br/>frontend/app/ai-writing/:id/page.tsx]
    Store[Zustand Store<br/>frontend/stores/aiWritingStore.ts]
    ApiClient[API Client<br/>frontend/lib/api/ai-writing.ts]
    WsHook[WS Hook<br/>frontend/hooks/useWritingWebSocket.ts]
  end

  %% Backend
  subgraph BE[Backend - NestJS]
    Ctrl[AI Writing Controller<br/>backend/.../ai-writing.controller.ts]
    Gw[AI Writing WS Gateway<br/>backend/.../ai-writing.gateway.ts]
    Emit[WritingEventEmitterService<br/>backend/.../writing-event-emitter.service.ts]

    subgraph Svc[Domain Services]
      Proj[ProjectService]
      Bible[StoryBibleService + Character/World/Timeline/Terminology]
      Chapter[ChapterWritingService]
      Mission[WritingMissionService]
      Consistency[ConsistencyEngineService]
      QGate[QualityGateService]
      QCheck[WritingQualityCheckerService]
      StyleTpl[StyleTemplateService]
    end

    subgraph AI[AI Engine]
      Orchestrator[Teams/MissionOrchestrator]
      LongContent[LongContentEngineService]
      LLM[AiChatService - LLM]
    end

    DB[(PostgreSQL via Prisma)]
  end

  UIList --> Store
  UIDetail --> Store

  Store --> ApiClient --> Ctrl
  UIDetail --> WsHook --> Gw

  Ctrl --> Proj --> DB
  Ctrl --> Bible --> DB
  Ctrl --> Chapter --> DB
  Ctrl --> Consistency --> DB
  Ctrl --> StyleTpl --> DB
  Ctrl --> Mission --> DB

  Mission --> Orchestrator
  Mission --> LongContent
  Mission --> LLM
  QGate --> DB
  QCheck --> LLM

  Mission --> Emit --> Gw
