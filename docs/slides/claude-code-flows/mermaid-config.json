{
  "theme": "dark",
  "themeVariables": {
    "darkMode": true,
    "background": "#0d1117",
    "primaryColor": "#1f2937",
    "primaryTextColor": "#e6edf3",
    "primaryBorderColor": "#58a6ff",
    "lineColor": "#8b949e",
    "secondaryColor": "#1a2825",
    "tertiaryColor": "#231a2e",
    "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, Segoe UI, Helvetica, Arial, sans-serif",
    "fontSize": "15px",
    "noteBkgColor": "#1a2332",
    "noteTextColor": "#e6edf3",
    "noteBorderColor": "#30363d",
    "actorBkg": "#1f2937",
    "actorTextColor": "#e6edf3",
    "actorBorder": "#58a6ff",
    "signalColor": "#8b949e",
    "signalTextColor": "#e6edf3",
    "labelBoxBkgColor": "#161b22",
    "labelBoxBorderColor": "#30363d",
    "labelTextColor": "#e6edf3",
    "edgeLabelBackground": "#161b22",
    "clusterBkg": "#161b22",
    "clusterBorder": "#30363d",
    "titleColor": "#e6edf3"
  },
  "flowchart": {
    "useMaxWidth": false,
    "htmlLabels": true,
    "curve": "basis",
    "padding": 20,
    "nodeSpacing": 40,
    "rankSpacing": 50
  },
  "sequence": {
    "useMaxWidth": false,
    "actorMargin": 100,
    "mirrorActors": false,
    "messageMargin": 50,
    "noteMargin": 15,
    "width": 200,
    "height": 50,
    "boxMargin": 10,
    "boxTextMargin": 10
  }
}
