#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 设置环境变量
export CI=true
export NODE_ENV=test

echo ""
echo "============================================================"
echo "  Pre-push 验证（类型 + 构建 + 变更测试 + UI 一致性）"
echo "  Lint 已在 pre-commit 执行"
echo "============================================================"
echo ""

# ★ 2026-05-05 [task #7] god-class size guard
#   策略：>2500 行的文件 **不许大幅增长**（单次推送 +50 行内可容忍小机制修复，
#   超 +50 行 = 强信号"应该拆分"）。已 god-class 的文件不冻结，但恶性增长拒推。
#   audit:debt 仪表盘持续跟踪存量趋势。
#   设计来源：第三轮审计 — 项目 god-class 3 周内 +67 行无拦截。
echo "[0a/5] god-class size guard..."
GOD_CLASS_THRESHOLD=2500
GOD_CLASS_MAX_GROWTH=50
VIOLATIONS=""
# rename 映射：new_path -> old_path（>=70% 相似度才算 rename，纯重命名 R100，结构整理仍 R09x）
RENAME_MAP=$(git diff --find-renames=70% --name-status origin/main HEAD -- '*.ts' '*.tsx' 2>/dev/null | awk '$1 ~ /^R/ {print $3"|"$2}')
for f in $(git diff --name-only origin/main HEAD -- '*.ts' '*.tsx' 2>/dev/null); do
    [ -f "$f" ] || continue
    cur=$(wc -l < "$f" 2>/dev/null | tr -d ' ')
    [ -n "$cur" ] || continue
    if [ "$cur" -gt "$GOD_CLASS_THRESHOLD" ]; then
        # 取 origin/main 该文件的行数（不存在 = 新文件 / rename target → 用 rename 源文件行数）
        prev=$(git show "origin/main:$f" 2>/dev/null | wc -l | tr -d ' ')
        prev=${prev:-0}
        if [ "$prev" = "0" ]; then
            old_path=$(echo "$RENAME_MAP" | grep "^$f|" | head -1 | cut -d'|' -f2)
            if [ -n "$old_path" ]; then
                prev=$(git show "origin/main:$old_path" 2>/dev/null | wc -l | tr -d ' ')
                prev=${prev:-0}
            fi
        fi
        delta=$((cur - prev))
        if [ "$delta" -gt "$GOD_CLASS_MAX_GROWTH" ]; then
            VIOLATIONS="$VIOLATIONS  $f: $prev → $cur (+$delta, 超 ${GOD_CLASS_MAX_GROWTH} 行容差)\n"
        fi
    fi
done
if [ -n "$VIOLATIONS" ]; then
    echo ""
    echo "  god-class size guard 违规！下列文件 >$GOD_CLASS_THRESHOLD 行且本次净增 >$GOD_CLASS_MAX_GROWTH 行："
    printf "%b" "$VIOLATIONS"
    echo ""
    echo "  策略：god-class 文件单次推送净增量上限 $GOD_CLASS_MAX_GROWTH 行（小修复容忍，大新功能必须拆分）。"
    echo "  超此阈值视为"应该拆类"信号 — 把新增逻辑搬到独立 service / utils 文件。"
    echo ""
    exit 1
fi
echo "  god-class size guard 通过（容差 ±$GOD_CLASS_MAX_GROWTH 行）"
echo ""

# 0. 架构边界看护（锁定 L4→L3→L2.5→L2→L1 单向依赖）
echo "[0/5] 架构边界看护..."
ARCH_LOG=$(mktemp)
(cd backend && npx jest src/__tests__/architecture --no-coverage --forceExit > "$ARCH_LOG" 2>&1) || {
    echo ""
    echo "  架构边界违规！"
    echo "── 最后 30 行输出 ──"
    tail -30 "$ARCH_LOG"
    echo ""
    rm -f "$ARCH_LOG"
    exit 1
}
rm -f "$ARCH_LOG"
echo "  架构边界合规"
echo ""

# 1. 类型检查（并行执行前后端）
echo "[1/5] 类型检查（前后端并行）..."
npx concurrently --kill-others-on-fail --names "fe,be" \
  "npm run type-check:frontend" \
  "npm run type-check:backend" \
  > /dev/null 2>&1 || {
    echo ""
    echo "  类型检查失败！重新运行查看详情:"
    echo ""
    npm run type-check:frontend 2>&1 | tail -20
    echo "---"
    npm run type-check:backend 2>&1 | tail -20
    echo ""
    exit 1
}
echo "  类型检查通过"
echo ""

# 2. 构建检查
echo "[2/5] 后端构建检查..."
BUILD_LOG=$(mktemp)
npm run build:backend > "$BUILD_LOG" 2>&1 || {
    echo ""
    echo "  构建失败！"
    echo "── 最后 20 行输出 ──"
    tail -20 "$BUILD_LOG"
    echo ""
    rm -f "$BUILD_LOG"
    exit 1
}
rm -f "$BUILD_LOG"
echo "  构建检查通过"
echo ""

# 3. 变更相关测试（只跑与本次变更相关的测试；无变更则跳过）
echo "[3/5] 变更相关测试..."
BACKEND_TEST_LOG=$(mktemp)
FRONTEND_TEST_LOG=$(mktemp)
BASE_REF="${PRE_PUSH_BASE_REF:-origin/main}"
BASE_SHA=$(git merge-base "$BASE_REF" HEAD 2>/dev/null || printf "%s" "$BASE_REF")
BACKEND_CHANGED=$(git diff --name-only "$BASE_SHA" HEAD -- 'backend/**' 2>/dev/null)
FRONTEND_CHANGED=$(git diff --name-only "$BASE_SHA" HEAD -- 'frontend/**' 2>/dev/null)
BACKEND_EXIT=0
FRONTEND_EXIT=0

echo "  diff base: $BASE_SHA"

# 2026-05-15: `git push` 把 GIT_INDEX_FILE 等内部 env 注入到 hook 子进程。jest
# --changedSince / vitest --changed 内部调 `git diff` 时拿到 push 临时 index
# 而非工作树 index，参数解析失败 → 吐 `git diff` usage 文本退 1。husky.sh 用
# `sh -e $0` 跑 hook，jest 一退就 abort，连"测试失败"错误信息都来不及打。
# 表象：hook 卡在 "backend: running jest --changedSince=..." 后立刻 exit 1。
# 上面 git diff --name-only "$BASE_SHA" HEAD -- 'backend/**' 在 hook 自身 shell
# 里没问题，所以只需在调用子进程测试之前 unset。
unset GIT_INDEX_FILE GIT_DIR GIT_WORK_TREE GIT_PREFIX GIT_REFLOG_ACTION

if [ -n "$BACKEND_CHANGED" ]; then
    echo "  backend: running jest --changedSince=$BASE_SHA"
    cd backend
    npx jest --changedSince="$BASE_SHA" --passWithNoTests --forceExit > "$BACKEND_TEST_LOG" 2>&1
    BACKEND_EXIT=$?
    cd ..
else
    echo "  backend: no changed files"
    printf '%s\n' "No tests found related to backend changes." > "$BACKEND_TEST_LOG"
fi

if [ -n "$FRONTEND_CHANGED" ]; then
    echo "  frontend: running vitest --changed $BASE_SHA"
    cd frontend
    npx vitest run --changed "$BASE_SHA" --passWithNoTests > "$FRONTEND_TEST_LOG" 2>&1
    FRONTEND_EXIT=$?
    cd ..
else
    echo "  frontend: no changed files"
    printf '%s\n' "No tests found related to frontend changes." > "$FRONTEND_TEST_LOG"
fi

if [ $BACKEND_EXIT -ne 0 ]; then
    echo ""
    echo "  backend 变更相关测试失败！"
    echo "── 最后 30 行输出 ──"
    tail -30 "$BACKEND_TEST_LOG"
    echo ""
    rm -f "$BACKEND_TEST_LOG" "$FRONTEND_TEST_LOG"
    exit 1
fi

if [ $FRONTEND_EXIT -ne 0 ]; then
    echo ""
    echo "  frontend 变更相关测试失败！"
    echo "── 最后 30 行输出 ──"
    tail -30 "$FRONTEND_TEST_LOG"
    echo ""
    rm -f "$BACKEND_TEST_LOG" "$FRONTEND_TEST_LOG"
    exit 1
fi

BACKEND_SUMMARY=$(grep -E "^(Tests|Test Suites|No tests found)" "$BACKEND_TEST_LOG" | tail -3)
FRONTEND_SUMMARY=$(grep -E "^(Tests|Test Suites|No tests found)" "$FRONTEND_TEST_LOG" | tail -3)

if [ -n "$BACKEND_SUMMARY" ]; then
    echo "$BACKEND_SUMMARY" | while read -r line; do echo "  backend: $line"; done
fi
if [ -n "$FRONTEND_SUMMARY" ]; then
    echo "$FRONTEND_SUMMARY" | while read -r line; do echo "  frontend: $line"; done
fi
if [ -z "$BACKEND_SUMMARY" ] && [ -z "$FRONTEND_SUMMARY" ]; then
    echo "  无变更相关测试"
fi
rm -f "$BACKEND_TEST_LOG" "$FRONTEND_TEST_LOG"
echo ""

# 4. UI 一致性看护（warn-only，rollout 期间不阻断 push）
# ★ 2026-05-18 [TOP 1] 前端 UI 一致性源头止血
#   策略：扫描公共组件强制复用 + 任意值 token 违规，与基线对比。
#   首次推送会写出基线（docs/_archive/ui-*-baseline.json）。
#   warn-only 模式：违规不阻断 push，只打印；后续切 SKIP_UI_AUDIT=1 可临时跳过。
#   切 strict 模式：把下方 `if npm run` 改为 `npm run audit:ui-strict || exit 1`。
#   设计文档：docs/guides/testing/frontend-ui-validation.md
echo "[4/5] UI 一致性看护（warn-only）..."
if [ "${SKIP_UI_AUDIT:-0}" = "1" ]; then
    echo "  跳过（SKIP_UI_AUDIT=1）"
else
    UI_AUDIT_LOG=$(mktemp)
    if npm run audit:ui-strict > "$UI_AUDIT_LOG" 2>&1; then
        # 提取最后的汇总行
        grep -E "^\s+(R[1-6]-|T[1-5]-|TOTAL:)" "$UI_AUDIT_LOG" | head -20 | while read -r line; do
            echo "  $line"
        done
        echo "  UI 一致性无回归"
    else
        echo ""
        echo "  ⚠ UI 一致性回归（warn-only，不阻断 push）："
        tail -30 "$UI_AUDIT_LOG"
        echo ""
        echo "  → 详见 docs/guides/testing/frontend-ui-validation.md"
        echo "  → 更新基线：npm run audit:ui-baseline（需 reviewer 同意）"
    fi
    rm -f "$UI_AUDIT_LOG"
fi
echo ""

# 5. i18n 单花括号守护（strict，PR-DR2-FU 系统性 bug 复盘 2026-05-18）
# ★ 项目 interpolate /\{\{(\w+)\}\}/g 只匹配双花括号 — 单花括号 placeholder 永远不替换
echo "[5/5] i18n placeholder 守护..."
if npx tsx scripts/utils/audit-i18n-placeholders.ts; then
    echo "  i18n 0 单花括号占位符"
else
    echo ""
    echo "  ✘ i18n 单花括号占位符回归 — 见上方报告"
    echo "  → 改 frontend/lib/i18n/locales/*.json：{xxx} → {{xxx}}"
    echo "  → 详见 frontend/lib/i18n/i18n-context.tsx:61 interpolate"
    exit 1
fi
echo ""

echo "============================================================"
echo "  所有验证通过"
echo "============================================================"
echo ""
