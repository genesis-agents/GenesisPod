#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 设置环境变量
export CI=true
export NODE_ENV=test

echo ""
echo "════════════════════════════════════════════════════════════"
echo "  Pre-push 验证 (与 CI 相同的检查)"
echo "════════════════════════════════════════════════════════════"
echo ""

# 1. 类型检查 (最重要!)
echo "🔍 [1/4] 类型检查..."
npm run type-check || {
    echo ""
    echo "❌ 类型检查失败！"
    echo "💡 运行 'npm run type-check' 查看详细错误"
    echo ""
    exit 1
}
echo "✓ 类型检查通过"
echo ""

# 2. Lint 检查 (仅类型检查已覆盖关键错误，lint warnings 不阻止 push)
echo "[2/4] Lint 检查 (仅报告，不阻止)..."
npm run lint 2>&1 || true
echo "Lint 检查完成"
echo ""

# 3. 构建检查
echo "🔨 [3/4] 构建检查..."
BUILD_LOG=$(mktemp)
npm run build:backend > "$BUILD_LOG" 2>&1 || {
    echo ""
    echo "❌ 构建失败！"
    echo "── 最后 20 行输出 ──"
    tail -20 "$BUILD_LOG"
    echo ""
    rm -f "$BUILD_LOG"
    exit 1
}
rm -f "$BUILD_LOG"
echo "✓ 构建检查通过"
echo ""

# 4. 快速测试
echo "🧪 [4/4] 快速测试..."
TEST_LOG=$(mktemp)
npm run test:quick > "$TEST_LOG" 2>&1 || {
    echo ""
    echo "❌ 测试失败！push 已阻止"
    echo "── 最后 30 行输出 ──"
    tail -30 "$TEST_LOG"
    echo ""
    rm -f "$TEST_LOG"
    exit 1
}
rm -f "$TEST_LOG"
echo "✓ 测试完成"
echo ""

echo "════════════════════════════════════════════════════════════"
echo "  ✅ 所有验证通过"
echo "════════════════════════════════════════════════════════════"
echo ""
