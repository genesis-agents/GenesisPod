#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 设置环境变量
export CI=true
export NODE_ENV=test

echo ""
echo "============================================================"
echo "  Pre-push 验证（类型 + 构建 + 变更测试）"
echo "  Lint 已在 pre-commit 执行"
echo "============================================================"
echo ""

# ★ 2026-05-05 [task #7] god-class size guard
#   策略：>2500 行的文件 **不许大幅增长**（单次推送 +50 行内可容忍小机制修复，
#   超 +50 行 = 强信号"应该拆分"）。已 god-class 的文件不冻结，但恶性增长拒推。
#   audit:debt 仪表盘持续跟踪存量趋势。
#   设计来源：第三轮审计 — 项目 god-class 3 周内 +67 行无拦截。
echo "[0a/5] god-class size guard..."
GOD_CLASS_THRESHOLD=2500
GOD_CLASS_MAX_GROWTH=50
VIOLATIONS=""
for f in $(git diff --name-only origin/main HEAD -- '*.ts' '*.tsx' 2>/dev/null); do
    [ -f "$f" ] || continue
    cur=$(wc -l < "$f" 2>/dev/null | tr -d ' ')
    [ -n "$cur" ] || continue
    if [ "$cur" -gt "$GOD_CLASS_THRESHOLD" ]; then
        # 取 origin/main 该文件的行数（不存在视为 0 = 新文件）
        prev=$(git show "origin/main:$f" 2>/dev/null | wc -l | tr -d ' ')
        prev=${prev:-0}
        delta=$((cur - prev))
        if [ "$delta" -gt "$GOD_CLASS_MAX_GROWTH" ]; then
            VIOLATIONS="$VIOLATIONS  $f: $prev → $cur (+$delta, 超 ${GOD_CLASS_MAX_GROWTH} 行容差)\n"
        fi
    fi
done
if [ -n "$VIOLATIONS" ]; then
    echo ""
    echo "  god-class size guard 违规！下列文件 >$GOD_CLASS_THRESHOLD 行且本次净增 >$GOD_CLASS_MAX_GROWTH 行："
    printf "%b" "$VIOLATIONS"
    echo ""
    echo "  策略：god-class 文件单次推送净增量上限 $GOD_CLASS_MAX_GROWTH 行（小修复容忍，大新功能必须拆分）。"
    echo "  超此阈值视为"应该拆类"信号 — 把新增逻辑搬到独立 service / utils 文件。"
    echo ""
    exit 1
fi
echo "  god-class size guard 通过（容差 ±$GOD_CLASS_MAX_GROWTH 行）"
echo ""

# 0. 架构边界看护（锁定 L4→L3→L2.5→L2→L1 单向依赖）
echo "[0/5] 架构边界看护..."
ARCH_LOG=$(mktemp)
(cd backend && npx jest src/__tests__/architecture --no-coverage --forceExit > "$ARCH_LOG" 2>&1) || {
    echo ""
    echo "  架构边界违规！"
    echo "── 最后 30 行输出 ──"
    tail -30 "$ARCH_LOG"
    echo ""
    rm -f "$ARCH_LOG"
    exit 1
}
rm -f "$ARCH_LOG"
echo "  架构边界合规"
echo ""

# 1. 类型检查（并行执行前后端）
echo "[1/5] 类型检查（前后端并行）..."
npx concurrently --kill-others-on-fail --names "fe,be" \
  "npm run type-check:frontend" \
  "npm run type-check:backend" \
  > /dev/null 2>&1 || {
    echo ""
    echo "  类型检查失败！重新运行查看详情:"
    echo ""
    npm run type-check:frontend 2>&1 | tail -20
    echo "---"
    npm run type-check:backend 2>&1 | tail -20
    echo ""
    exit 1
}
echo "  类型检查通过"
echo ""

# 2. 构建检查
echo "[2/5] 后端构建检查..."
BUILD_LOG=$(mktemp)
npm run build:backend > "$BUILD_LOG" 2>&1 || {
    echo ""
    echo "  构建失败！"
    echo "── 最后 20 行输出 ──"
    tail -20 "$BUILD_LOG"
    echo ""
    rm -f "$BUILD_LOG"
    exit 1
}
rm -f "$BUILD_LOG"
echo "  构建检查通过"
echo ""

# 3. 变更相关测试（只跑与本次变更相关的测试；无变更则跳过）
echo "[3/5] 变更相关测试..."
TEST_LOG=$(mktemp)

# 后端：只跑与 origin/main 之后变更文件相关的测试
# --forceExit：个别测试（SSE / setInterval）会留 open handle，不加会卡很久
cd backend
npx jest --changedSince=origin/main --passWithNoTests --forceExit > "$TEST_LOG" 2>&1
BACKEND_EXIT=$?
cd ..

# 前端：只跑与变更相关的测试
cd frontend
npx vitest run --changed HEAD~1 --passWithNoTests >> "$TEST_LOG" 2>&1 || true
cd ..

if [ $BACKEND_EXIT -ne 0 ]; then
    echo ""
    echo "  测试失败！"
    echo "── 最后 30 行输出 ──"
    tail -30 "$TEST_LOG"
    echo ""
    rm -f "$TEST_LOG"
    exit 1
fi

SUMMARY=$(grep -E "^(Tests|Test Suites|No tests found)" "$TEST_LOG" | tail -3)
if [ -n "$SUMMARY" ]; then
    echo "$SUMMARY" | while read -r line; do echo "  $line"; done
else
    echo "  无变更相关测试"
fi
rm -f "$TEST_LOG"
echo ""

echo "============================================================"
echo "  所有验证通过"
echo "============================================================"
echo ""
