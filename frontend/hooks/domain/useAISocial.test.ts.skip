/**
 * AI Social Hooks Unit Tests
 *
 * Comprehensive tests for AI Social module hooks
 * - useSocialConnections
 * - useSocialContents
 * - useSocialAIEngine
 * - useSocialReview
 * - useSocialPublish
 * - useSocialSources
 */

import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';
import { renderHook, act, waitFor } from '@testing-library/react';
import {
  useSocialConnections,
  useSocialContents,
  useSocialAIEngine,
  useSocialReview,
  useSocialPublish,
  useSocialSources,
  useAISocial,
} from './useAISocial';
import * as apiSocial from '@/services/ai-social/api';

// Mock the entire API module
vi.mock('@/services/ai-social/api', () => ({
  // Connection APIs
  getConnections: vi.fn(),
  getConnection: vi.fn(),
  getConnectionByPlatform: vi.fn(),
  upsertConnection: vi.fn(),
  deleteConnection: vi.fn(),
  testConnection: vi.fn(),
  refreshConnection: vi.fn(),
  initConnection: vi.fn(),
  verifyConnection: vi.fn(),
  // Content APIs
  getContents: vi.fn(),
  getContent: vi.fn(),
  createContent: vi.fn(),
  updateContent: vi.fn(),
  deleteContent: vi.fn(),
  // AI Engine APIs
  processUrl: vi.fn(),
  processSource: vi.fn(),
  regenerateContent: vi.fn(),
  checkCompliance: vi.fn(),
  // Review APIs
  approveContent: vi.fn(),
  rejectContent: vi.fn(),
  requestRevision: vi.fn(),
  resubmitForReview: vi.fn(),
  // Publish APIs
  publishContent: vi.fn(),
  scheduleContent: vi.fn(),
  cancelSchedule: vi.fn(),
  getPublishLogs: vi.fn(),
  // Source APIs
  getExploreSources: vi.fn(),
  getResearchSources: vi.fn(),
  getOfficeSources: vi.fn(),
  getWritingSources: vi.fn(),
}));

// ==================== Mock Data ====================

const mockConnection = {
  id: 'conn-1',
  userId: 'user-1',
  platformType: 'WECHAT_MP',
  accountName: 'Test Account',
  accountId: 'test-123',
  avatarUrl: 'https://example.com/avatar.jpg',
  sessionData: null,
  isActive: true,
  lastCheckAt: '2025-01-25T00:00:00Z',
  expiresAt: null,
  createdAt: '2025-01-01T00:00:00Z',
  updatedAt: '2025-01-25T00:00:00Z',
};

const mockContent = {
  id: 'content-1',
  userId: 'user-1',
  connectionId: 'conn-1',
  contentType: 'WECHAT_ARTICLE',
  sourceType: 'MANUAL',
  sourceId: null,
  sourceUrl: null,
  title: 'Test Article',
  content: 'Test content body',
  author: 'Test Author',
  digest: 'Test digest',
  coverImageUrl: null,
  images: [],
  tags: ['test'],
  location: null,
  status: 'DRAFT',
  aiProcessLog: null,
  aiSuggestions: null,
  reviewStatus: 'PENDING',
  reviewedById: null,
  reviewedAt: null,
  reviewNote: null,
  complianceCheck: null,
  scheduledAt: null,
  publishedAt: null,
  autoPublish: false,
  externalId: null,
  externalUrl: null,
  errorMessage: null,
  retryCount: 0,
  createdAt: '2025-01-01T00:00:00Z',
  updatedAt: '2025-01-25T00:00:00Z',
};

const mockPublishLog = {
  id: 'log-1',
  contentId: 'content-1',
  action: 'PUBLISH',
  status: 'SUCCESS',
  details: null,
  errorMessage: null,
  screenshotUrl: null,
  createdAt: '2025-01-25T00:00:00Z',
};

// ==================== useSocialConnections Tests ====================

describe('useSocialConnections', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  afterEach(() => {
    vi.clearAllMocks();
  });

  describe('Initial State', () => {
    it('should initialize with empty state', () => {
      const { result } = renderHook(() => useSocialConnections());

      expect(result.current.connections).toEqual([]);
      expect(result.current.loading).toBe(false);
      expect(result.current.error).toBeNull();
    });
  });

  describe('fetchConnections', () => {
    it('should fetch connections successfully', async () => {
      const mockConnections = [mockConnection];
      vi.mocked(apiSocial.getConnections).mockResolvedValue(mockConnections);

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const data = await result.current.fetchConnections();
        expect(data).toEqual(mockConnections);
      });

      expect(result.current.connections).toEqual(mockConnections);
      expect(result.current.loading).toBe(false);
      expect(result.current.error).toBeNull();
      expect(apiSocial.getConnections).toHaveBeenCalledTimes(1);
    });

    it('should handle fetch error', async () => {
      const errorMessage = 'Network error';
      vi.mocked(apiSocial.getConnections).mockRejectedValue(
        new Error(errorMessage)
      );

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const data = await result.current.fetchConnections();
        expect(data).toEqual([]);
      });

      expect(result.current.error).toBe('Network error');
      expect(result.current.loading).toBe(false);
    });

    it('should set loading state during fetch', async () => {
      vi.mocked(apiSocial.getConnections).mockImplementation(
        () =>
          new Promise((resolve) => {
            setTimeout(() => resolve([mockConnection]), 100);
          })
      );

      const { result } = renderHook(() => useSocialConnections());

      act(() => {
        result.current.fetchConnections();
      });

      expect(result.current.loading).toBe(true);

      await waitFor(() => {
        expect(result.current.loading).toBe(false);
      });
    });
  });

  describe('fetchConnection', () => {
    it('should fetch single connection by id', async () => {
      vi.mocked(apiSocial.getConnection).mockResolvedValue(mockConnection);

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const connection = await result.current.fetchConnection('conn-1');
        expect(connection).toEqual(mockConnection);
      });

      expect(apiSocial.getConnection).toHaveBeenCalledWith('conn-1');
    });

    it('should handle fetch connection error', async () => {
      vi.mocked(apiSocial.getConnection).mockRejectedValue(
        new Error('Not found')
      );

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const connection = await result.current.fetchConnection('invalid-id');
        expect(connection).toBeNull();
      });

      expect(result.current.error).toBe('Not found');
    });
  });

  describe('fetchConnectionByPlatform', () => {
    it('should fetch connection by platform type', async () => {
      vi.mocked(apiSocial.getConnectionByPlatform).mockResolvedValue(
        mockConnection
      );

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const connection =
          await result.current.fetchConnectionByPlatform('WECHAT_MP');
        expect(connection).toEqual(mockConnection);
      });

      expect(apiSocial.getConnectionByPlatform).toHaveBeenCalledWith(
        'WECHAT_MP'
      );
    });
  });

  describe('saveConnection', () => {
    it('should create new connection', async () => {
      const config = {
        cookies: 'test-cookie-data',
        sessionData: { key: 'value' },
      };
      vi.mocked(apiSocial.upsertConnection).mockResolvedValue(mockConnection);

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const connection = await result.current.saveConnection(
          'WECHAT_MP',
          config
        );
        expect(connection).toEqual(mockConnection);
      });

      expect(result.current.connections).toEqual([mockConnection]);
      expect(apiSocial.upsertConnection).toHaveBeenCalledWith(
        'WECHAT_MP',
        config
      );
    });

    it('should update existing connection', async () => {
      const updatedConnection = { ...mockConnection, accountName: 'Updated' };
      vi.mocked(apiSocial.getConnections).mockResolvedValue([mockConnection]);
      vi.mocked(apiSocial.upsertConnection).mockResolvedValue(
        updatedConnection
      );

      const { result } = renderHook(() => useSocialConnections());

      // First fetch to populate connections
      await act(async () => {
        await result.current.fetchConnections();
      });

      // Then update
      await act(async () => {
        await result.current.saveConnection('WECHAT_MP', {
          cookies: 'updated-cookies',
          sessionData: { updated: true },
        });
      });

      expect(result.current.connections[0].accountName).toBe('Updated');
    });

    it('should handle save error', async () => {
      vi.mocked(apiSocial.upsertConnection).mockRejectedValue(
        new Error('Save failed')
      );

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const connection = await result.current.saveConnection('WECHAT_MP', {
          cookies: 'test-cookies',
          sessionData: { test: true },
        });
        expect(connection).toBeNull();
      });

      expect(result.current.error).toBe('Save failed');
    });
  });

  describe('removeConnection', () => {
    it('should delete connection successfully', async () => {
      vi.mocked(apiSocial.getConnections).mockResolvedValue([mockConnection]);
      vi.mocked(apiSocial.deleteConnection).mockResolvedValue(undefined);

      const { result } = renderHook(() => useSocialConnections());

      // First fetch to populate connections
      await act(async () => {
        await result.current.fetchConnections();
      });

      expect(result.current.connections).toHaveLength(1);

      // Then delete
      await act(async () => {
        const success = await result.current.removeConnection('WECHAT_MP');
        expect(success).toBe(true);
      });

      expect(result.current.connections).toHaveLength(0);
      expect(apiSocial.deleteConnection).toHaveBeenCalledWith('WECHAT_MP');
    });

    it('should handle delete error', async () => {
      vi.mocked(apiSocial.deleteConnection).mockRejectedValue(
        new Error('Delete failed')
      );

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const success = await result.current.removeConnection('WECHAT_MP');
        expect(success).toBe(false);
      });

      expect(result.current.error).toBe('Delete failed');
    });
  });

  describe('testConnection', () => {
    it('should test connection successfully', async () => {
      const testResult = { success: true, message: 'Connected' };
      vi.mocked(apiSocial.testConnection).mockResolvedValue(testResult);

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const result_test = await result.current.testConnection('conn-1');
        expect(result_test).toEqual(testResult);
      });
    });

    it('should handle test failure', async () => {
      vi.mocked(apiSocial.testConnection).mockRejectedValue(
        new Error('Test failed')
      );

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const result_test = await result.current.testConnection('conn-1');
        expect(result_test.success).toBe(false);
        expect(result_test.message).toBe('Test failed');
      });
    });
  });

  describe('refreshConnection', () => {
    it('should refresh connection successfully', async () => {
      const refreshedConnection = {
        ...mockConnection,
        lastCheckAt: '2025-01-26T00:00:00Z',
      };
      vi.mocked(apiSocial.getConnections).mockResolvedValue([mockConnection]);
      vi.mocked(apiSocial.refreshConnection).mockResolvedValue(
        refreshedConnection
      );

      const { result } = renderHook(() => useSocialConnections());

      // First fetch to populate connections
      await act(async () => {
        await result.current.fetchConnections();
      });

      // Then refresh
      await act(async () => {
        const connection = await result.current.refreshConnection('conn-1');
        expect(connection).toEqual(refreshedConnection);
      });

      expect(result.current.connections[0].lastCheckAt).toBe(
        '2025-01-26T00:00:00Z'
      );
    });

    it('should handle refresh error', async () => {
      vi.mocked(apiSocial.refreshConnection).mockRejectedValue(
        new Error('Refresh failed')
      );

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const connection = await result.current.refreshConnection('conn-1');
        expect(connection).toBeNull();
      });

      expect(result.current.error).toBe('Refresh failed');
    });
  });

  describe('startConnection', () => {
    it('should start OAuth flow', async () => {
      const initResponse = {
        status: 'pending',
        sessionKey: 'test-session-key',
        screenshot: 'data:image/png;base64,...',
        message: 'Please scan QR code',
      };
      vi.mocked(apiSocial.initConnection).mockResolvedValue(initResponse);

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const response = await result.current.startConnection('WECHAT_MP');
        expect(response).toEqual(initResponse);
      });
    });

    it('should handle existing connection', async () => {
      const initResponse = {
        status: 'existing',
        connection: mockConnection,
        message: 'Connection already exists',
      };
      vi.mocked(apiSocial.initConnection).mockResolvedValue(initResponse);

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const response = await result.current.startConnection('WECHAT_MP');
        expect(response).toEqual(initResponse);
      });

      expect(result.current.connections).toEqual([mockConnection]);
    });
  });

  describe('checkConnection', () => {
    it('should verify connection successfully', async () => {
      const verifyResponse = {
        status: 'success',
        connection: mockConnection,
        message: 'Connection verified successfully',
      };
      vi.mocked(apiSocial.verifyConnection).mockResolvedValue(verifyResponse);

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const response = await result.current.checkConnection('WECHAT_MP');
        expect(response).toEqual(verifyResponse);
      });

      expect(result.current.connections).toEqual([mockConnection]);
    });

    it('should handle verification error', async () => {
      vi.mocked(apiSocial.verifyConnection).mockRejectedValue(
        new Error('Verification failed')
      );

      const { result } = renderHook(() => useSocialConnections());

      await act(async () => {
        const response = await result.current.checkConnection('WECHAT_MP');
        expect(response.status).toBe('error');
        expect(response.message).toBe('Verification failed');
      });
    });
  });
});

// ==================== useSocialContents Tests ====================

describe('useSocialContents', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  describe('Initial State', () => {
    it('should initialize with empty state', () => {
      const { result } = renderHook(() => useSocialContents());

      expect(result.current.contents).toEqual([]);
      expect(result.current.total).toBe(0);
      expect(result.current.loading).toBe(false);
      expect(result.current.error).toBeNull();
    });
  });

  describe('fetchContents', () => {
    it('should fetch contents successfully', async () => {
      const mockResponse = {
        items: [mockContent],
        total: 1,
      };
      vi.mocked(apiSocial.getContents).mockResolvedValue(mockResponse);

      const { result } = renderHook(() => useSocialContents());

      await act(async () => {
        const data = await result.current.fetchContents();
        expect(data).toEqual(mockResponse);
      });

      expect(result.current.contents).toEqual([mockContent]);
      expect(result.current.total).toBe(1);
      expect(result.current.loading).toBe(false);
    });

    it('should filter by status', async () => {
      const mockResponse = {
        items: [mockContent],
        total: 1,
      };
      vi.mocked(apiSocial.getContents).mockResolvedValue(mockResponse);

      const { result } = renderHook(() => useSocialContents());

      await act(async () => {
        await result.current.fetchContents({ status: 'DRAFT' });
      });

      expect(apiSocial.getContents).toHaveBeenCalledWith({ status: 'DRAFT' });
    });

    it('should handle fetch error', async () => {
      vi.mocked(apiSocial.getContents).mockRejectedValue(
        new Error('Fetch failed')
      );

      const { result } = renderHook(() => useSocialContents());

      await act(async () => {
        const data = await result.current.fetchContents();
        expect(data).toEqual({ items: [], total: 0 });
      });

      expect(result.current.error).toBe('Fetch failed');
    });

    it('should support pagination', async () => {
      const mockResponse = {
        items: [mockContent],
        total: 10,
      };
      vi.mocked(apiSocial.getContents).mockResolvedValue(mockResponse);

      const { result } = renderHook(() => useSocialContents());

      await act(async () => {
        await result.current.fetchContents({ limit: 5, offset: 5 });
      });

      expect(apiSocial.getContents).toHaveBeenCalledWith({
        limit: 5,
        offset: 5,
      });
    });
  });

  describe('fetchContent', () => {
    it('should fetch single content by id', async () => {
      vi.mocked(apiSocial.getContent).mockResolvedValue(mockContent);

      const { result } = renderHook(() => useSocialContents());

      await act(async () => {
        const content = await result.current.fetchContent('content-1');
        expect(content).toEqual(mockContent);
      });
    });

    it('should handle fetch content error', async () => {
      vi.mocked(apiSocial.getContent).mockRejectedValue(new Error('Not found'));

      const { result } = renderHook(() => useSocialContents());

      await act(async () => {
        const content = await result.current.fetchContent('invalid-id');
        expect(content).toBeNull();
      });

      expect(result.current.error).toBe('Not found');
    });
  });

  describe('addContent', () => {
    it('should create content successfully', async () => {
      const dto = {
        contentType: 'WECHAT_ARTICLE',
        sourceType: 'MANUAL',
        title: 'New Article',
        content: 'Content body',
      };
      vi.mocked(apiSocial.createContent).mockResolvedValue(mockContent);

      const { result } = renderHook(() => useSocialContents());

      await act(async () => {
        const content = await result.current.addContent(dto);
        expect(content).toEqual(mockContent);
      });

      expect(result.current.contents).toEqual([mockContent]);
      expect(result.current.total).toBe(1);
    });

    it('should handle create error', async () => {
      vi.mocked(apiSocial.createContent).mockRejectedValue(
        new Error('Create failed')
      );

      const { result } = renderHook(() => useSocialContents());

      await act(async () => {
        const content = await result.current.addContent({
          contentType: 'WECHAT_ARTICLE',
          sourceType: 'MANUAL',
          title: 'Test',
          content: 'Test',
        });
        expect(content).toBeNull();
      });

      expect(result.current.error).toBe('Create failed');
    });
  });

  describe('editContent', () => {
    it('should update content successfully', async () => {
      const updatedContent = { ...mockContent, title: 'Updated Title' };
      vi.mocked(apiSocial.getContents).mockResolvedValue({
        items: [mockContent],
        total: 1,
      });
      vi.mocked(apiSocial.updateContent).mockResolvedValue(updatedContent);

      const { result } = renderHook(() => useSocialContents());

      // First fetch to populate contents
      await act(async () => {
        await result.current.fetchContents();
      });

      // Then update
      await act(async () => {
        await result.current.editContent('content-1', {
          title: 'Updated Title',
        });
      });

      expect(result.current.contents[0].title).toBe('Updated Title');
    });

    it('should handle update error', async () => {
      vi.mocked(apiSocial.updateContent).mockRejectedValue(
        new Error('Update failed')
      );

      const { result } = renderHook(() => useSocialContents());

      await act(async () => {
        const content = await result.current.editContent('content-1', {
          title: 'Test',
        });
        expect(content).toBeNull();
      });

      expect(result.current.error).toBe('Update failed');
    });
  });

  describe('removeContent', () => {
    it('should delete content successfully', async () => {
      vi.mocked(apiSocial.getContents).mockResolvedValue({
        items: [mockContent],
        total: 1,
      });
      vi.mocked(apiSocial.deleteContent).mockResolvedValue(undefined);

      const { result } = renderHook(() => useSocialContents());

      // First fetch to populate contents
      await act(async () => {
        await result.current.fetchContents();
      });

      expect(result.current.contents).toHaveLength(1);
      expect(result.current.total).toBe(1);

      // Then delete
      await act(async () => {
        const success = await result.current.removeContent('content-1');
        expect(success).toBe(true);
      });

      expect(result.current.contents).toHaveLength(0);
      expect(result.current.total).toBe(0);
    });

    it('should handle delete error', async () => {
      vi.mocked(apiSocial.deleteContent).mockRejectedValue(
        new Error('Delete failed')
      );

      const { result } = renderHook(() => useSocialContents());

      await act(async () => {
        const success = await result.current.removeContent('content-1');
        expect(success).toBe(false);
      });

      expect(result.current.error).toBe('Delete failed');
    });
  });
});

// ==================== useSocialAIEngine Tests ====================

describe('useSocialAIEngine', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  describe('Initial State', () => {
    it('should initialize with correct state', () => {
      const { result } = renderHook(() => useSocialAIEngine());

      expect(result.current.loading).toBe(false);
      expect(result.current.error).toBeNull();
    });
  });

  describe('processFromUrl', () => {
    const mockProcessResponse = {
      content: mockContent,
      checkResult: {
        passed: true,
        issues: [],
        checkedAt: '2024-01-15T10:00:00Z',
      },
      message: 'Content processed successfully',
    };

    it('should process URL successfully', async () => {
      const dto = {
        url: 'https://example.com/article',
        targetType: 'WECHAT_ARTICLE',
      };
      vi.mocked(apiSocial.processUrl).mockResolvedValue(mockProcessResponse);

      const { result } = renderHook(() => useSocialAIEngine());

      await act(async () => {
        const response = await result.current.processFromUrl(dto);
        expect(response).toEqual(mockProcessResponse);
      });

      expect(result.current.loading).toBe(false);
      expect(result.current.error).toBeNull();
    });

    it('should handle processing error and re-throw', async () => {
      const dto = {
        url: 'https://invalid.com',
        targetType: 'WECHAT_ARTICLE',
      };
      vi.mocked(apiSocial.processUrl).mockRejectedValue(
        new Error('Invalid URL')
      );

      const { result } = renderHook(() => useSocialAIEngine());

      await act(async () => {
        try {
          await result.current.processFromUrl(dto);
          // Should not reach here
          expect(true).toBe(false);
        } catch (error) {
          expect(error).toBeInstanceOf(Error);
          expect((error as Error).message).toBe('Invalid URL');
        }
      });

      expect(result.current.error).toBe('Invalid URL');
      expect(result.current.loading).toBe(false);
    });

    it('should set loading state during processing', async () => {
      const dto = {
        url: 'https://example.com',
        targetType: 'WECHAT_ARTICLE',
      };
      vi.mocked(apiSocial.processUrl).mockImplementation(
        () =>
          new Promise((resolve) => {
            setTimeout(() => resolve(mockProcessResponse), 100);
          })
      );

      const { result } = renderHook(() => useSocialAIEngine());

      act(() => {
        result.current.processFromUrl(dto);
      });

      expect(result.current.loading).toBe(true);

      await waitFor(() => {
        expect(result.current.loading).toBe(false);
      });
    });
  });

  describe('processFromSource', () => {
    const mockSourceResponse = {
      content: mockContent,
      checkResult: {
        passed: true,
        issues: [],
        checkedAt: '2024-01-15T10:00:00Z',
      },
      message: 'Source processed successfully',
    };

    it('should process source successfully', async () => {
      const dto = {
        sourceType: 'AI_RESEARCH',
        sourceId: 'research-1',
        targetType: 'WECHAT_ARTICLE',
      };
      vi.mocked(apiSocial.processSource).mockResolvedValue(mockSourceResponse);

      const { result } = renderHook(() => useSocialAIEngine());

      await act(async () => {
        const response = await result.current.processFromSource(dto);
        expect(response).toEqual(mockSourceResponse);
      });

      expect(apiSocial.processSource).toHaveBeenCalledWith(dto);
    });

    it('should handle processing error', async () => {
      const dto = {
        sourceType: 'AI_RESEARCH',
        sourceId: 'invalid',
        targetType: 'WECHAT_ARTICLE',
      };
      vi.mocked(apiSocial.processSource).mockRejectedValue(
        new Error('Source not found')
      );

      const { result } = renderHook(() => useSocialAIEngine());

      await act(async () => {
        try {
          await result.current.processFromSource(dto);
          expect(true).toBe(false);
        } catch (error) {
          expect((error as Error).message).toBe('Source not found');
        }
      });

      expect(result.current.error).toBe('Source not found');
    });
  });

  describe('regenerate', () => {
    const mockRegenerateResponse = {
      content: { ...mockContent, content: 'Regenerated' },
      checkResult: {
        passed: true,
        issues: [],
        checkedAt: '2024-01-15T10:00:00Z',
      },
      message: 'Content regenerated successfully',
    };

    it('should regenerate content successfully', async () => {
      vi.mocked(apiSocial.regenerateContent).mockResolvedValue(
        mockRegenerateResponse
      );

      const { result } = renderHook(() => useSocialAIEngine());

      await act(async () => {
        const response = await result.current.regenerate('content-1');
        expect(response).toEqual(mockRegenerateResponse);
      });
    });

    it('should handle regeneration error', async () => {
      vi.mocked(apiSocial.regenerateContent).mockRejectedValue(
        new Error('Regeneration failed')
      );

      const { result } = renderHook(() => useSocialAIEngine());

      await act(async () => {
        const response = await result.current.regenerate('content-1');
        expect(response).toBeNull();
      });

      expect(result.current.error).toBe('Regeneration failed');
    });
  });

  describe('checkCompliance', () => {
    it('should check compliance successfully', async () => {
      const complianceResult = {
        passed: true,
        issues: [],
        checkedAt: '2024-01-15T10:00:00Z',
      };
      vi.mocked(apiSocial.checkCompliance).mockResolvedValue(complianceResult);

      const { result } = renderHook(() => useSocialAIEngine());

      await act(async () => {
        const result_check = await result.current.checkCompliance('content-1');
        expect(result_check).toEqual(complianceResult);
      });
    });

    it('should handle compliance check error', async () => {
      vi.mocked(apiSocial.checkCompliance).mockRejectedValue(
        new Error('Check failed')
      );

      const { result } = renderHook(() => useSocialAIEngine());

      await act(async () => {
        const result_check = await result.current.checkCompliance('content-1');
        expect(result_check).toBeNull();
      });

      expect(result.current.error).toBe('Check failed');
    });
  });
});

// ==================== useSocialReview Tests ====================

describe('useSocialReview', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  describe('approve', () => {
    it('should approve content successfully', async () => {
      const approvedContent = {
        ...mockContent,
        reviewStatus: 'APPROVED',
      };
      vi.mocked(apiSocial.approveContent).mockResolvedValue(approvedContent);

      const { result } = renderHook(() => useSocialReview());

      await act(async () => {
        const content = await result.current.approve('content-1', 'Looks good');
        expect(content).toEqual(approvedContent);
      });

      expect(apiSocial.approveContent).toHaveBeenCalledWith(
        'content-1',
        'Looks good'
      );
    });
  });

  describe('reject', () => {
    it('should reject content successfully', async () => {
      const rejectedContent = {
        ...mockContent,
        reviewStatus: 'REJECTED',
      };
      vi.mocked(apiSocial.rejectContent).mockResolvedValue(rejectedContent);

      const { result } = renderHook(() => useSocialReview());

      await act(async () => {
        const content = await result.current.reject(
          'content-1',
          'Not suitable'
        );
        expect(content).toEqual(rejectedContent);
      });

      expect(apiSocial.rejectContent).toHaveBeenCalledWith(
        'content-1',
        'Not suitable'
      );
    });
  });

  describe('requestRevision', () => {
    it('should request revision successfully', async () => {
      const revisionContent = {
        ...mockContent,
        reviewStatus: 'REVISION_REQUESTED',
      };
      vi.mocked(apiSocial.requestRevision).mockResolvedValue(revisionContent);

      const { result } = renderHook(() => useSocialReview());

      await act(async () => {
        const content = await result.current.requestRevision(
          'content-1',
          'Please fix typos'
        );
        expect(content).toEqual(revisionContent);
      });
    });
  });

  describe('resubmit', () => {
    it('should resubmit for review successfully', async () => {
      const resubmittedContent = {
        ...mockContent,
        reviewStatus: 'PENDING',
      };
      vi.mocked(apiSocial.resubmitForReview).mockResolvedValue(
        resubmittedContent
      );

      const { result } = renderHook(() => useSocialReview());

      await act(async () => {
        const content = await result.current.resubmit('content-1');
        expect(content).toEqual(resubmittedContent);
      });
    });
  });
});

// ==================== useSocialPublish Tests ====================

describe('useSocialPublish', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  describe('Initial State', () => {
    it('should initialize with empty logs', () => {
      const { result } = renderHook(() => useSocialPublish());

      expect(result.current.logs).toEqual([]);
      expect(result.current.loading).toBe(false);
      expect(result.current.error).toBeNull();
    });
  });

  describe('publish', () => {
    it('should publish content successfully', async () => {
      const publishResult = { success: true };
      vi.mocked(apiSocial.publishContent).mockResolvedValue(publishResult);

      const { result } = renderHook(() => useSocialPublish());

      await act(async () => {
        const result_publish = await result.current.publish('content-1');
        expect(result_publish).toEqual(publishResult);
      });

      expect(apiSocial.publishContent).toHaveBeenCalledWith(
        'content-1',
        undefined
      );
    });

    it('should publish with specific connection', async () => {
      const publishResult = { success: true };
      vi.mocked(apiSocial.publishContent).mockResolvedValue(publishResult);

      const { result } = renderHook(() => useSocialPublish());

      await act(async () => {
        await result.current.publish('content-1', 'conn-1');
      });

      expect(apiSocial.publishContent).toHaveBeenCalledWith('content-1', {
        connectionId: 'conn-1',
      });
    });

    it('should handle publish error', async () => {
      vi.mocked(apiSocial.publishContent).mockRejectedValue(
        new Error('Publish failed')
      );

      const { result } = renderHook(() => useSocialPublish());

      await act(async () => {
        const result_publish = await result.current.publish('content-1');
        expect(result_publish.success).toBe(false);
        expect(result_publish.errorMessage).toBe('Publish failed');
      });

      expect(result.current.error).toBe('Publish failed');
    });
  });

  describe('schedule', () => {
    it('should schedule content successfully', async () => {
      const scheduledContent = {
        ...mockContent,
        scheduledAt: '2025-02-01T10:00:00Z',
      };
      vi.mocked(apiSocial.scheduleContent).mockResolvedValue(scheduledContent);

      const { result } = renderHook(() => useSocialPublish());

      await act(async () => {
        const content = await result.current.schedule(
          'content-1',
          '2025-02-01T10:00:00Z'
        );
        expect(content).toEqual(scheduledContent);
      });
    });

    it('should schedule with specific connection', async () => {
      const scheduledContent = { ...mockContent, scheduledAt: '2025-02-01' };
      vi.mocked(apiSocial.scheduleContent).mockResolvedValue(scheduledContent);

      const { result } = renderHook(() => useSocialPublish());

      await act(async () => {
        await result.current.schedule('content-1', '2025-02-01', 'conn-1');
      });

      expect(apiSocial.scheduleContent).toHaveBeenCalledWith(
        'content-1',
        '2025-02-01',
        'conn-1'
      );
    });
  });

  describe('unschedule', () => {
    it('should cancel schedule successfully', async () => {
      const unscheduledContent = { ...mockContent, scheduledAt: null };
      vi.mocked(apiSocial.cancelSchedule).mockResolvedValue(unscheduledContent);

      const { result } = renderHook(() => useSocialPublish());

      await act(async () => {
        const content = await result.current.unschedule('content-1');
        expect(content).toEqual(unscheduledContent);
      });
    });
  });

  describe('fetchLogs', () => {
    it('should fetch publish logs successfully', async () => {
      const logs = [mockPublishLog];
      vi.mocked(apiSocial.getPublishLogs).mockResolvedValue(logs);

      const { result } = renderHook(() => useSocialPublish());

      await act(async () => {
        const fetchedLogs = await result.current.fetchLogs('content-1');
        expect(fetchedLogs).toEqual(logs);
      });

      expect(result.current.logs).toEqual(logs);
    });
  });
});

// ==================== useSocialSources Tests ====================

describe('useSocialSources', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  const mockSourceResponse = {
    items: [
      { id: 'source-1', title: 'Source 1', type: 'article' },
      { id: 'source-2', title: 'Source 2', type: 'report' },
    ],
    total: 2,
  };

  describe('fetchExplore', () => {
    it('should fetch explore sources successfully', async () => {
      vi.mocked(apiSocial.getExploreSources).mockResolvedValue(
        mockSourceResponse
      );

      const { result } = renderHook(() => useSocialSources());

      await act(async () => {
        const data = await result.current.fetchExplore();
        expect(data).toEqual(mockSourceResponse);
      });

      expect(apiSocial.getExploreSources).toHaveBeenCalledWith(undefined);
    });

    it('should support pagination', async () => {
      vi.mocked(apiSocial.getExploreSources).mockResolvedValue(
        mockSourceResponse
      );

      const { result } = renderHook(() => useSocialSources());

      await act(async () => {
        await result.current.fetchExplore({ limit: 10, offset: 0 });
      });

      expect(apiSocial.getExploreSources).toHaveBeenCalledWith({
        limit: 10,
        offset: 0,
      });
    });
  });

  describe('fetchResearch', () => {
    it('should fetch research sources successfully', async () => {
      vi.mocked(apiSocial.getResearchSources).mockResolvedValue(
        mockSourceResponse
      );

      const { result } = renderHook(() => useSocialSources());

      await act(async () => {
        const data = await result.current.fetchResearch();
        expect(data).toEqual(mockSourceResponse);
      });
    });
  });

  describe('fetchOffice', () => {
    it('should fetch office sources successfully', async () => {
      vi.mocked(apiSocial.getOfficeSources).mockResolvedValue(
        mockSourceResponse
      );

      const { result } = renderHook(() => useSocialSources());

      await act(async () => {
        const data = await result.current.fetchOffice();
        expect(data).toEqual(mockSourceResponse);
      });
    });
  });

  describe('fetchWriting', () => {
    it('should fetch writing sources successfully', async () => {
      vi.mocked(apiSocial.getWritingSources).mockResolvedValue(
        mockSourceResponse
      );

      const { result } = renderHook(() => useSocialSources());

      await act(async () => {
        const data = await result.current.fetchWriting();
        expect(data).toEqual(mockSourceResponse);
      });
    });
  });
});

// ==================== useAISocial Combined Hook Tests ====================

describe('useAISocial', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  it('should provide all sub-hooks', () => {
    const { result } = renderHook(() => useAISocial());

    expect(result.current).toHaveProperty('connections');
    expect(result.current).toHaveProperty('contents');
    expect(result.current).toHaveProperty('aiEngine');
    expect(result.current).toHaveProperty('review');
    expect(result.current).toHaveProperty('publish');
    expect(result.current).toHaveProperty('sources');
  });

  it('should have working connections hook', async () => {
    vi.mocked(apiSocial.getConnections).mockResolvedValue([mockConnection]);

    const { result } = renderHook(() => useAISocial());

    await act(async () => {
      await result.current.connections.fetchConnections();
    });

    expect(result.current.connections.connections).toEqual([mockConnection]);
  });

  it('should have working contents hook', async () => {
    vi.mocked(apiSocial.getContents).mockResolvedValue({
      items: [mockContent],
      total: 1,
    });

    const { result } = renderHook(() => useAISocial());

    await act(async () => {
      await result.current.contents.fetchContents();
    });

    expect(result.current.contents.contents).toEqual([mockContent]);
  });
});
