{
  "ignorePatterns": ["next.config.js", "scripts/**/*.js"],
  "extends": [
    "next/core-web-vitals",
    "plugin:@typescript-eslint/recommended",
    "plugin:@typescript-eslint/recommended-requiring-type-checking",
    "plugin:react-hooks/recommended",
    "prettier"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": "./tsconfig.json",
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint", "react-hooks"],
  "rules": {
    // React规则
    "react/no-unescaped-entities": "off",
    "react/jsx-no-target-blank": "error",
    "react/jsx-key": "error",
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "warn",

    // Next.js规则
    "@next/next/no-page-custom-font": "off",
    "@next/next/no-html-link-for-pages": "error",

    // TypeScript规则
    "@typescript-eslint/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_"
      }
    ],
    "@typescript-eslint/no-explicit-any": "error", // Now enforced - any types must be justified with eslint-disable
    "@typescript-eslint/no-non-null-assertion": "warn",
    "@typescript-eslint/explicit-function-return-type": "off",
    "@typescript-eslint/explicit-module-boundary-types": "off",
    // Promise handling - temporarily relaxed for legacy code
    "@typescript-eslint/no-floating-promises": "warn",
    "@typescript-eslint/no-misused-promises": "warn",

    // Unsafe type rules - temporarily relaxed for legacy code
    "@typescript-eslint/no-unsafe-assignment": "warn",
    "@typescript-eslint/no-unsafe-argument": "warn",
    "@typescript-eslint/no-unsafe-member-access": "warn",
    "@typescript-eslint/no-unsafe-call": "warn",
    "@typescript-eslint/no-unsafe-return": "warn",
    "@typescript-eslint/no-unnecessary-type-assertion": "warn",
    "@typescript-eslint/no-unsafe-enum-comparison": "warn",
    "@typescript-eslint/require-await": "warn",
    "@typescript-eslint/await-thenable": "warn",
    "@typescript-eslint/no-redundant-type-constituents": "warn",
    "@typescript-eslint/restrict-template-expressions": "warn",

    // 代码质量
    "no-console": [
      "warn",
      {
        "allow": ["warn", "error"]
      }
    ],
    "no-debugger": "error",
    "no-alert": "warn", // Admin pages may use confirm dialogs
    "prefer-const": "error",
    "no-var": "error",

    // ★ Hydration 安全规则：禁止 locale-dependent 方法（SSR/CSR 结果不一致）
    // - toLocaleDateString/toLocaleTimeString: 使用 <ClientDate> 组件
    // - toLocaleString: 直接显示数字或使用 Intl.NumberFormat 在客户端格式化
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "CallExpression[callee.property.name='toLocaleDateString']",
        "message": "Avoid toLocaleDateString() - causes hydration errors. Use <ClientDate> component or formatDateSafe() from '@/lib/utils/date'."
      },
      {
        "selector": "CallExpression[callee.property.name='toLocaleTimeString']",
        "message": "Avoid toLocaleTimeString() - causes hydration errors. Use <ClientDate> component or formatDateSafe() from '@/lib/utils/date'."
      },
      {
        "selector": "CallExpression[callee.property.name='toLocaleString']",
        "message": "Avoid toLocaleString() in JSX - causes hydration errors. For numbers, display directly or format in useEffect/event handlers."
      },
      {
        "selector": "TSAsExpression[typeAnnotation.type='TSArrayType'][typeAnnotation.elementType.type='TSStringKeyword']",
        "message": "禁止 `(x as string[])` lying assertion — backend 实际可能 emit object[]，导致 `.slice/.map` 运行时崩溃。改用 `(x as unknown[]).map(item => typeof item === 'string' ? item : String(item))` 或走 zod schema parse。"
      },
      {
        "selector": "TSAsExpression[typeAnnotation.type='TSArrayType'][typeAnnotation.elementType.type='TSNumberKeyword']",
        "message": "禁止 `(x as number[])` lying assertion — 同上，请用运行时 type-check 或 zod parse。"
      },
      {
        "selector": "TSAsExpression[typeAnnotation.type='TSArrayType'][typeAnnotation.elementType.type='TSBooleanKeyword']",
        "message": "禁止 `(x as boolean[])` lying assertion — 同上，请用运行时 type-check 或 zod parse。"
      },
      {
        "selector": "CallExpression[callee.name=/^useApi(Get|Post|Put|Delete|Mutation)$/] > Literal[value=/^\\/api\\/(?!test)/]",
        "message": "useApi* path 禁带 /api/ 前缀 — apiClient.baseUrl 已含 /api/v1，双前缀拼出 /api/v1/api/... → backend 必 404。写 '/notifications/...' 不是 '/api/notifications/...'（spec mock /api/test 例外）。"
      },
      {
        "selector": "CallExpression[callee.object.name='apiClient'] > Literal[value=/^\\/api\\/(?!test)/]",
        "message": "apiClient.X(path) path 禁带 /api/ 前缀 — buildUrl 拼到 baseUrl=/api/v1 上变双前缀必 404。"
      }
    ]
  },
  "overrides": [
    {
      "files": ["components/common/ClientDate.tsx"],
      "rules": {
        "no-restricted-syntax": "off"
      }
    },
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/__tests__/**/*.{ts,tsx}"],
      "rules": {
        "@typescript-eslint/unbound-method": "off",
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-unsafe-assignment": "off",
        "@typescript-eslint/no-unsafe-member-access": "off",
        "@typescript-eslint/no-unsafe-call": "off"
      }
    }
  ]
}
