# GenesisPod Frontend - 环境变量示例
# 复制此文件为 .env.local 并填写实际值
# NEXT_PUBLIC_ 前缀的变量会暴露给浏览器端

# ====================
# API 连接（必须）
# ====================
# 后端 API 地址（留空时自动使用 Railway URL）
NEXT_PUBLIC_API_URL=http://localhost:4000

# ====================
# Railway 部署（生产环境按实际填写）
# ====================
# NEXT_PUBLIC_RAILWAY_DOMAIN=genesis-ai

# ====================
# 品牌配置（可选，有默认值）
# ====================
NEXT_PUBLIC_BRAND_NAME=Genesis
NEXT_PUBLIC_BRAND_FULL_NAME=GenesisPod
NEXT_PUBLIC_BRAND_SUBTITLE=AI ENGINE
NEXT_PUBLIC_BRAND_TAGLINE=AI-Powered Research Platform
NEXT_PUBLIC_BRAND_EMAIL_FROM=Genesis <noreply@genesis.ai>
NEXT_PUBLIC_BRAND_CONTACT_EMAIL=contact@genesis.ai

# ====================
# 功能开关
# ====================
NEXT_PUBLIC_WORKSPACE_AI_V2_ENABLED=false

# ====================
# 运行环境（可选）
# ====================
NEXT_PUBLIC_ENV=development
