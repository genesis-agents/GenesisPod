# Railway 远程数据库连接配置
# 使用方法：
# 1. 从 Railway Dashboard 获取你的数据库 URL
#    Railway Dashboard → 你的项目 → PostgreSQL → Variables → DATABASE_URL
# 2. 将下面的 DATABASE_URL 替换为你的实际值
# 3. 运行: npm run db:studio:railway

# PostgreSQL 连接 URL 格式:
# postgresql://用户名:密码@主机:端口/数据库名?sslmode=require
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_HOST.railway.app:5432/railway"

# 示例 (请替换为你的实际值):
# DATABASE_URL="postgresql://postgres:aBcDeFgHiJkL@containers-us-west-123.railway.app:5432/railway"
