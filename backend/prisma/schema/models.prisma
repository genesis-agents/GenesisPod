/// 研究 TODO
/// 研究任务分解后的 TODO 项，提供任务可视化和进度追踪
model ResearchTodo {
  id        String @id @default(cuid())
  topicId   String @map("topic_id")
  missionId String @map("mission_id")

  // ========== 任务基本信息 ==========
  type        ResearchTodoType
  title       String           @db.VarChar(200)
  description String?          @db.Text

  // ========== 关联信息 ==========
  dimensionId   String? @map("dimension_id")
  dimensionName String? @map("dimension_name")
  agentId       String? @map("agent_id")
  agentName     String? @map("agent_name")
  agentRole     String? @map("agent_role") // leader, researcher, reviewer, synthesizer
  modelId       String? @map("model_id") @db.VarChar(100) // ★ Agent 使用的 AI 模型 ID

  // ========== 分配理由（Leader Agent 决策依据）==========
  assignmentReason Json? @map("assignment_reason") // { agentReason?: string, modelReason?: string }

  // ========== 状态与进度 ==========
  status        ResearchTodoStatus @default(PENDING)
  progress      Int                @default(0) // 0-100
  statusMessage String?            @map("status_message") @db.VarChar(500)
  priority      Int                @default(0) // 数字越大优先级越高

  // ========== 依赖关系 ==========
  dependsOn String[] @default([]) @map("depends_on") // 依赖的任务 ID 列表

  // ========== 执行时间 ==========
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  estimatedMs Int?      @map("estimated_ms") // 预估耗时（毫秒）
  actualMs    Int?      @map("actual_ms") // 实际耗时（毫秒）

  // ========== 结果信息 ==========
  result Json? // { sourcesFound?, wordCount?, keyFindings?, error? }

  // ========== 用户控制权限 ==========
  userCanPause      Boolean @default(true) @map("user_can_pause")
  userCanCancel     Boolean @default(true) @map("user_can_cancel")
  userCanPrioritize Boolean @default(true) @map("user_can_prioritize")

  // ========== 时间戳 ==========
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ========== 关系 ==========
  topic ResearchTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // ========== 索引 ==========
  @@index([topicId, missionId])
  @@index([topicId, status])
  @@index([missionId, status])
  @@index([status, priority(sort: Desc)])
  @@map("research_todos")
}

// ============ 用户 API Key (BYOK) ============

/// API Key 使用模式
enum UserApiKeyMode {
  PERSONAL // 自用模式
  DONATED // 捐赠到共享池
}

/// 用户自有 API Key
/// 支持自用模式和捐赠到共享池模式
model UserApiKey {
  id                 String         @id @default(cuid())
  userId             String         @map("user_id")
  provider           String         @db.VarChar(50) // openai, anthropic, deepseek, google 等
  /// PR-2 (2026-05-05): 多 key 支持。同一 user + provider 可有多条，用 label 区分
  /// （"default" / "personal-org-a" / "backup" / "dev-vs-prod"）。
  /// keyResolver 选择优先级：preferred(label="default") → label asc → first active
  label              String         @default("default") @db.VarChar(50)
  encryptedValue     String         @map("encrypted_value") @db.Text
  iv                 String         @db.VarChar(32)
  keyHint            String?        @map("key_hint") @db.VarChar(20) // 脱敏提示如 "sk-...3f8a"
  keyVersion         Int            @default(1) @map("key_version")
  mode               UserApiKeyMode @default(PERSONAL)
  apiEndpoint        String?        @map("api_endpoint") @db.Text
  preferredModelId   String?        @map("preferred_model_id") @db.VarChar(200)
  donatedSecretId    String?        @map("donated_secret_id") // 关联 Secret Manager 的 ID
  isActive           Boolean        @default(true) @map("is_active")
  testStatus         String?        @map("test_status") @db.VarChar(20) // success | failed
  /// ★ 2026-05-06: 归一化错误码（与 SecretKey 对齐）
  /// 401 / 403 / 429 / 5xx / network / timeout / decryption_failed / null（成功）
  lastErrorCode      String?        @map("last_error_code") @db.VarChar(40)
  lastErrorMessage   String?        @map("last_error_message") @db.Text
  /// 调用次数统计：捐赠模式 + 个人模式都累加（业务流量调用上游成功时 +1）
  /// ★ 2026-05-06: 之前仅捐赠模式累加；现 KeyChain.reportSuccess 持久化扩展至 personal
  usageCount         Int            @default(0) @map("usage_count")
  /// ★ 2026-05-12: 真实业务调用时间。已归一字段，业务流量 + 手动 Test 都写入此列
  /// (前 last_tested_at 列在 migration 20260512a 中 drop).
  /// 写入路径：persistDbHealthOutcome (personal 分支) success/failure 都更新.
  lastUsedAt         DateTime?      @map("last_used_at")
  donationRewardedAt DateTime?      @map("donation_rewarded_at") // 首次捐赠奖励发放时间（防重复）
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, label])
  @@index([provider, mode, isActive])
  @@index([mode, isActive])
  @@map("user_api_keys")
}

// ============ Secret Manager 密钥管理 ============

/// Secret 分类
enum SecretCategory {
  AI_MODEL // AI 模型 API Key
  SEARCH // 搜索 API (Tavily, Serper, Perplexity)
  EXTRACTION // 内容提取 API (Jina, Firecrawl)
  YOUTUBE // YouTube 字幕 API
  TTS // 语音合成 API
  SKILLSMP // SkillsMP API
  POLICY // 政策研究 API (Congress.gov)
  FINANCE // 金融数据 API (Alpha Vantage)
  ACADEMIC // 学术研究 API (Semantic Scholar, PubMed)
  WEATHER // 天气数据 API (OpenWeatherMap)
  IMAGE_SEARCH // 图片搜索 API (Bing, Google CSE, SerpAPI)
  DEV_TOOLS // 开发工具 API (GitHub, GitLab)
  MCP // MCP 服务器 API (Slack, Google Drive)
  USER_DONATED // 用户捐赠的 API Key
  OTHER // 其他
}

/// Secret 访问操作类型
enum SecretAction {
  VIEW // 查看密钥值
  CREATE // 创建密钥
  UPDATE // 更新密钥
  DELETE // 删除密钥
  REFERENCE // 引用密钥
  ACCESS_DENIED // 访问被拒绝
}

/// 集中式密钥存储
/// 所有敏感 API Key 统一加密存储，其他配置通过 secretRef 引用
model Secret {
  id          String         @id @default(cuid())
  name        String         @unique @db.VarChar(100) // 唯一标识，如 "openai-api-key"
  displayName String         @map("display_name") @db.VarChar(200) // 显示名称
  category    SecretCategory @default(OTHER)
  description String?        @db.Text

  // ★ 加密存储 (AES-256-CBC)
  encryptedValue String @map("encrypted_value") @db.Text // 密文
  iv             String @db.VarChar(32) // 初始化向量 (hex, 16 bytes = 32 hex chars)
  keyVersion     Int    @default(1) @map("key_version") // 加密密钥版本号，用于密钥轮转

  // 元数据
  provider String? @db.VarChar(50) // openai, anthropic, tavily 等
  isActive Boolean @default(true) @map("is_active")

  // 过期管理
  expiresAt     DateTime? @map("expires_at") // 过期时间
  lastRotatedAt DateTime? @map("last_rotated_at") // 最后轮转时间

  // 审计
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by") @db.VarChar(100)
  updatedBy String?  @map("updated_by") @db.VarChar(100)

  // 软删除
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by") @db.VarChar(100)

  // 访问记录
  // ★ accessCount 语义 (Secret-level): 整个 secret 被查询的累计次数,
  //   getSecretByName / getValueInternal 等多入口都 +1。
  //   与 SecretKey.accessCount (行级，单 key 命中次数) 不同义,UI 上不可直接对比。
  lastAccessedAt DateTime? @map("last_accessed_at")
  accessCount    Int       @default(0) @map("access_count")
  currentVersion Int       @default(1) @map("current_version") // 当前激活版本号

  // 关联
  versions   SecretVersion[]
  accessLogs SecretAccessLog[]
  keys       SecretKey[]

  // 索引
  @@index([category])
  @@index([provider])
  @@index([isActive])
  @@index([keyVersion])
  @@index([expiresAt])
  @@index([deletedAt])
  // 复合索引优化常见查询
  @@index([category, isActive])
  @@index([provider, isActive])
  @@index([isActive, updatedAt])
  @@map("secrets")
}

/// 一个 Secret name 下的多 KEY 并存（fallback chain + 健康熔断）
/// Secret.encryptedValue/iv/keyVersion 仍保留作为兼容字段（dual-track），
/// 业务侧切到 getSecretKey() 后再下线（P3 之后）
model SecretKey {
  id       String @id @default(cuid())
  secretId String @map("secret_id")

  /// 标签（同一 secret 下唯一），用户输入或默认 "primary" / "backup-1"
  label String @db.VarChar(100)

  /// 加密存储 (AES-256-CBC)
  encryptedValue String @map("encrypted_value") @db.Text
  iv             String @db.VarChar(32)
  keyVersion     Int    @default(1) @map("key_version")

  /// 脱敏指纹用于 UI 显示（"sk-...3f8a"），不参与解密
  keyHint String? @map("key_hint") @db.VarChar(40)

  /// 是否启用（fallback chain 仅遍历 isActive=true）
  isActive Boolean @default(true) @map("is_active")

  /// fallback 优先级，数字越小越优先
  priority Int @default(0)

  /// 健康状态（与 UserApiKey 对齐）
  /// ★ 2026-05-06: testStatus / lastErrorCode / lastErrorMessage 都
  /// 由"真使用反馈"统一写入：手动 Test 按钮调上游探测、业务流量 markSuccess /
  /// markFailure 都走同一路径。UI 看到的状态永远是"最近一次真实活动"的结果。
  /// ★ 2026-05-12: last_tested_at 列在 migration 20260512a 中归一到 last_used_at.
  testStatus String? @map("test_status") @db.VarChar(20) // 'success' | 'failed'

  /// 最近一次失败的归一化错误码：401 / 403 / 429 / 5xx / network / timeout / decryption_failed
  /// 用于 UI 出语义化 badge（"未授权" / "限流" / 等），而不是只显示 "Failed"
  lastErrorCode String? @map("last_error_code") @db.VarChar(40)

  /// 最近一次失败的错误摘要（不存敏感数据），用于 UI 提示
  lastErrorMessage String? @map("last_error_message") @db.Text

  /// ★ accessCount 语义 (SecretKey 行级): 单 key 被 markSuccess / markFailure 的累计次数,
  /// = "命中数 + 失败数"。与 Secret.accessCount (整 secret 查询次数,多入口都 +1) 不同义,
  /// admin UI 拉到一起对比会误导,请保持分列展示。
  accessCount Int @default(0) @map("access_count")

  /// ★ 2026-05-12: 真实业务调用时间（不是手动 Test）。
  /// 写入路径：secretsService.getValueInternal 取出 key 时异步 markUsed,
  /// 或 KeyExecutor 成功反馈 persistDbHealthOutcome(system 路径).
  lastUsedAt DateTime? @map("last_used_at")

  /// 审计
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by") @db.VarChar(100)
  updatedBy String?  @map("updated_by") @db.VarChar(100)

  secret Secret @relation(fields: [secretId], references: [id], onDelete: Cascade)

  @@unique([secretId, label])
  @@index([secretId, isActive, priority])
  @@index([secretId, testStatus])
  @@map("secret_keys")
}

// 密钥版本历史
model SecretVersion {
  id       String @id @default(cuid())
  secretId String @map("secret_id")
  version  Int // 版本号: 1, 2, 3...

  // 加密存储
  encryptedValue String @map("encrypted_value") @db.Text
  iv             String @db.VarChar(32)
  keyVersion     Int    @default(1) @map("key_version")
  checksum       String @db.VarChar(64) // SHA-256 用于完整性校验

  // 审计字段
  createdBy String?  @map("created_by") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  // 版本说明
  changeNote String? @map("change_note") @db.Text

  // 关系
  secret Secret @relation(fields: [secretId], references: [id], onDelete: Cascade)

  @@unique([secretId, version])
  @@index([secretId])
  @@index([createdAt])
  @@map("secret_versions")
}

/// Secret 访问日志
/// 记录密钥的访问和修改历史，用于安全审计
/// ★ 使用 SetNull 避免级联删除导致审计证据丢失
model SecretAccessLog {
  id       String  @id @default(cuid())
  secretId String? @map("secret_id") // 可选，支持记录已删除密钥的日志

  // ★ 使用枚举确保类型安全
  action       SecretAction
  actionStatus String       @default("success") @map("action_status") @db.VarChar(20) // success, failed, denied

  // 删除时备份密钥元数据
  secretName String? @map("secret_name") @db.VarChar(100)

  // 变更审计 (仅 update/delete 时记录)
  oldValueHash String? @map("old_value_hash") @db.VarChar(64) // SHA-256 hash
  newValueHash String? @map("new_value_hash") @db.VarChar(64)

  // 操作者信息
  userId    String? @map("user_id") @db.VarChar(100)
  userEmail String? @map("user_email") @db.VarChar(200)
  ipAddress String? @map("ip_address") @db.VarChar(50)
  userAgent String? @map("user_agent") @db.Text

  // 错误信息 (仅失败时)
  errorMessage String? @map("error_message") @db.Text

  timestamp DateTime @default(now())

  // ★ 使用 SetNull 而非 Cascade，避免删除密钥时丢失审计日志
  secret Secret? @relation(fields: [secretId], references: [id], onDelete: SetNull)

  // 索引
  @@index([secretId])
  @@index([timestamp])
  @@index([action])
  @@index([actionStatus])
  @@index([secretName])
  // 复合索引优化审计查询
  @@index([secretId, timestamp])
  @@index([userId, timestamp])
  @@index([action, timestamp])
  @@map("secret_access_logs")
}

// ============ 通知系统 (Notification System) ============

/// 通知类型
enum NotificationType {
  // 系统通知
  SYSTEM // 系统公告
  UPDATE // 版本更新
  TIP // 使用提示

  // 团队/协作通知
  JOIN_REQUEST // 有人申请加入团队
  JOIN_APPROVED // 申请被批准
  JOIN_REJECTED // 申请被拒绝
  INVITATION // 被邀请加入团队
  INVITATION_EXPIRED // 邀请过期

  // 研究/任务通知
  RESEARCH_COMPLETED // 研究任务完成（topic-insights / Deep Research）
  MISSION_COMPLETED // Agent Playground mission 完成
  WRITING_COMPLETED // AI Writing 章节/全文完成
  OFFICE_COMPLETED // AI Office (Slides/Doc) 生成完成
  TASK_ASSIGNED // 任务分配
  MENTION // @提及

  // 积分通知
  CREDITS_LOW // 积分不足警告
  CREDITS_RECEIVED // 收到积分

  // 反馈通知
  FEEDBACK_REPLIED // 反馈收到回复
  FEEDBACK_STATUS_CHANGED // 反馈状态变更

  // AI Social 通知
  SESSION_EXPIRED // 平台会话过期

  // BYOK 密钥申请通知
  KEY_REQUEST_SUBMITTED // 用户提交了密钥申请，通知所有管理员
  KEY_REQUEST_APPROVED // 申请被批准，通知用户
  KEY_REQUEST_REJECTED // 申请被拒绝，通知用户
  KEY_GRANTED // admin 主动授权（无申请流程），通知被授权用户
}

/// 用户通知
/// 支持多种通知类型，包含操作按钮和元数据
model Notification {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // 通知内容
  type    NotificationType
  title   String           @db.VarChar(200)
  message String           @db.Text
  iconUrl String?          @map("icon_url") @db.VarChar(500) // 通知图标

  // 操作
  actionUrl   String? @map("action_url") @db.VarChar(500) // 点击跳转链接
  actionLabel String? @map("action_label") @db.VarChar(50) // 操作按钮文字

  // 相关实体（用于关联查询）
  relatedType String? @map("related_type") @db.VarChar(50) // topic, research, feedback, user
  relatedId   String? @map("related_id")

  // 状态
  read   Boolean   @default(false)
  readAt DateTime? @map("read_at")

  // 元数据（模板变量，如 {user: "张三", team: "研究小组"}）
  metadata Json? @default("{}")

  // 过期时间
  expiresAt DateTime? @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  // 关系
  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt(sort: Desc)])
  @@index([userId, type])
  @@index([relatedType, relatedId])
  @@index([expiresAt])
  @@map("notifications")
}

/// 用户通知偏好设置
model NotificationPreference {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  // 通知渠道开关
  emailEnabled Boolean @default(true) @map("email_enabled")
  pushEnabled  Boolean @default(true) @map("push_enabled")
  soundEnabled Boolean @default(true) @map("sound_enabled")

  // 各类型通知开关（JSON）
  // { system: true, joinRequest: true, research: true, credits: true, feedback: true }
  typeSettings Json @default("{}") @map("type_settings")

  // 免打扰时段
  quietHoursStart String? @map("quiet_hours_start") @db.VarChar(5) // HH:mm
  quietHoursEnd   String? @map("quiet_hours_end") @db.VarChar(5) // HH:mm

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  user User @relation("UserNotificationPreference", fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ============ 团队邀请系统 (Invitation System) ============

/// 邀请状态
enum InvitationStatus {
  PENDING // 待接受
  ACCEPTED // 已接受
  DECLINED // 已拒绝
  EXPIRED // 已过期
  CANCELLED // 已取消
}

/// Topic 邀请
/// 管理员/Owner 邀请用户加入团队
model TopicInvitation {
  id String @id @default(uuid())

  topicId String @map("topic_id")
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // 邀请人
  inviterId String @map("inviter_id")
  inviter   User   @relation("TopicInvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)

  // 被邀请人（通过用户ID或邮箱）
  inviteeId    String? @map("invitee_id")
  invitee      User?   @relation("TopicInvitationInvitee", fields: [inviteeId], references: [id], onDelete: SetNull)
  inviteeEmail String? @map("invitee_email") @db.VarChar(255) // 邮箱邀请

  // 邀请码（用于链接邀请）
  inviteCode String? @unique @map("invite_code") @db.VarChar(32)

  // 邀请角色
  role TopicRole @default(MEMBER)

  // 邀请消息
  message String? @db.Text

  // 状态
  status InvitationStatus @default(PENDING)

  // 过期时间（默认7天）
  expiresAt DateTime @map("expires_at")

  // 响应信息
  respondedAt DateTime? @map("responded_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([topicId])
  @@index([inviterId])
  @@index([inviteeId])
  @@index([inviteeEmail])
  @@index([inviteCode])
  @@index([status])
  @@index([expiresAt])
  @@map("topic_invitations")
}

// ============ 反馈回复系统 (Feedback Reply System) ============

/// 反馈优先级
enum FeedbackPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

/// 反馈回复
/// 支持用户和管理员之间的对话
model FeedbackReply {
  id         String @id @default(uuid())
  feedbackId String @map("feedback_id")

  // 回复者（可以是用户或管理员）
  userId  String? @map("user_id")
  isAdmin Boolean @default(false) @map("is_admin")

  // 回复内容
  content String @db.Text

  // 附件
  attachments Json? @default("[]")

  // 内部备注（仅管理员可见）
  internalNote Boolean @default(false) @map("internal_note")

