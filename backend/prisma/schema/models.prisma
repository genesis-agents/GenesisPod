// ============ 系统设置 ============

model SystemSetting {
  id        String  @id @default(uuid())
  key       String  @unique @db.VarChar(100) // setting key, e.g., "search.provider"
  value     String? @db.Text // setting value (nullable)
  encrypted Boolean @default(false) // whether value is encrypted

  description String? @db.Text
  category    String  @default("general") @db.VarChar(50) // general, search, ai, etc.

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("system_settings")
}

// ============ AI模型配置 ============

// AI模型类型枚举 - 支持 Tier 分级
enum AIModelType {
  // === 文本聊天 Tier ===
  CHAT // 标准聊天模型 (GPT-4, Claude, Gemini Pro) - 用于复杂对话和分析
  CHAT_FAST // 快速/低成本聊天模型 (GPT-4o-mini, Claude Haiku, Gemini Flash) - 用于简单任务：分类、翻译、摘要提取

  // === 图片处理 Tier ===
  IMAGE_GENERATION // 图片生成模型 (DALL-E 3, Imagen 4, Midjourney)
  IMAGE_EDITING // 图片编辑模型 (Imagen 3, DALL-E 2 edit)

  // === 代码 Tier ===
  CODE // 代码模型 (Claude Sonnet, GPT-4o, Codestral, DeepSeek Coder) - 用于代码生成、补全和分析

  // === 多模态 Tier ===
  MULTIMODAL // 多模态模型 (Gemini 2.0 Flash - 同时支持文本和图片)

  // === 向量和检索 Tier ===
  EMBEDDING // 向量嵌入模型 (text-embedding-3-small, text-embedding-3-large)
  RERANK // 重排序模型 (Cohere rerank)

  // === 评估 Tier ===
  EVALUATOR // 报告质量评审模型 - 专用于 10 维评审，确保跨报告评分可比性
}

model AIModel {
  id          String @id @default(uuid())
  name        String @db.VarChar(50) // 内部名称 (grok, gpt-4, claude, gemini) - 不再唯一，允许同一provider多个模型
  displayName String @map("display_name") @db.VarChar(100)
  provider    String @db.VarChar(50) // xAI, OpenAI, Anthropic, Google
  modelId     String @map("model_id") @db.VarChar(200) // 实际模型ID - 允许重复以支持横向扩展

  // 模型类型 - 用于按业务需求选择合适的模型
  modelType AIModelType @default(CHAT) @map("model_type")

  // 显示设置
  icon  String @db.Text // emoji or icon URL path
  color String @db.VarChar(100) // Tailwind gradient class

  // API配置
  apiEndpoint String  @map("api_endpoint") @db.Text // API endpoint URL
  apiKey      String? @map("api_key") @db.Text // 加密存储的API Key (兼容旧数据)
  secretKey   String? @map("secret_key") @db.VarChar(100) // 引用 Secret Manager 中的密钥名称

  // 模型参数
  maxTokens   Int   @default(4096) @map("max_tokens")
  temperature Float @default(0.7)

  // Embedding 模型专用参数
  embeddingDimensions Int? @map("embedding_dimensions") // 向量维度 (1536, 3072 等)
  maxInputTokens      Int? @map("max_input_tokens") // 最大输入 token 数

  // 模型能力标记
  isReasoning Boolean @default(false) @map("is_reasoning") // 是否为推理模型 (o1, o3, gpt-5, deepseek-r1)
  // 推理模型需要特殊处理：设置 reasoning_effort 参数，避免推理 token 消耗全部输出预算

  // ★ 模型能力配置 - 消除硬编码，完全由数据库驱动
  apiFormat               String  @default("openai") @map("api_format") @db.VarChar(20) // openai, anthropic, google, xai, ollama, vllm, llamacpp
  supportsTemperature     Boolean @default(true) @map("supports_temperature") // 推理模型通常不支持
  supportsStreaming       Boolean @default(true) @map("supports_streaming")
  supportsFunctionCalling Boolean @default(true) @map("supports_function_calling")
  supportsVision          Boolean @default(false) @map("supports_vision")
  tokenParamName          String  @default("max_tokens") @map("token_param_name") @db.VarChar(30) // max_tokens 或 max_completion_tokens
  defaultTimeoutMs        Int     @default(120000) @map("default_timeout_ms") // 推理模型需要更长时间

  // ★ 2026-05-06 Structured Output capability matrix（消除"假设所有模型都支持
  //   responseFormat:json"的运行时崩溃）。值是 ai_models 表的权威源，运行时按
  //   strategy 字段选 adapter 路径 + 用 fallbackStrategies 自动降级。
  //   - structuredOutputStrategy 取值：
  //     'json_schema_strict' (OpenAI/Grok strict mode) /
  //     'json_schema'        (OpenAI/Grok json_schema 但非 strict) /
  //     'tool_use'           (Anthropic Tools API) /
  //     'json_mode'          (response_format: { type: 'json_object' }) /
  //     'gemini_response_schema' (Gemini responseSchema 字段) /
  //     'gbnf_grammar'       (Llama.cpp / vLLM GBNF) /
  //     'prompt'             (system prompt + post-parse) /
  //     'none'               (禁用 structured output，直返文本)
  //   - fallbackStrategies: 失败降级链，按顺序尝试。例 OpenAI:
  //     ['json_schema_strict', 'json_schema', 'json_mode', 'prompt']
  structuredOutputStrategy String?  @map("structured_output_strategy") @db.VarChar(40)
  fallbackStrategies       String[] @default([]) @map("fallback_strategies") // 降级链
  supportsJsonSchemaStrict Boolean  @default(false) @map("supports_json_schema_strict")
  supportsJsonSchema       Boolean  @default(false) @map("supports_json_schema")
  supportsToolUse          Boolean  @default(false) @map("supports_tool_use")
  supportsJsonMode         Boolean  @default(false) @map("supports_json_mode")
  supportsGbnfGrammar      Boolean  @default(false) @map("supports_gbnf_grammar")

  // 价格配置（每百万 token）
  priceInputPerMillion     Decimal? @map("price_input_per_million") @db.Decimal(10, 4)
  priceOutputPerMillion    Decimal? @map("price_output_per_million") @db.Decimal(10, 4)
  priceCacheReadPerMillion Decimal? @map("price_cache_read_per_million") @db.Decimal(10, 4)

  // 成本档位（Harness BudgetAccountant downgrade 路径用）
  // basic = 便宜（mini/nano/haiku 类）；standard = 主力对话；strong = 旗舰推理（opus/o1/gpt-5）
  // 由管理员显式配置，不再用模型名 startsWith 启发式
  costTier String? @map("cost_tier") @db.VarChar(16)

  // 模型优先级（用于 fallback 排序，数字越大优先级越高）
  priority Int @default(50)

  // 状态
  isEnabled Boolean @default(true) @map("is_enabled")
  isDefault Boolean @default(false) @map("is_default") // 是否为该类型的默认模型

  description String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 2026-05-08 v5: 管理员把本模型授权给指定用户的关系（KeyAssignment.modelDbId → AIModel.id）
  keyAssignments KeyAssignment[]

  @@index([modelType, isEnabled]) // 按类型快速查询启用的模型
  @@index([modelId]) // 按模型ID查询（支持横向扩展后的多实例查询）
  @@map("ai_models")
}

// ============================================================================
// Debate System - 基于业界最佳实践的多AI辩论系统
// 参考: AutoGen (Microsoft), MAD (Multi-Agents-Debate), DebateLLM
// ============================================================================

enum DebateStatus {
  PENDING // 等待开始
  ACTIVE // 进行中
  PAUSED // 暂停
  COMPLETED // 已完成
  CANCELLED // 已取消
}

enum DebateRole {
  RED // 红方/正方
  BLUE // 蓝方/反方
  JUDGE // 裁判
  OBSERVER // 观察者
}

// 辩论会话 - 每次辩论是独立的Session，与Topic消息历史隔离
model DebateSession {
  id String @id @default(uuid())

  // 关联Topic（辩论发生在哪个Topic）
  topicId String @map("topic_id")

  // 辩论主题
  topic       String  @db.VarChar(500)
  description String? @db.Text

  // 辩论状态
  status DebateStatus @default(PENDING)

  // 辩论配置
  maxRounds      Int @default(3) @map("max_rounds") // 最大轮次
  currentRound   Int @default(0) @map("current_round") // 当前轮次
  roundTimeoutMs Int @default(120000) @map("round_timeout_ms") // 每轮超时

  // 发起者
  initiatedById String   @map("initiated_by_id")
  initiatedAt   DateTime @default(now()) @map("initiated_at")

  // 结束信息
  completedAt DateTime? @map("completed_at")
  conclusion  String?   @db.Text // 辩论结论（可由Judge生成）
  winnerId    String?   @map("winner_id") // 获胜方Agent ID

  // 元数据
  metadata Json? // 扩展配置

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  agents   DebateAgent[]
  messages DebateMessage[]

  @@index([topicId])
  @@index([status])
  @@index([initiatedById])
  @@index([createdAt(sort: Desc)])
  @@map("debate_sessions")
}

// 辩论参与者 - 每个AI在辩论中的角色和独立历史
model DebateAgent {
  id String @id @default(uuid())

  // 关联辩论会话
  sessionId String        @map("session_id")
  session   DebateSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // 关联AI成员
  aiMemberId  String @map("ai_member_id")
  displayName String @map("display_name") @db.VarChar(100)
  aiModel     String @map("ai_model") @db.VarChar(50)

  // 辩论角色
  role DebateRole

  // 立场描述（系统生成或用户指定）
  stance       String? @db.VarChar(200) // 如 "支持先有鸡"
  stancePrompt String? @map("stance_prompt") @db.Text // 完整的角色prompt

  // 独立的对话历史（核心！不与Topic历史共享）
  // 每个Agent只看到自己的历史，防止角色混乱
  conversationHistory Json @default("[]") @map("conversation_history")

  // 统计
  messageCount Int @default(0) @map("message_count")
  totalTokens  Int @default(0) @map("total_tokens")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  messages DebateMessage[]

  @@unique([sessionId, aiMemberId])
  @@index([sessionId])
  @@index([role])
  @@map("debate_agents")
}

// 辩论消息 - 独立于Topic消息的辩论专用消息
model DebateMessage {
  id String @id @default(uuid())

  // 关联辩论会话
  sessionId String        @map("session_id")
  session   DebateSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // 发送者Agent
  agentId String      @map("agent_id")
  agent   DebateAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // 消息内容
  content String @db.Text

  // 轮次信息
  round Int // 第几轮

  // AI生成元数据
  modelUsed  String? @map("model_used") @db.VarChar(50)
  tokensUsed Int?    @map("tokens_used")
  latencyMs  Int?    @map("latency_ms") // 响应延迟

  // 同步到Topic的消息ID（可选，用于在Topic中显示）
  topicMessageId String? @map("topic_message_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId, round])
  @@index([agentId])
  @@index([createdAt])
  @@map("debate_messages")
}

// ============ Raw Data Collection (replaces MongoDB) ============

model RawData {
  id String @id @default(uuid())

  // Data source type (arxiv, github, hackernews, rss, blog, etc.)
  source String @db.VarChar(50)

  // External ID for deduplication (e.g., arXiv ID, GitHub repo name)
  externalId String? @map("external_id") @db.VarChar(500)

  // Complete raw data stored as JSONB
  data Json

  // 主 Resource 关联（反向关系）
  primaryResource Resource? @relation("PrimaryRawData")

  // 历史关联 - 一个 RawData 可能被多个 Resource 引用（如合并场景）
  resourceId String?   @map("resource_id")
  resource   Resource? @relation("ResourceRawDataHistory", fields: [resourceId], references: [id], onDelete: SetNull)

  // Processing status
  processedAt     DateTime? @map("processed_at")
  processingError String?   @map("processing_error") @db.Text
  isProcessed     Boolean   @default(false) @map("is_processed")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Unique constraint for source + externalId (防止重复采集)
  @@unique([source, externalId], name: "raw_data_source_external_id_unique")
  // Indexes for performance
  @@index([source])
  @@index([externalId])
  @@index([resourceId])
  @@index([createdAt])
  @@index([isProcessed])
  // GIN index for JSONB data (created via raw SQL migration)
  @@map("raw_data")
}

// ============ AI Generated Images ============

model GeneratedImage {
  id String @id @default(uuid())

  // User who generated the image
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Generation parameters
  prompt         String  @db.Text
  enhancedPrompt String? @map("enhanced_prompt") @db.Text
  style          String  @default("realistic") @db.VarChar(50)
  aspectRatio    String  @default("1:1") @map("aspect_ratio") @db.VarChar(10)
  negativePrompt String? @map("negative_prompt") @db.Text

  // Generated image
  imageUrl String @map("image_url") @db.Text
  width    Int    @default(1024)
  height   Int    @default(1024)

  // Provider info
  provider String @default("stability") @db.VarChar(50)

  // Processing details (for history display)
  textModelUsed   String? @map("text_model_used") @db.VarChar(100)
  imageModelUsed  String? @map("image_model_used") @db.VarChar(100)
  processingSteps Json?   @map("processing_steps")
  promptInsights  Json?   @map("prompt_insights")

  // Bookmark status
  isBookmarked Boolean @default(false) @map("is_bookmarked")

  // Visibility
  visibility ContentVisibility @default(PRIVATE) // 可见性：私有/公开

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@index([isBookmarked])
  @@index([visibility])
  @@map("generated_images")
}

// ============================================================================
// DeepDive Engine v2.1 - 品牌套件系统
