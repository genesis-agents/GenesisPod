  @@index([metricType, createdAt(sort: Desc)])
  @@index([modelId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([success, createdAt(sort: Desc)])
  @@map("ai_engine_metrics")
