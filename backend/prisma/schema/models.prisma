// ============ AI Kernel: Process Management ============

enum ProcessState {
  CREATED
  READY
  RUNNING
  PAUSED
  WAITING
  COMPLETED
  FAILED
  CANCELLED
  ZOMBIE
}

enum MemoryLayer {
  WORKING
  SESSION
  SHARED
  PERSISTENT
}

model AgentProcess {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  parentId      String?      @map("parent_id")
  agentId       String       @map("agent_id")
  teamSessionId String?      @map("team_session_id")
  state         ProcessState @default(CREATED)
  priority      Int          @default(5)
  tokenBudget   Int          @default(50000) @map("token_budget")
  tokensUsed    Int          @default(0) @map("tokens_used")
  costBudget    Float        @default(1.0) @map("cost_budget")
  costUsed      Float        @default(0) @map("cost_used")
  checkpoint    Json?
  input         Json?
  output        Json?
  error         String?      @db.Text
  grantedTools  String[]     @map("granted_tools")
  grantedSkills String[]     @map("granted_skills")
  dataScope     Json?        @map("data_scope")
  metadata      Json?
  version       Int          @default(1)
  startedAt     DateTime?    @map("started_at")
  completedAt   DateTime?    @map("completed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  parent           AgentProcess?    @relation("ProcessTree", fields: [parentId], references: [id], onDelete: SetNull)
  children         AgentProcess[]   @relation("ProcessTree")
  events           ProcessEvent[]
  memories         ProcessMemory[]
  sentMessages     ProcessMessage[] @relation("SentMessages")
  receivedMessages ProcessMessage[] @relation("ReceivedMessages")

  @@index([userId, state])
  @@index([parentId])
  @@index([teamSessionId])
  @@index([state, priority])
  @@map("agent_processes")
}

model ProcessEvent {
  id        String   @id @default(uuid())
  processId String   @map("process_id")
  sequence  Int
  type      String   @db.VarChar(100)
  payload   Json?
  result    Json?
  createdAt DateTime @default(now()) @map("created_at")

  process AgentProcess @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@unique([processId, sequence])
  @@index([processId, createdAt])
  @@map("process_events")
}

model ProcessMemory {
  id        String      @id @default(uuid())
  processId String      @map("process_id")
  layer     MemoryLayer
  key       String      @db.VarChar(255)
  value     Json
  expiresAt DateTime?   @map("expires_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  process AgentProcess @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@unique([processId, layer, key])
  @@index([processId, layer])
  @@index([expiresAt])
  @@map("process_memories")
}

model ProcessMessage {
  id            String   @id @default(uuid())
  fromProcessId String   @map("from_process_id")
  toProcessId   String   @map("to_process_id")
  channel       String   @db.VarChar(100)
  payload       Json
  acknowledged  Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  fromProcess AgentProcess @relation("SentMessages", fields: [fromProcessId], references: [id], onDelete: Cascade)
  toProcess   AgentProcess @relation("ReceivedMessages", fields: [toProcessId], references: [id], onDelete: Cascade)

  @@index([toProcessId, acknowledged])
  @@index([channel])
  @@map("process_messages")
}

// ============ BYOK v2：管理员可分发 Key 池 + 分配 + 申请工单 ============

/// 管理员分配状态
enum KeyAssignmentStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
  STALE // PR-A 2026-05-08：关联 DistributableKey 停用时进入此态（cron 同步）
}

/// Key 申请状态
enum KeyRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// 管理员把某个 AI 模型授权给指定用户（含用户级配额、周期续期）
///
/// 2026-05-08 v5（drop_distributable_keys）：
///   - 删除 DistributableKey 双源抽象，KeyAssignment 直接关联 AIModel
///   - keyId(FK→DistributableKey) → modelDbId(FK→AIModel.id)
///   - 唯一约束 [userId, modelDbId]
///   - provider/modelId 保留为冗余字段（grant 时由 model 派生填充，listing 用免 join）
///   - 池级配额 monthlyQuotaCents/currentSpendCents 已删（spend 走 userSpendCents
///     + CreditsService）。如需"全 provider 总配额"概念，未来在 CreditsService 加
///
/// 历史 PR-A 模型粒度 + 周期续期 + STALE 状态保留
model KeyAssignment {
  id                 String              @id @default(cuid())
  // FK → AIModel.id（管理员配置的模型）。删 model 时级联删除该授权
  modelDbId          String              @map("model_db_id")
  userId             String              @map("user_id")
  // 冗余字段（= AIModel.provider lowercased），grant 时填充，listing/filter 用免 join
  provider           String              @db.VarChar(50)
  // 冗余字段（= AIModel.modelId），grant 时填充，UI 显示用免 join
  modelId            String              @map("model_id") @db.VarChar(200)
  // 用户级配额（美分）；null 表示无单独限额（受 CreditsService 总账控制）
  userQuotaCents     Int?                @map("user_quota_cents")
  userSpendCents     Int                 @default(0) @map("user_spend_cents")
  /// ★ accessCount 语义 (KeyAssignment 级): assigned 路径业务流量 success 累计 (仅成功,失败不计).
  /// 与 Secret.accessCount (整 secret 查询累计,含失败) / SecretKey.accessCount (单 key markSuccess+
  /// markFailure 累计) 同名但 触发面 / 粒度 完全不同, admin UI 拉到一起对比会误导.
  accessCount        Int                 @default(0) @map("access_count")
  /// ★ 2026-05-12: 真实业务调用时间. 写入路径: persistDbHealthOutcome (assigned 分支).
  lastUsedAt         DateTime?           @map("last_used_at")
  status             KeyAssignmentStatus @default(ACTIVE)
  // 有效期类型：ONE_TIME=单次到期；RECURRING=周期续期（cron 自动 reset spendCents）
  validityType       String              @default("ONE_TIME") @map("validity_type") @db.VarChar(20)
  recurrenceUnit     String?             @map("recurrence_unit") @db.VarChar(10) // WEEK / MONTH / YEAR
  recurrenceInterval Int?                @map("recurrence_interval") // 1=每月，3=每季度
  nextRenewalAt      DateTime?           @map("next_renewal_at")
  assignedAt         DateTime            @default(now()) @map("assigned_at")
  assignedBy         String?             @map("assigned_by") @db.VarChar(100)
  expiresAt          DateTime?           @map("expires_at")
  revokedAt          DateTime?           @map("revoked_at")
  revokedBy          String?             @map("revoked_by") @db.VarChar(100)
  revokedReason      String?             @map("revoked_reason") @db.Text
  note               String?             @db.Text
  // 过期通知追踪（避免重复通知）
  notifiedExpiringAt DateTime?           @map("notified_expiring_at")

  model AIModel @relation(fields: [modelDbId], references: [id], onDelete: Cascade)
  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, modelDbId])
  @@index([userId, status])
  @@index([modelDbId, status])
  @@index([expiresAt, status])
  @@index([nextRenewalAt])
  @@map("key_assignments")
}

/// 用户申请 Key 工单
model KeyRequest {
  id String @id @default(cuid())

  userId String @map("user_id")

  /// 用户提交申请时**不再选择** provider（admin 未必有该 provider 的可用模型，
  /// 强制选 provider 反而把申请卡死）。admin 审批时自由选任意 enabled AIModel。
  /// 字段保留 nullable 仅为向后兼容历史数据；新建申请一律 NULL。
  provider String? @db.VarChar(50)

  reason                String?          @db.Text
  estimatedUsage        String?          @map("estimated_usage") @db.VarChar(20) // LIGHT / MEDIUM / HEAVY
  note                  String?          @db.Text
  status                KeyRequestStatus @default(PENDING)
  handledBy             String?          @map("handled_by") @db.VarChar(100)
  handledAt             DateTime?        @map("handled_at")
  rejectionReason       String?          @map("rejection_reason") @db.Text
  resultingAssignmentId String?          @map("resulting_assignment_id")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("key_requests")
}

// ============ BYOK v3：用户自己配置的多模型实例 ============
//
// 同一个 provider Key 可以绑多个不同用途的模型，字段对齐管理员的
// AIModel（modelId / modelType / maxTokens / temperature / apiFormat /
// supports* / tokenParamName / isReasoning / priority / isDefault 等）。
//
// - (userId, provider, modelId) 三元组唯一
// - isDefault=true 的 (userId, provider, modelType) 只能有一个（应用层保证）
// - apiKey 走 UserApiKey；这张表只存模型 profile，不重复存 Key

model UserModelConfig {
  id          String @id @default(cuid())
  userId      String @map("user_id")
  provider    String @db.VarChar(50)
  modelId     String @map("model_id") @db.VarChar(200)
  displayName String @map("display_name") @db.VarChar(200)

  modelType AIModelType @default(CHAT) @map("model_type")

  // 用户自定义 endpoint（空则用 provider 官方或 UserApiKey.apiEndpoint）
  apiEndpoint String? @map("api_endpoint") @db.Text

  // 运行参数
  maxTokens   Int   @default(4096) @map("max_tokens")
  temperature Float @default(0.7)

  // Embedding 专用
  embeddingDimensions Int? @map("embedding_dimensions")
  maxInputTokens      Int? @map("max_input_tokens")

  // 能力标志
  isReasoning             Boolean @default(false) @map("is_reasoning")
  apiFormat               String  @default("openai") @map("api_format") @db.VarChar(50)
  supportsTemperature     Boolean @default(true) @map("supports_temperature")
  supportsStreaming       Boolean @default(true) @map("supports_streaming")
  supportsFunctionCalling Boolean @default(true) @map("supports_function_calling")
  supportsVision          Boolean @default(false) @map("supports_vision")
  tokenParamName          String  @default("max_tokens") @map("token_param_name") @db.VarChar(50)
  defaultTimeoutMs        Int     @default(120000) @map("default_timeout_ms")

  // 价格（可选，仅供统计）
  priceInputPerMillion  Decimal? @map("price_input_per_million") @db.Decimal(10, 4)
  priceOutputPerMillion Decimal? @map("price_output_per_million") @db.Decimal(10, 4)

  priority    Int     @default(50)
  isEnabled   Boolean @default(true) @map("is_enabled")
  isDefault   Boolean @default(false) @map("is_default")
  description String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 同一个 modelId 可以在不同 modelType 下重复（例如 gpt-4o 同时作 CHAT、CODE、MULTIMODAL）。
  /// 这样一键 AI 配置能把单个 provider 的 Key 铺满所有适配类型，而不是只建一条被 dedup 拦下。
  @@unique([userId, provider, modelId, modelType])
  @@index([userId, modelType, isEnabled])
  @@index([userId, provider])
  @@index([userId, isDefault])
  @@map("user_model_configs")
}

/// 一键 AI 配置的推荐矩阵（provider × modelType → 按优先级排序的 regex 模式列表）。
/// - 系统首次启动 seed 一次硬编码默认；之后管理员可通过后台编辑
/// - user-auto-configure 和 admin-auto-configure 都读这张表
/// - patterns 是 JSON 数组（string[]），按顺序匹配 /v1/models 返回的 modelId，第一个命中即胜出
model ModelRecommendation {
  id        String      @id @default(cuid())
  provider  String      @db.VarChar(50)
  modelType AIModelType @map("model_type")

  /// 正则字符串列表，例如 ["^gpt-4o(?!-mini)", "^gpt-4-turbo"]。按序匹配
  patterns Json @default("[]")

  /// 同 provider + modelType 可能有多条（未来扩展），按 priority 升序取
  priority Int @default(50)

  /// 备注，例如"2026-04 更新：加入 gpt-5"
  note String? @db.Text

  /// 最后一次修改者（管理员 userId），系统 seed 时为 null
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provider, modelType])
  @@index([provider])
  @@map("model_recommendations")
}

/// 存储采样快照 — 每日 cron 采一次，供 admin 面板画趋势图
model StorageSnapshot {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now()) @map("created_at")
  dbTotalBytes   BigInt   @map("db_total_bytes")
  r2TotalBytes   BigInt   @default(0) @map("r2_total_bytes")
  r2TotalObjects Int      @default(0) @map("r2_total_objects")
  offloadFields  Json?    @map("offload_fields")
  dbTopTables    Json?    @map("db_top_tables")

  @@index([createdAt(sort: Desc)])
  @@map("storage_snapshots")
}

// ============================================================================
// Topic Insights Harness · Rollout Metrics
// ============================================================================

/// 每次 harness pipeline run 的结果记录（Group N-1）
/// 用于灰度监控 dashboard / 历史 P95 / 跨 pod 聚合 / 事故 post-mortem
model HarnessRunMetric {
  id        String @id @default(uuid())
  missionId String @map("mission_id") @db.VarChar(100)
  userId    String @map("user_id") @db.VarChar(100)

  success      Boolean
  durationMs   Int     @map("duration_ms")
  /// ST-08-QGATE 产出的 overall score（0-100），失败时可为 null
  qualityScore Int?    @map("quality_score")
  tokensUsed   Int     @default(0) @map("tokens_used")
  costUsd      Decimal @default(0) @map("cost_usd") @db.Decimal(10, 4)
  /// 失败时填 error message 前 500 字符
  errorMessage String? @map("error_message") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([success, createdAt(sort: Desc)])
  @@map("harness_run_metrics")
}

/// 每个 mission 的 harness pipeline checkpoint。每个 stage.persist 后更新，
/// resume 时加载 completedStages + stageResults + budgetSnapshot 跳过已完成 stage。
/// 单 mission 单行：用 missionId 作为 unique key，后续 stage 成功直接 upsert。
model PipelineRunCheckpoint {
  id               String   @id @default(uuid())
  missionId        String   @unique @map("mission_id") @db.VarChar(100)
  /// 已完成 stage 的 id 列表，顺序执行顺序（JSON string array）
  completedStages  Json     @map("completed_stages")
  /// stageId -> stage 输出对象 的 map（JSON object）
  stageResults     Json     @map("stage_results")
  /// PipelineBudget.snapshot() — 恢复 budget 计数用
  budgetSnapshot   Json     @map("budget_snapshot")
  /// 恢复时需要的 identity 片段：depth, mode, capabilities（JSON object）
  /// 完整 AbortController / budget 在 runtime 重建，不持久化
  identitySnapshot Json     @map("identity_snapshot")
  /// 最后一个完成的 stage id，便于监控
  lastStageId      String?  @map("last_stage_id") @db.VarChar(50)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([updatedAt(sort: Desc)])
  @@map("pipeline_run_checkpoints")
}

/// ============================================================
/// Harness Checkpoint + Event Sourcing  (PR-C, 2026-04-24)
///
/// 为通用 Harness 层（任何 AI App 跑的 IAgent）提供持久化与可回放：
///   - HarnessCheckpoint: 任意时刻的 envelope + identity + budget 快照
///   - HarnessAgentEvent: 完整事件流（thinking/action/output/...），按 seq 严格有序
///
/// 与 PipelineRunCheckpoint 区别：
///   - PipelineRunCheckpoint 是 topic-insights 业务 stage 级断点（mission scoped）
///   - HarnessCheckpoint 是通用 agent 级断点（agent scoped, App agnostic）
///   - 一个 mission 可关联多个 HarnessCheckpoint（每个 sub-agent 各自）
/// ============================================================

model HarnessCheckpoint {
  id            String   @id @default(uuid())
  agentId       String   @map("agent_id") @db.VarChar(64)
  /// auto-interval / key-event / manual / pre-cancel / pre-terminate
  reason        String   @db.VarChar(32)
  /// "idle" | "running" | "completed" | "failed" | "cancelled"
  agentState    String   @map("agent_state") @db.VarChar(16)
  /// envelope snapshot (system / messages / reminders / tools / memory / budget / metadata)
  envelope      Json
  /// identity snapshot (role / persona / goal / constraints / skills / tools)
  identity      Json
  /// 已发射的事件计数 — 与 HarnessAgentEvent.seq 对齐用于 replay
  eventsEmitted Int      @map("events_emitted")
  /// task snapshot { goal, input } 用于 resume 时还原入口；可空
  taskSnapshot  Json?    @map("task_snapshot")
  /// 业务可塞自己的索引字段（missionId / topicId / sessionId 等）
  scope         Json?
  takenAt       DateTime @default(now()) @map("taken_at")

  @@index([agentId, takenAt(sort: Desc)])
  @@index([takenAt(sort: Desc)])
  @@map("harness_checkpoints")
}

model HarnessAgentEvent {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id") @db.VarChar(64)
  /// 全局严格递增（按 agent 分区即可）— resume 时按 seq 读取并重放
  seq       Int
  /// thinking / action_planned / action_executed / reflection / output / error / budget_warning / terminated
  type      String   @db.VarChar(32)
  /// payload 原样存（任意 IAgentEvent.payload）
  payload   Json
  /// trace 关联（PR-G 的 SpanRecord）
  traceId   String?  @map("trace_id") @db.VarChar(40)
  spanId    String?  @map("span_id") @db.VarChar(20)
  emittedAt DateTime @default(now()) @map("emitted_at")

  @@unique([agentId, seq])
  @@index([agentId, emittedAt])
  @@index([traceId])
  @@map("harness_agent_events")
}

/// ============================================================
/// Harness Vector Memory (PR-S, 2026-04-25)
///
/// Agent 长期语义记忆持久层。Mission 完成后自动 index：
///   - 取 mission output / 关键 thinking / final reflection
///   - embed 后入库
///   - 下次同 user/workspace 跑相似 mission 时自动召回
///
/// 注意：当前用 Float[] 存 embedding（PG 原生数组）。
/// 大规模生产应改用 pgvector 扩展（schema 加 @db.Vector(1536)）。
/// ============================================================
model HarnessVectorMemory {
  id             String   @id @default(uuid())
  /// namespace = userId / workspaceId / sessionId（业务方决定隔离粒度）
  namespace      String   @db.VarChar(128)
  /// 业务可塞 'topic-insights:mission' / 'research:report' 等
  source         String?  @db.VarChar(64)
  /// 业务自定义 key（'mission:abc123' / 'topic:xyz'）
  entryKey       String   @map("entry_key") @db.VarChar(128)
  /// 原文（compaction 后入库的精炼文本，<= 2000 chars）
  content        String
  /// embedding 向量（OpenAI text-embedding-3-small = 1536 维）
  embedding      Float[]
  /// confidence: 0..1（learner 置信度；越高优先召回）
  confidence     Float    @default(1.0)
  /// 业务标签：['mission', 'success'], ['topic', 'finance'] 等
  tags           String[]
  /// 任意业务 metadata
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  /// LRU 淘汰用：每次召回更新 lastAccessedAt
  lastAccessedAt DateTime @default(now()) @map("last_accessed_at")

  @@index([namespace, createdAt(sort: Desc)])
  @@index([namespace, lastAccessedAt(sort: Desc)])
  @@index([source])
  @@map("harness_vector_memory")
}

/// ============================================================
/// Agent Playground Mission (2026-04-25)
///
/// Demo 模块的 mission 持久化。让用户能在列表页回看历史 mission：
///   - 启动时插入 record (status=running)
///   - 完成时 update status + finalScore + reportFull + verdicts + ...
///   - 失败时 update status=failed + errorMessage
///
/// 不复用 TeamMission（那是 topic-insights 业务的，schema 不一样）。
/// ============================================================
model AgentPlaygroundMission {
  id            String                @id @default(uuid())
  userId        String                @map("user_id")
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId   String?               @map("workspace_id")
  electionState MissionElectionState?

  /// 输入
  topic      String @db.VarChar(500)
  depth      String @db.VarChar(20) // quick / standard / deep
  language   String @db.VarChar(20)
  maxCredits Int    @default(300) @map("max_credits")

  /// 状态
  status      String    @db.VarChar(20) // running / completed / failed / rejected
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  wallTimeMs  Int?      @map("wall_time_ms")

  /// 完成时填充
  finalScore       Int?    @map("final_score")
  tokensUsed       BigInt? @map("tokens_used")
  costUsd          Float?  @map("cost_usd")
  trajectoryStored Int?    @map("trajectory_stored")
  reportTitle      String? @map("report_title") @db.VarChar(500)
  reportSummary    String? @map("report_summary") @db.Text
  errorMessage     String? @map("error_message") @db.Text

  /// 持久化的 blob（detail 页重新渲染用）
  themeSummary             String? @map("theme_summary") @db.Text
  dimensions               Json? // [{id, name, rationale, toolHint?}]
  reportFull               Json?   @map("report_full") @db.JsonB // 完整 ResearchReport（v1）或 ReportArtifact（v2+）
  /// Off-load 到 R2 后：DB 置 NULL，reportFullUri 写 key，reportFullSize 记原始字节数
  reportFullUri            String? @map("report_full_uri")
  reportFullSize           Int?    @map("report_full_size")
  /// ★ ReportArtifact schema 版本号（mission-pipeline-writer-artifact.md / D15）
  /// v1 = 旧 ResearchReport（单 markdown）
  /// v2 = ReportArtifact（sections / citations / figures / quickView / factTable）
  reportArtifactVersion    Int?    @map("report_artifact_version")
  verdicts                 Json? // [{verifierId, score, critique, attempt}]
  /// ★ 用户档位（mission-pipeline-user-profiles.md §11 / D20）
  /// merged after defaults applied + auto-rules applied
  userProfile              Json?   @map("user_profile")
  /// ★ Reconciler [3.5] 节点产物（factTable / conflicts / overlaps / gaps / figureCandidates）
  reconciliationReport     Json?   @map("reconciliation_report") @db.JsonB
  reconciliationReportUri  String? @map("reconciliation_report_uri")
  reconciliationReportSize Int?    @map("reconciliation_report_size")

  /// ★ Leader-Replanner-Lite 务实 leader 方案（Phase Lead-1+）
  /// leader_journal: { plan: M0 输出含 goals/qualityBar/successCriteria/initialRisks,
  ///                   decisions[]: M1/M4 决策记录, foreword: M6 输出 }
  leaderJournal      Json?    @map("leader_journal") @db.JsonB
  leaderJournalUri   String?  @map("leader_journal_uri")
  leaderJournalSize  Int?     @map("leader_journal_size")
  /// Leader 在 M7 sign-off 给整 mission 的总分（不同于 reviewer / critic 评分）
  leaderOverallScore Int?     @map("leader_overall_score")
  /// Leader 在 M7 是否签字接受交付；false → mission status = quality-failed
  leaderSigned       Boolean? @map("leader_signed")
  /// Leader 自评的 verdict，与 quality.finalVerdict 独立（前者由 Lead 决定，后者由 Writer 评分器算）
  leaderVerdict      String?  @map("leader_verdict") @db.VarChar(20)

  /// ★ PR-R0 (2026-05-07 per-task rerun + cascade)：S6 analyst 输出主动持久化（cascade rerun ctx 还原用）
  analystOutput     Json?   @map("analyst_output") @db.JsonB
  analystOutputUri  String? @map("analyst_output_uri")
  analystOutputSize Int?    @map("analyst_output_size")
  /// ★ PR-R0 (2026-05-07 per-task rerun + cascade)：S7 writer outline 输出主动持久化（cascade rerun ctx 还原用）
  outlinePlan       Json?   @map("outline_plan") @db.JsonB
  outlinePlanUri    String? @map("outline_plan_uri")
  outlinePlanSize   Int?    @map("outline_plan_size")

  /// Leader 对话历史（点击 Leader 节点弹出聊天框）
  leaderChats     AgentPlaygroundLeaderChat[]
  /// ★ P0-D 完整版 (2026-05-06): trajectory 持久化关系
  researchResults AgentPlaygroundResearchResult[]
  chapterDrafts   AgentPlaygroundChapterDraft[]
  /// ★ 报告版本化（rerun 产生新版本而不覆盖旧版本）
  reportVersions  MissionReportVersion[]
  /// ★ PR-R0 (per-task rerun + cascade)：单 stage 重跑频次记录（24h × 5 次/mission+stepId 防滥用）
  rerunAttempts   AgentPlaygroundRerunAttempt[]

  /// ★ PR-H v1 (2026-05-01): pod-aware mission lifecycle —— pod 重启检测 + 后续 resume 接续
  /// lastCompletedStage: 0~12（S0~S12）；null = 还没完成 S1
  ///   单调递增；用于 Pod 重启后判断从哪个 stage 续跑
  lastCompletedStage Int?      @map("last_completed_stage")
  /// 当前承载该 mission 的 pod ID（process.env.RAILWAY_REPLICA_ID || hostname）
  ///   pod 重启后 podId 变化 + heartbeatAt 不再刷新 → recovery 服务标记 failed
  podId              String?   @map("pod_id") @db.VarChar(120)
  /// 心跳时间 —— runMission 主循环每 30s 刷新一次到 DB
  ///   stale 90s + status=running → pod recycled → 标记 failed
  heartbeatAt        DateTime? @map("heartbeat_at")

  @@index([userId, startedAt(sort: Desc)])
  @@index([status])
  @@index([status, heartbeatAt]) // PR-H: pod recovery 扫描
  @@map("agent_playground_missions")
}

/// PR-R0 (2026-05-07 per-task rerun + cascade)：单 stage 重跑尝试记录
/// 用途：24h 内 mission+stepId 重跑次数限制（≤ 5 次防滥用）
/// 清理：cron job 每天清 7 天前的行（不影响 24h 频次窗口）
model AgentPlaygroundRerunAttempt {
  id          String                 @id @default(uuid())
  missionId   String                 @map("mission_id")
  mission     AgentPlaygroundMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  userId      String                 @map("user_id")
  stepId      String                 @map("step_id") @db.VarChar(120)
  triggeredAt DateTime               @default(now()) @map("triggered_at")

  @@index([missionId, stepId, triggeredAt(sort: Desc)])
  @@index([userId, triggeredAt(sort: Desc)])
  @@map("agent_playground_rerun_attempts")
}

/// agent-playground mission 的事件流持久化
/// 用于 Railway recycle 后能完整回放（in-memory MissionEventBuffer 兜底用）
model AgentPlaygroundMissionEvent {
  id        String   @id @default(uuid())
  missionId String   @map("mission_id")
  type      String   @db.VarChar(120) // agent-playground.agent:thought 等
  agentId   String?  @map("agent_id") @db.VarChar(120)
  traceId   String?  @map("trace_id") @db.VarChar(120)
  payload   Json
  ts        BigInt // event.timestamp (ms epoch)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([missionId, ts])
  @@map("agent_playground_mission_events")
}

/// mission-scoped model election state
/// advisory-lock transaction 内的 authoritative source，用于跨实例多模型分配一致性。
/// FK ON DELETE CASCADE 让 mission 删除时自动清理状态行，作为应用层 clear() 的兜底
/// （直接 DB delete / admin 清理脚本路径也不留孤儿）。
///
/// ⚠ 分层约束（2026-05-11 Round 4 arch 评审 P3 灰区）：
/// 当前 FK 指向 `agent_playground_missions`（schema 层固定表名），反映"目前
/// 仅一个 ai-app caller 接入 election"的现实。election 机制位于 ai-engine
/// （理论上是通用基元），但实际仅一个上层应用使用。
///
/// 未来扩展（其他 ai-app 也需要 election）时必须重构：
///   (a) 删除 FK，改用软引用 + `missionType` enum 字段（推荐）；或
///   (b) 抽 `missions` 公共基础表让各业务表 FK 回去
/// 当前接受 YAGNI（CLAUDE.md "简洁优先"），不为假想需求预先抽象。
///
/// 注：本 schema 文件由 Prisma 直接消费，业务表名 `agent_playground_missions`
/// 出现在此处属于"schema 引用 schema"，非 ai-engine 业务概念泄漏。
model MissionElectionState {
  missionId         String   @id @map("mission_id")
  committedModelIds String[] @default([]) @map("committed_model_ids")
  reservations      Json     @default("[]") @db.JsonB
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  mission AgentPlaygroundMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("mission_election_states")
}

/// agent-playground per-dim researcher 完整产物持久化（P0-D 完整版）
/// rerun incremental 模式从此表 hydrate entry.lastResearcherResults 跳过 S3 重做。
/// 单 mission × 多 dim × 可选 retryLabel → 复合唯一索引避免重复写入。
model AgentPlaygroundResearchResult {
  id         String                 @id @default(uuid())
  missionId  String                 @map("mission_id")
  mission    AgentPlaygroundMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  /// dim 名（中文，与事件流 payload.dimension 对齐）
  dimension  String                 @db.VarChar(200)
  /// retryLabel（fresh-collect retry 路径独立 pipeline）；默认空串确保 UNIQUE 索引无 NULL 歧义
  retryLabel String                 @default("") @map("retry_label") @db.VarChar(60)
  /// 完整 findings 数组：[{claim, evidence, source}]
  findings   Json                   @db.JsonB
  /// summary（前端展示 + leader assess 输入）
  summary    String                 @db.Text
  /// state: completed / degraded / failed
  state      String                 @db.VarChar(20)
  iterations Int?
  wallTimeMs Int?                   @map("wall_time_ms")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  @@unique([missionId, dimension, retryLabel])
  @@index([missionId])
  @@map("agent_playground_research_results")
}

/// agent-playground per-chapter draft 完整产物持久化（P0-D 完整版）
/// rerun 时从此表 hydrate dimensionPipelines.chapters[i].content / score / status，
/// 让 S5+ 章节 pipeline 可跳过重写（仅 review 不通过的章节才重写）。
model AgentPlaygroundChapterDraft {
  id           String                 @id @default(uuid())
  missionId    String                 @map("mission_id")
  mission      AgentPlaygroundMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  dimension    String                 @db.VarChar(200)
  chapterIndex Int                    @map("chapter_index")
  heading      String                 @db.VarChar(500)
  thesis       String?                @db.Text
  content      String                 @db.Text
  /// 章节态：writing / reviewing / passed / done / failed-finalized
  status       String                 @db.VarChar(30)
  score        Int?
  critique     String?                @db.Text
  attempts     Int                    @default(1)
  wordCount    Int?                   @map("word_count")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  @@unique([missionId, dimension, chapterIndex])
  @@index([missionId])
  @@map("agent_playground_chapter_drafts")
}

/// ★ 报告版本化 (2026-05-06): rerun 每次产生新版本，不覆盖旧版本。
/// version 单调递增（1, 2, 3 ...），由 MissionStore.saveReportVersion 原子分配。
/// 旧版本 mission.report_full 保留，版本历史在此表查询。
model MissionReportVersion {
  id              String   @id @default(uuid())
  missionId       String   @map("mission_id")
  /// 单调递增版本号（1 = 首次 initial run，2+ = rerun）
  version         Int
  /// 人读版本标签，如 "initial-2026-05-06" / "rerun-fresh-2026-05-07"
  versionLabel    String?  @map("version_label") @db.VarChar(120)
  /// 完整 ReportArtifact v2（或 ResearchReport v1）
  reportFull      Json?    @map("report_full") @db.JsonB
  reportFullUri   String?  @map("report_full_uri")
  reportFullSize  Int?     @map("report_full_size")
  /// 报告标题（从 reportFull 提取，便于列表展示）
  reportTitle     String?  @map("report_title") @db.VarChar(500)
  /// 报告摘要（executiveSummary.markdown，便于列表展示）
  reportSummary   String?  @map("report_summary") @db.Text
  /// Leader 总分（来自 leaderSignOff.leaderOverallScore）
  finalScore      Int?     @map("final_score")
  /// Leader 是否签字（true=completed, false=quality-failed, null=failed/cancelled）
  leaderSigned    Boolean? @map("leader_signed")
  /// 触发类型：initial / rerun-fresh / rerun-incremental / todo-rerun
  triggerType     String   @map("trigger_type") @db.VarChar(40)
  /// diff vs 前一版本（可选，供将来 diff UI 用；首版本为 null）
  changesFromPrev Json?    @map("changes_from_prev") @db.JsonB
  /// 本版本生成时间
  generatedAt     DateTime @default(now()) @map("generated_at")

  mission AgentPlaygroundMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([missionId, version])
  @@index([missionId, generatedAt(sort: Desc)])
  @@map("mission_report_versions")
}

/// agent-playground 中用户与 mission Leader 的对话记录
model AgentPlaygroundLeaderChat {
  id         String                 @id @default(uuid())
  missionId  String                 @map("mission_id")
  mission    AgentPlaygroundMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  userId     String                 @map("user_id")
  role       String                 @db.VarChar(20) // user / assistant
  content    String                 @db.Text
  tokensUsed Int?                   @map("tokens_used")
  /// assistant-only：LLM JSON 决策
  /// { type: 'DIRECT_ANSWER'|'CREATE_TODO'|'CLARIFY'|'ACKNOWLEDGE',
  ///   understanding?, todo?: [{name, rationale}], clarifyOptions?: string[] }
  decision   Json?                  @db.JsonB
  createdAt  DateTime               @default(now()) @map("created_at")

  @@index([missionId, createdAt])
  @@map("agent_playground_leader_chats")
}

/// 跨 mission 失败模式记忆 —— 让 Harness 在新 mission 启动时
/// 检索"已知会撞墙的 (agent, model, prompt前缀, failureCode) 组合"，
/// 直接走 fallback 而不是浪费 token 重蹈覆辙。
///
/// key 设计：(agentSpecId, modelId, promptHashPrefix, failureCode) 复合唯一
/// promptHashPrefix = first 16 hex chars of sha256(systemPrompt) —— 同 agent 同
/// prompt 才算同模式。dimension/topic 不同会产生不同 hash，避免误伤。
model HarnessFailurePattern {
  id                String   @id @default(uuid())
  /// AgentSpec.id（如 'playground.researcher'）
  agentSpecId       String   @map("agent_spec_id") @db.VarChar(120)
  /// 失败时实际用的 LLM model id
  modelId           String   @map("model_id") @db.VarChar(120)
  /// systemPrompt sha256 前 16 字符（同 prompt 才算同模式）
  promptHashPrefix  String   @map("prompt_hash_prefix") @db.VarChar(16)
  /// HarnessFailureCode 字符串
  failureCode       String   @map("failure_code") @db.VarChar(64)
  /// 历史出现次数
  count             Int      @default(1)
  /// 最后一次失败的 missionId / userId，便于 root-cause 取证
  lastMissionId     String?  @map("last_mission_id")
  lastUserId        String?  @map("last_user_id")
  /// 最后一次的 diagnostic 快照（rawContent/parseError 等）
  lastDiagnostic    Json?    @map("last_diagnostic") @db.JsonB
  /// 上次成功 fallback 的 model id（如果有）—— 下次直接用
  lastFallbackModel String?  @map("last_fallback_model") @db.VarChar(120)
  /// 是否已在此 (agent, prompt, code) 上学到稳定 workaround（人工/自动标记）
  resolved          Boolean  @default(false)
  firstSeenAt       DateTime @default(now()) @map("first_seen_at")
  lastSeenAt        DateTime @default(now()) @updatedAt @map("last_seen_at")

  @@unique([agentSpecId, modelId, promptHashPrefix, failureCode], map: "harness_failure_pattern_uniq")
  @@index([agentSpecId, failureCode])
  @@index([lastSeenAt])
  @@map("harness_failure_patterns")
}

/// E R4 Phase 2 (2026-05-05): 用户自定义 Agent 定义（骨架阶段）
///
/// 用户在 5 步向导里配置自定义 agent（topic schema / skills 组合 / pipeline /
/// 集成）。当前为骨架（model + module + 第 1 步 basic info），控制器和 UI
/// 增量在后续 PR 补全。
///
///   - PR-E1（本次）：model + module + 1 步 basic info wizard
///   - PR-E2：5 步完整向导（topic schema / skills / pipeline / integration / review）
///   - PR-E3：与 agent-playground 集成（customAgentId → 启动 mission）
model CustomAgentDefinition {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String? @map("workspace_id")

  slug        String  @db.VarChar(64)
  displayName String  @map("display_name") @db.VarChar(128)
  description String? @db.Text

  /// 5 步向导各步骤数据（Json 持久化，避免每步加列）
  config Json

  /// 状态机：DRAFT / PUBLISHED / ARCHIVED
  status  String @default("DRAFT") @db.VarChar(16)
  /// 版本号（每次发布递增；下游引用版本而非 mutable id）
  version Int    @default(1)

  isEnabled Boolean @default(true) @map("is_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, slug])
  @@index([userId, status, isEnabled])
  @@map("custom_agent_definitions")
}

/// CustomAgentLaunch (2026-05-05 R-CA)
///
/// custom-agents 模块自己持有的 mission 启动记录，作用：
///   - 让每个 custom agent 主页（/custom-agents/:id）能 list "我用这个 agent 跑过的所有 mission"
///   - 不污染 base 层 agent_playground_missions 表（playground 不感知 custom agent 存在）
///
/// 设计：
///   - missionId 不加 FK 约束 —— mission 删除后 launch 仍保留 snapshot；UI 拿不到 mission 时显示"已删除"
///   - 启动失败的 mission 也写一条（debug 用）；mission_id null 时表示 launch 失败前抛错
model CustomAgentLaunch {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customAgentId String   @map("custom_agent_id")
  /// 关联的 mission id（playground 表的 row id），不强制 FK
  missionId     String?  @map("mission_id")
  /// 启动时的 topic 快照（mission 被删后仍可读）
  topic         String   @db.VarChar(500)
  startedAt     DateTime @default(now()) @map("started_at")

  @@index([userId, customAgentId, startedAt(sort: Desc)])
  @@index([missionId])
  @@map("custom_agent_launches")
}

/// AI Provider catalog（数据驱动 BYOK / 模型配置）
///
/// 替代之前 hardcoded PROVIDER_DEFAULTS（user-api-keys.service.ts）+ 前端
/// PROVIDER_ICONS 字典。新增 provider 走 admin UI / DB 写入即可，不改代码。
///
/// 双层 scope：
///   - system：全局可用，admin 维护，所有用户共享（OpenAI / Anthropic / Voyage 等）
///   - user：用户自定义（自托管 vLLM / 试验性 provider），仅 ownerUserId 可见
///
/// AIModel.provider 字段保持 string，等价于此表 slug 的软外键（不强制 FK
/// 是为兼容历史数据，且某些 provider 短暂出现/消失不应级联删模型）。
model AIProvider {
  id              String   @id @default(uuid())
  slug            String   @db.VarChar(50) // kebab-case 唯一标识（"voyage", "openai"）
  name            String   @db.VarChar(100) // 显示名 "Voyage AI"
  endpoint        String   @db.VarChar(500) // base URL
  apiFormat       String   @map("api_format") @db.VarChar(20) // openai / anthropic / google / cohere
  testModel       String   @map("test_model") @db.VarChar(100) // health check 探活模型 id
  /// 支持的 AIModelType 列表（CHAT / EMBEDDING / RERANK 等），驱动 capabilities 路由
  capabilities    String[]
  iconUrl         String?  @map("icon_url") @db.VarChar(500)
  description     String?  @db.Text
  docUrl          String?  @map("doc_url") @db.VarChar(500)
  freeTierNote    String?  @map("free_tier_note") @db.VarChar(300)
  /// 模型探测正则（一键自动配置时按此 patterns 匹配 GET /v1/models 返回的 ids）
  /// 形如 [{"modelType": "EMBEDDING", "patterns": ["^voyage-3"]}]
  recommendations Json?

  displayOrder Int     @default(0) @map("display_order")
  isEnabled    Boolean @default(true) @map("is_enabled")

  /// "system"（admin 维护，全局共享）或 "user"（用户自定义）
  scope       String  @db.VarChar(16)
  /// scope=user 时关联用户；scope=system 时为 null
  ownerUserId String? @map("owner_user_id")
  ownerUser   User?   @relation("UserAIProviders", fields: [ownerUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// 同 scope 下 slug 唯一；user scope 还需绑定 ownerUserId
  @@unique([slug, scope, ownerUserId])
  @@index([scope, isEnabled, displayOrder])
  @@index([ownerUserId])
  @@map("ai_providers")
}

/// 2026-05-11 P3 (BYOK 数据驱动重构)
///
/// API 格式模板表 —— 把 connection-test / chat call 派发用的"协议规范"从
/// switch case 硬编码迁出，admin 可在 UI 加自定义 OpenAI-兼容微调（覆盖
/// auth header 名 / prefix），新接入 provider 不必改代码。
///
/// 内置 4 行（isBuiltin=true，UI 显示但不可删除）：
///   - openai     : Bearer auth, OpenAI body schema
///   - anthropic  : x-api-key + anthropic-version 头, Anthropic body
///   - google     : x-goog-api-key, Google contents/parts body
///   - cohere     : Bearer, Cohere embed/rerank body
///
/// 自定义行（isBuiltin=false）：authStyle=custom 时由 customHeaderName /
/// customHeaderPrefix 指定。body schema 锁死 OpenAI 兼容（覆盖 95% 新 provider）。
model ApiFormat {
  id                 String  @id @default(uuid())
  slug               String  @db.VarChar(50)
  name               String  @db.VarChar(100)
  isBuiltin          Boolean @default(false) @map("is_builtin")
  /// "bearer" | "x-api-key" | "x-goog-api-key" | "custom"
  authStyle          String  @map("auth_style") @db.VarChar(40)
  /// authStyle=custom 时填，例如 "X-Custom-Auth"
  customHeaderName   String? @map("custom_header_name") @db.VarChar(100)
  /// 例如 "ApiKey " 或 "Token " 加在 apiKey 前面
  customHeaderPrefix String? @map("custom_header_prefix") @db.VarChar(40)
  description        String? @db.Text

  displayOrder Int     @default(0) @map("display_order")
  isEnabled    Boolean @default(true) @map("is_enabled")

  /// "system" 或 "user"
  scope       String  @db.VarChar(16)
  ownerUserId String? @map("owner_user_id")
  ownerUser   User?   @relation("UserApiFormats", fields: [ownerUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([slug, scope, ownerUserId])
  @@index([scope, isEnabled, displayOrder])
  @@map("api_formats")
}

/// 2026-05-11 P3 (BYOK 数据驱动重构)
///
/// 模型类型表 —— 把之前 frontend hardcoded MODEL_TYPE_OPTIONS（11 个枚举）
/// 迁到 DB，admin 可加自定义类型（如 VIDEO_GENERATION / STT），不改代码。
///
/// 内置 11 行（isBuiltin=true）：
///   CHAT / CHAT_FAST / CODE / IMAGE_GENERATION / IMAGE_EDITING / MULTIMODAL
///   EMBEDDING / RERANK / EVALUATOR / TTS / AUDIO
///
/// 业务侧仍按 enum AIModelType 路由（兼容期间）；自定义类型走 fallback 通用路径。
model ModelType {
  id               String  @id @default(uuid())
  slug             String  @db.VarChar(50)
  name             String  @db.VarChar(100)
  description      String? @db.Text
  /// "text" | "image" | "embed" | "audio" | "video" | "other"
  category         String  @db.VarChar(40)
  /// 推荐使用的 ApiFormat slug（admin 加新 modelType 时建议值）
  defaultApiFormat String? @map("default_api_format") @db.VarChar(50)
  isBuiltin        Boolean @default(false) @map("is_builtin")

  displayOrder Int     @default(0) @map("display_order")
  isEnabled    Boolean @default(true) @map("is_enabled")

  scope       String  @db.VarChar(16)
  ownerUserId String? @map("owner_user_id")
  ownerUser   User?   @relation("UserModelTypes", fields: [ownerUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([slug, scope, ownerUserId])
  @@index([scope, isEnabled, displayOrder])
  @@map("model_types")
}

/// PR-A0 (2026-05-06 v1.4 报告装配重构)
/// per-workspace feature flag grant —— 支持 admin RBAC 防 IDOR + 审计可溯源
/// 见 docs/architecture/ai-harness/evaluation/report-assembly-invariant-redesign.md §5.2
model FeatureFlagWorkspaceGrant {
  id          String    @id @default(uuid()) @db.Uuid
  flagKey     String    @map("flag_key")
  workspaceId String    @map("workspace_id") @db.Uuid
  enabled     Boolean   @default(true)
  grantedAt   DateTime  @default(now()) @map("granted_at")
  /// admin 用户 id；NOT NULL 强制每条 grant 都有责任人
  grantedBy   String    @map("granted_by") @db.Uuid
  expiresAt   DateTime? @map("expires_at")
  reason      String?

  @@unique([flagKey, workspaceId])
  @@index([flagKey, workspaceId, enabled])
  @@index([expiresAt])
  @@map("feature_flag_workspace_grant")
}

/// PR-A0 配套 audit log —— grant/revoke/update 全程可溯源
model FeatureFlagAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  flagKey     String   @map("flag_key")
  workspaceId String   @map("workspace_id") @db.Uuid
  /// 'grant' | 'revoke' | 'update'（DB CHECK 约束）
  action      String
  actorUserId String   @map("actor_user_id") @db.Uuid
  prevEnabled Boolean? @map("prev_enabled")
  nextEnabled Boolean? @map("next_enabled")
  reason      String?
  occurredAt  DateTime @default(now()) @map("occurred_at")

  @@index([flagKey, workspaceId, occurredAt(sort: Desc)])
  @@map("feature_flag_audit_log")
}
