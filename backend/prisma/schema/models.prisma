// ============ 积分系统 (Credits System) ============

// 积分交易类型
enum CreditTransactionType {
  // 获取类型
  INITIAL // 注册初始积分
  DAILY_CHECKIN // 每日签到
  TASK_REWARD // 任务奖励
  REFERRAL_BONUS // 推荐奖励
  ADMIN_GRANT // 管理员发放
  COMPENSATION // 异常补偿
  DONATION_REWARD // API Key 捐赠奖励
  DONATION_USAGE_REWARD // API Key 捐赠使用奖励（持续）
  // 消耗类型
  AI_ASK // AI 问答消耗
  AI_TEAMS // AI 团队消耗
  AI_OFFICE // AI 办公消耗
  AI_SIMULATION // AI 模拟消耗
  AI_WRITING // AI 写作消耗
  AI_IMAGE // AI 绘画消耗
  AI_SOCIAL // AI 社交内容消耗
  AI_RESEARCH // AI 研究消耗
  AI_INSIGHTS // AI 洞察消耗
  NOTEBOOK_RESEARCH // 笔记本研究消耗
  AI_PLANNING // AI 规划消耗
  EXPLORE // 探索页 AI 功能消耗
  LIBRARY // 资源库消耗
  NOTES // 笔记消耗
  COLLECTIONS // 收藏集消耗
  // 调整类型
  EXPIRATION // 过期扣除
  REFUND // 退款
  ADJUSTMENT // 手动调整
}

// 积分账户
model CreditAccount {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  balance       Int       @default(10000)
  totalEarned   Int       @default(10000) @map("total_earned")
  totalSpent    Int       @default(0) @map("total_spent")
  giftBalance   Int       @default(0) @map("gift_balance")
  giftExpiresAt DateTime? @map("gift_expires_at")
  isActive      Boolean   @default(true) @map("is_active")
  isFrozen      Boolean   @default(false) @map("is_frozen")
  todaySpent    Int       @default(0) @map("today_spent")
  todayDate     DateTime? @map("today_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]
  checkins     DailyCheckin[]

  @@index([userId])
  @@map("credit_accounts")
}

// 积分交易记录
model CreditTransaction {
  id                  String                @id @default(uuid())
  accountId           String                @map("account_id")
  type                CreditTransactionType
  amount              Int // 正数为收入，负数为支出
  balanceAfter        Int                   @map("balance_after")
  description         String                @db.VarChar(500)
  moduleType          String?               @map("module_type") // ai-ask, deep-research 等
  operationType       String?               @map("operation_type") // chat, research-deep 等
  referenceId         String?               @map("reference_id") // 关联的业务ID
  tokenCount          Int?                  @map("token_count") // AI调用消耗的token数
  inputTokens         Int?                  @map("input_tokens") // 输入token数
  outputTokens        Int?                  @map("output_tokens") // 输出token数
  cacheCreationTokens Int?                  @map("cache_creation_tokens") // Prompt Cache 写入token数
  cacheReadTokens     Int?                  @map("cache_read_tokens") // Prompt Cache 命中token数
  modelName           String?               @map("model_name") // 使用的AI模型
  idempotencyKey      String?               @unique @map("idempotency_key") // 幂等性key
  createdAt           DateTime              @default(now()) @map("created_at")

  account CreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt(sort: Desc)])
  @@index([type])
  @@index([moduleType, operationType])
  @@map("credit_transactions")
}

// 积分规则配置
model CreditRule {
  id               String   @id @default(uuid())
  moduleType       String   @map("module_type") // ai-ask, ai-studio, ai-teams 等
  operationType    String   @map("operation_type") // chat, research-quick, ai-reply 等
  baseCredits      Int      @map("base_credits") // 基础积分消耗
  tokenMultiplier  Float    @default(1.0) @map("token_multiplier") // Token乘数
  modelMultipliers Json     @default("{}") @map("model_multipliers") // 不同模型的倍率 {"gpt-4o": 2.0}
  name             String   @db.VarChar(100) // 规则名称
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([moduleType, operationType])
  @@map("credit_rules")
}

// 每日签到记录
model DailyCheckin {
  id            String   @id @default(uuid())
  accountId     String   @map("account_id")
  checkinDate   DateTime @map("checkin_date") @db.Date
  creditsEarned Int      @map("credits_earned")
  streakDays    Int      @default(1) @map("streak_days")
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  createdAt     DateTime @default(now()) @map("created_at")

  account CreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, checkinDate])
  @@index([accountId, checkinDate(sort: Desc)])
  @@index([ipAddress, checkinDate])
  @@map("daily_checkins")
}

// ============================================================================
// Slides Engine v3.0 - 检查点系统
// ============================================================================

// Slides 会话状态枚举
enum SlidesSessionStatus {
  ACTIVE // 进行中
  COMPLETED // 已完成
  ARCHIVED // 已归档
}

// Slides 会话表
model SlidesSession {
  id             String              @id @default(uuid())
  userId         String              @map("user_id")
  title          String              @db.VarChar(200)
  status         SlidesSessionStatus @default(ACTIVE)
  currentStateId String?             @map("current_state_id") // 当前检查点ID

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关联
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkpoints SlidesCheckpoint[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([status])
  @@map("slides_sessions")
}

// 检查点类型枚举
enum SlidesCheckpointType {
  TASK_DECOMPOSITION // 任务分解完成
  OUTLINE_CONFIRMED // 大纲确认
  PAGE_RENDERED // 单页渲染完成
  BATCH_RENDERED // 批量渲染完成
  USER_MODIFIED // 用户手动修改
  AUTO_SAVE // 自动保存
}

// Slides 检查点表
model SlidesCheckpoint {
  id        String               @id @default(uuid())
  sessionId String               @map("session_id")
  name      String               @db.VarChar(200) // 用户友好名称
  type      SlidesCheckpointType
  version   String               @db.VarChar(20) // 语义版本号 (1.0.0)

  // 状态快照 (JSON)
  stateJson Json @map("state_json") // CheckpointState 序列化

  // 元数据 (JSON)
  metadata Json @default("{}") // CheckpointMetadata 序列化

  createdAt DateTime @default(now()) @map("created_at")

  // 关联
  session SlidesSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt(sort: Desc)])
  @@index([type])
  @@map("slides_checkpoints")
}

// ============ AI Office - Slides Team ============

// Slides Team 执行状态
enum SlidesTeamStatus {
  PENDING // 等待开始
  ANALYZING // 内容分析中
  PLANNING // 结构规划中
  GENERATING // 内容生成中
  RENDERING // 渲染中
  REVIEWING // 质量审核中
  COMPLETED // 完成
  FAILED // 失败
}

// Slides Team 执行记录
model SlidesTeamExecution {
  id        String @id @default(uuid())
  sessionId String @map("session_id")
  userId    String @map("user_id")

  // 执行状态
  status          SlidesTeamStatus @default(PENDING)
  currentPhase    String?          @map("current_phase") @db.VarChar(50)
  progressPercent Int              @default(0) @map("progress_percent")

  // 输入
  sourceContent String  @map("source_content") @db.Text
  targetPages   Int?    @map("target_pages")
  stylePreset   String? @map("style_preset") @db.VarChar(50)
  audience      String? @db.VarChar(200)

  // Agent 执行结果（JSON）
  analysisResult   Json? @map("analysis_result") // ContentAnalyst 输出
  planningResult   Json? @map("planning_result") // VisualStrategist 输出
  generationResult Json? @map("generation_result") // ContentWriter 输出
  reviewResult     Json? @map("review_result") // QualityReviewer 输出

  // 错误信息
  errorMessage String? @map("error_message") @db.Text
  errorPhase   String? @map("error_phase") @db.VarChar(50)

  // 时间戳
  createdAt   DateTime  @default(now()) @map("created_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // 关联 - sessionId 只是普通字符串，不关联 SlidesSession（因为 team 模式使用临时 session ID）
  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs SlidesTeamLog[]

  @@index([sessionId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("slides_team_executions")
}

// Slides Team 执行日志
model SlidesTeamLog {
  id          String @id @default(uuid())
  executionId String @map("execution_id")

  // 日志信息
  phase     String @db.VarChar(50) // analyzing, planning, generating, rendering, reviewing
  agentName String @map("agent_name") @db.VarChar(50) // ContentAnalyst, VisualStrategist, etc.
  level     String @db.VarChar(10) // INFO, WARN, ERROR
  message   String @db.Text
  metadata  Json? // 额外数据

  createdAt DateTime @default(now()) @map("created_at")

  // 关联
  execution SlidesTeamExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, createdAt(sort: Desc)])
  @@index([phase])
  @@index([level])
  @@map("slides_team_logs")
}

// ============ Webhook 系统 ============

/// Webhook 事件类型
enum WebhookEventType {
  // Topic 事件
  TOPIC_CREATED
  TOPIC_UPDATED
  TOPIC_DELETED
  TOPIC_ARCHIVED

  // 消息事件
  MESSAGE_CREATED
  MESSAGE_DELETED

  // AI 响应事件
  AI_RESPONSE_CREATED
  AI_RESPONSE_ERROR

  // 任务事件
  MISSION_CREATED
  MISSION_COMPLETED
  MISSION_FAILED
  MISSION_CANCELLED

  // 成员事件
  MEMBER_JOINED
  MEMBER_LEFT
  AI_MEMBER_ADDED
  AI_MEMBER_REMOVED

  // 辩论事件
  DEBATE_STARTED
  DEBATE_COMPLETED
}

/// Webhook 订阅
model WebhookSubscription {
  id     String @id @default(cuid())
  userId String @map("user_id")

  // 订阅配置
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)
  url         String  @db.VarChar(2000) // 回调URL
  secret      String  @db.VarChar(256) // 签名密钥

  // 事件过滤
  events   WebhookEventType[] // 订阅的事件类型
  topicIds String[]           @map("topic_ids") // 限制特定话题，空表示所有

  // 状态
  isActive       Boolean   @default(true) @map("is_active")
  failureCount   Int       @default(0) @map("failure_count") // 连续失败次数
  lastFailureAt  DateTime? @map("last_failure_at")
  disabledReason String?   @map("disabled_reason") @db.VarChar(500)

  // 配置
  retryCount   Int @default(3) @map("retry_count") // 重试次数
  timeoutMs    Int @default(30000) @map("timeout_ms") // 超时时间
  batchSize    Int @default(1) @map("batch_size") // 批量发送大小
  batchDelayMs Int @default(0) @map("batch_delay_ms") // 批量延迟

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关联
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId, isActive])
  @@index([isActive])
  @@map("webhook_subscriptions")
}

/// Webhook 投递状态
enum WebhookDeliveryStatus {
  PENDING // 等待发送
  SENDING // 发送中
  SUCCESS // 成功
  FAILED // 失败
  RETRYING // 重试中
}

/// Webhook 投递日志
model WebhookDelivery {
  id             String @id @default(cuid())
  subscriptionId String @map("subscription_id")

  // 事件信息
  eventType WebhookEventType @map("event_type")
  eventId   String           @map("event_id") @db.VarChar(100) // 原始事件ID
  payload   Json // 事件数据

  // 投递状态
  status       WebhookDeliveryStatus @default(PENDING)
  attemptCount Int                   @default(0) @map("attempt_count")
  nextRetryAt  DateTime?             @map("next_retry_at")

  // 响应信息
  responseStatus Int?    @map("response_status")
  responseBody   String? @map("response_body") @db.Text
  responseTimeMs Int?    @map("response_time_ms")
  errorMessage   String? @map("error_message") @db.Text

  // 时间戳
  createdAt   DateTime  @default(now()) @map("created_at")
  deliveredAt DateTime? @map("delivered_at")

  // 关联
  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, status])
  @@index([status, nextRetryAt])
  @@index([eventType, createdAt(sort: Desc)])
  @@map("webhook_deliveries")
}

// ============ 微信数据源 ============

