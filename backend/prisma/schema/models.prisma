// ============================================================================
// AI Office - 智能文档生成系统
// 支持 PPT、Word、Excel 等多种格式，Genspark 风格版本管理
// ============================================================================

// 文档类型枚举
enum OfficeDocumentType {
  ARTICLE // 文章/博客 → DOCX
  PPT // 演示文稿 → PPTX
  SPREADSHEET // 数据表格 → XLSX
  REPORT // 分析报告 → DOCX/PDF
  PROPOSAL // 提案/计划书 → DOCX/PPTX
  RESEARCH // 研究文档 → DOCX
}

// 文档状态枚举
enum OfficeDocumentStatus {
  DRAFT // 草稿
  GENERATING // 生成中
  COMPLETED // 已完成
  ARCHIVED // 已归档
}

// 版本触发方式枚举
enum VersionTrigger {
  AI_GENERATION // AI生成新版本
  USER_EDIT // 用户编辑触发
  MANUAL_SAVE // 手动保存
  AUTO_SAVE // 自动保存
}

// 资源引用类型枚举
enum ResourceRefType {
  PRIMARY // 主要参考资源
  SUPPORTING // 辅助参考
  CITED // 引用来源
}

// AI Office 文档主表
model OfficeDocument {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  workspaceId String? @map("workspace_id")

  // 基础信息
  title  String               @db.VarChar(500)
  type   OfficeDocumentType
  status OfficeDocumentStatus @default(DRAFT)

  // 内容存储
  content       Json // 结构化内容 (每页/每节数据)
  markdown      String? @db.Text // Markdown 源码 (可选)
  htmlSnapshots Json?   @map("html_snapshots") // HTML 页面快照数组

  // 版本管理
  currentVersionId String? @map("current_version_id")

  // 元数据
  metadata Json @default("{}") // { slideCount, wordCount, duration, ... }

  // AI 配置 (动态，不硬编码模型)
  aiConfig       Json? @map("ai_config") // { textModelId, imageModelId, temperature, style }
  generationLogs Json? @map("generation_logs") // 生成过程日志

  // === 素材绑定与质量控制 (v2.0 新增) ===
  // 素材分析结果：{ chapters, keyInsights, dataPoints, quotes, recommendations }
  sourceAnalysis   Json?     @map("source_analysis")
  // 全局样式配置：{ header, footer, pageNumber, safeArea, brand, typography }
  globalStyle      Json?     @map("global_style")
  // 质量检查报告：{ duplicates, layoutIssues, contentIssues, consistencyIssues }
  qualityReport    Json?     @map("quality_report")
  qualityCheckedAt DateTime? @map("quality_checked_at")

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关联
  user           User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace?                    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  versions       OfficeDocumentVersion[]
  resourceRefs   OfficeDocumentResourceRef[]
  knowledgeBases OfficeDocumentKnowledgeBase[] // 关联的知识库

  @@index([userId, createdAt])
  @@index([workspaceId])
  @@index([type, status])
  @@map("office_documents")
}

// 文档版本表 (Genspark 风格保存点)
model OfficeDocumentVersion {
  id            String @id @default(uuid())
  documentId    String @map("document_id")
  versionNumber Int    @map("version_number") // 递增版本号 (1, 2, 3...)

  // 版本标识
  name        String  @db.VarChar(100) // "保存点-14" (自动生成)
  description String? @db.Text // AI 生成的版本描述

  // 内容快照
  contentSnapshot  Json    @map("content_snapshot") // 完整内容快照
  markdownSnapshot String? @map("markdown_snapshot") @db.Text // Markdown 快照

  // 触发信息
  trigger       VersionTrigger
  triggerSource String?        @map("trigger_source") @db.VarChar(200) // 触发来源详情

  // 元数据快照
  metadataSnapshot Json @map("metadata_snapshot") // { slideCount, wordCount }

  // 缩略图
  thumbnail String? @db.Text // Base64 or URL

  // AI 信息 (记录使用的模型，不硬编码)
  aiModelId  String? @map("ai_model_id") // 关联到 AIModel 表
  promptUsed String? @map("prompt_used") @db.Text // 生成时使用的 Prompt

  // 时间
  createdAt DateTime @default(now()) @map("created_at")

  // 关联
  document OfficeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, versionNumber])
  @@index([documentId, createdAt])
  @@map("office_document_versions")
}

// 文档资源引用表 (@ 引用系统)
model OfficeDocumentResourceRef {
  id         String @id @default(uuid())
  documentId String @map("document_id")
  resourceId String @map("resource_id")

  // 引用类型
  refType ResourceRefType @default(PRIMARY) @map("ref_type")

  // 使用追踪
  usedInPages       Int[]   @map("used_in_pages") // 在哪些页面使用了此资源
  extractionSummary String? @map("extraction_summary") @db.Text // AI 从资源提取的关键信息摘要

  // 时间
  createdAt DateTime @default(now()) @map("created_at")

  // 关联
  document OfficeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  resource Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([documentId, resourceId])
  @@index([documentId])
  @@index([resourceId])
  @@map("office_document_resource_refs")
}

// 文档模板表
enum TemplateCategory {
  BUSINESS // 商业
  ACADEMIC // 学术
  MARKETING // 营销
  TECHNICAL // 技术
  CREATIVE // 创意
  GENERAL // 通用
}

model OfficeDocumentTemplate {
  id String @id @default(uuid())

  // 基础信息
  name        String           @db.VarChar(200) // "商业计划书模板"
  description String?          @db.Text
  category    TemplateCategory @default(GENERAL)

  // 模板配置
  style         String @db.VarChar(50) // genspark, consulting, tech, ...
  defaultLayout String @default("cards") @map("default_layout") @db.VarChar(50) // cards, timeline, ...
  colorScheme   Json   @map("color_scheme") // { primary, accent, background, text }

  // 结构定义
  structure Json // 预定义的章节结构

  // 预览
  thumbnail String? @db.Text

  // 元数据
  usageCount Int     @default(0) @map("usage_count")
  isBuiltin  Boolean @default(false) @map("is_builtin")
  isPublic   Boolean @default(true) @map("is_public")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isBuiltin, isPublic])
  @@map("office_document_templates")
}

// ============ ASK AI 会话管理 ============

model AskSession {
  id           String  @id @default(uuid())
  userId       String  @map("user_id")
  title        String  @db.VarChar(200)
  summary      String? @db.Text // AI 生成的会话摘要
  modelId      String? @map("model_id") // 默认使用的模型
  isBookmarked Boolean @default(false) @map("is_bookmarked") // 书签标记

  // Teams 模式扩展（teams-mode v0.2）
  mode       AskSessionMode @default(SOLO)
  roomConfig Json           @default("{}") @map("room_config") // RoomConfigDto JSON

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user           User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       AskMessage[]
  knowledgeBases AskSessionKnowledgeBase[] // 关联的知识库
  members        AskRoomMember[]
  turns          AskRoomTurn[]
  runtimeState   AskRoomSessionRuntimeState?

  @@index([userId, updatedAt])
  @@index([userId, isBookmarked])
  @@map("ask_sessions")
}

enum AskSessionMode {
  SOLO
  ROOM
}

/// room runtime shared watermark / ephemeral coordination state
model AskRoomSessionRuntimeState {
  sessionId     String   @id @map("session_id")
  maxEmittedSeq Int      @default(0) @map("max_emitted_seq")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  session AskSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("ask_room_session_runtime_states")
}

model AskMessage {
  id        String  @id @default(uuid())
  sessionId String  @map("session_id")
  role      String  @db.VarChar(20) // user, assistant, system
  content   String  @db.Text
  modelId   String? @map("model_id") // 使用的模型 ID
  modelName String? @map("model_name") @db.VarChar(100) // 使用的模型名称

  // 元数据
  tokens    Int? // token 使用量
  webSearch Boolean @default(false) @map("web_search") // 是否启用网页搜索

  // Teams 模式扩展（teams-mode v0.2）
  senderType         AskSenderType @default(USER) @map("sender_type")
  senderMemberId     String?       @map("sender_member_id") // AskRoomMember.id, 软删后保留
  mentionedMemberIds String[]      @default([]) @map("mentioned_member_ids")
  turnId             String?       @map("turn_id")
  parentMessageId    String?       @map("parent_message_id") // 自引用：debate / handoff 链路
  sequenceNum        Int?          @map("sequence_num") // 房间内单调递增；流式排序用

  createdAt DateTime @default(now()) @map("created_at")

  session       AskSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderMember  AskRoomMember? @relation(fields: [senderMemberId], references: [id], onDelete: SetNull)
  turn          AskRoomTurn?   @relation(fields: [turnId], references: [id], onDelete: SetNull)
  parent        AskMessage?    @relation(name: "ask_msg_replies", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies       AskMessage[]   @relation(name: "ask_msg_replies")
  triggeredTurn AskRoomTurn?   @relation(name: "ask_turn_trigger")

  @@index([sessionId, createdAt])
  @@index([sessionId, sequenceNum])
  @@index([turnId])
  // mentionedMemberIds GIN 索引在迁移 SQL 中通过 CREATE INDEX CONCURRENTLY 创建
  @@map("ask_messages")
}

enum AskSenderType {
  USER
  AI
  SYSTEM
}

// 房间成员（一个 AI = 一行）；软删，不允许硬删除单成员
model AskRoomMember {
  id           String            @id @default(uuid())
  sessionId    String            @map("session_id")
  memberType   AskRoomMemberType @default(VIRTUAL) @map("member_type")
  agentId      String?           @map("agent_id") // memberType=REGISTERED 时为 harness AgentRegistry id
  modelId      String            @map("model_id")
  displayName  String            @map("display_name") @db.VarChar(100)
  role         AskRoomMemberRole @default(MEMBER)
  systemPrompt String?           @map("system_prompt") @db.Text
  persona      Json? // { tone, expertise, constraints }; ≤ 2KB by app validator
  order        Int               @default(0)
  enabled      Boolean           @default(true)
  deletedAt    DateTime?         @map("deleted_at") // 软删；查询默认过滤

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session  AskSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages AskMessage[]

  @@index([sessionId, order])
  @@index([sessionId, deletedAt])
  @@map("ask_room_members")
}

enum AskRoomMemberRole {
  LEADER
  MEMBER
}

enum AskRoomMemberType {
  REGISTERED // 已注册的 harness agent
  VIRTUAL // 用户即兴选 model + persona 构造的虚拟成员
}

// 每次用户消息触发的一次编排
model AskRoomTurn {
  id               String        @id @default(uuid())
  sessionId        String        @map("session_id")
  triggerMessageId String        @unique @map("trigger_message_id")
  mode             AskRoomMode
  status           AskTurnStatus @default(PENDING)
  participantIds   String[]      @default([]) @map("participant_ids")
  partialDeltas    Json?         @map("partial_deltas") // {messageId: {seq: deltaText}}, 断线重连补差用
  metadata         Json?
  startedAt        DateTime      @default(now()) @map("started_at")
  endedAt          DateTime?     @map("ended_at")

  session  AskSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  trigger  AskMessage   @relation(name: "ask_turn_trigger", fields: [triggerMessageId], references: [id], onDelete: Restrict)
  messages AskMessage[]

  @@index([sessionId, startedAt])
  @@map("ask_room_turns")
}

enum AskRoomMode {
  FREECHAT
  PARALLEL_MERGE
  DEBATE
  VOTE
  REVIEW
  HANDOFF
}

enum AskTurnStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ============ 推演 / Simulation ============

enum SimulationTeam {
  BLUE // 蓝军 - 我方/主角公司
  RED // 红军 - 竞争对手/挑战者
  GREEN // 绿军 - 市场/客户/供应商/渠道等利益相关方
  WHITE // 白方 - 裁判控制组/监管机构/政策制定者
  CHAOS // 混沌 - 黑天鹅事件制造者
  ARBITER // 系统裁判(AI)
  HUMAN // 人类干预
}

enum SimulationRunStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

model SimulationScenario {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(200)
  industry    String  @db.VarChar(100)
  region      String? @db.VarChar(100)
  goals       Json?
  constraints Json?
  dataSources Json?
  createdById String? @db.VarChar(36)

  companies SimulationCompany[]
  agents    SimulationAgent[]
  runs      SimulationRun[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([industry])
  @@map("simulation_scenarios")
}

model SimulationCompany {
  id         String  @id @default(uuid())
  scenarioId String  @db.VarChar(36)
  name       String  @db.VarChar(200)
  type       String? @db.VarChar(50) // benchmark/startup/region
  market     String? @db.VarChar(100)

  metrics     Json? // cash, capacity, inventory, price_band, debt, etc.
  publicData  Json?
  privateData Json?

  scenario SimulationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  agents   SimulationAgent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([scenarioId])
  @@map("simulation_companies")
}

model SimulationAgent {
  id            String         @id @default(uuid())
  scenarioId    String         @db.VarChar(36)
  companyId     String?        @db.VarChar(36)
  team          SimulationTeam @default(BLUE)
  role          String         @db.VarChar(100)
  persona       Json?
  memoryPublic  Json?
  memoryPrivate Json?
  tools         Json?

  scenario SimulationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  company  SimulationCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  turns    SimulationTurn[]   @relation("TurnAgents")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([scenarioId])
  @@index([companyId])
  @@index([team])
  @@map("simulation_agents")
}

model SimulationRun {
  id            String              @id @default(uuid())
  scenarioId    String              @db.VarChar(36)
  status        SimulationRunStatus @default(PENDING)
  params        Json?
  rounds        Int                 @default(2)
  currentRound  Int                 @default(0)
  worldState    Json?
  evidenceTrail Json?
  summary       Json?
  startedById   String?             @db.VarChar(36)

  scenario SimulationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  turns    SimulationTurn[]

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  @@index([scenarioId])
  @@index([status])
  @@map("simulation_runs")
}

model SimulationTurn {
  id           String @id @default(uuid())
  runId        String @db.VarChar(36)
  roundNumber  Int
  submissions  Json?
  adjudication Json?
  evidence     Json?
  worldState   Json?

  run    SimulationRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  agents SimulationAgent[] @relation("TurnAgents")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([runId, roundNumber])
  @@map("simulation_turns")
}

// ============ AI Office Agent 矩阵系统 ============

enum OfficeAgentType {
  SLIDES
  DOCS
  DESIGNER
}

enum OfficeTaskStatus {
  PENDING
  PLANNING
  EXECUTING
  COMPLETED
  FAILED
  CANCELLED
}

enum OfficeArtifactType {
  PPTX
  DOCX
  PDF
  IMAGE
  CODE
  DATA
}

// AI Office Agent 任务记录
model OfficeAgentTask {
  id        String           @id @default(uuid())
  userId    String?          @map("user_id") @db.VarChar(36)
  agentType OfficeAgentType  @map("agent_type")
  status    OfficeTaskStatus @default(PENDING)

  input  Json // AgentInput
  plan   Json? // AgentPlan
  result Json? // AgentResult

  // 性能指标
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  duration    Int? // 毫秒

  // 资源消耗
  tokensUsed Int @default(0) @map("tokens_used")
  toolCalls  Int @default(0) @map("tool_calls")

  // 错误信息
  error String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  artifacts OfficeAgentArtifact[]
  toolLogs  OfficeAgentToolLog[]

  @@index([userId, agentType])
  @@index([status])
  @@index([createdAt])
  @@map("office_agent_tasks")
}

// AI Office Agent 产出物
model OfficeAgentArtifact {
  id       String             @id @default(uuid())
  taskId   String             @map("task_id") @db.VarChar(36)
  type     OfficeArtifactType
  name     String
  mimeType String             @map("mime_type")
  size     Int
  url      String? // S3 URL
  content  Json? // 内联内容

  createdAt DateTime @default(now()) @map("created_at")

  task OfficeAgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("office_agent_artifacts")
}

// AI Office Agent 工具调用日志
model OfficeAgentToolLog {
  id       String  @id @default(uuid())
  taskId   String  @map("task_id") @db.VarChar(36)
  toolType String  @map("tool_type")
  input    Json
  output   Json?
  duration Int // 毫秒
  success  Boolean
  error    String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  task OfficeAgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("office_agent_tool_logs")
}

// ============ 用户反馈系统 ============

enum FeedbackType {
  BUG
  FEATURE
  IMPROVEMENT
  OTHER
  ANNOTATION
}

enum FeedbackStatus {
  PENDING
  REVIEWED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Feedback {
  id          String         @id @default(uuid())
  type        FeedbackType
  status      FeedbackStatus @default(PENDING)
  title       String         @db.VarChar(500)
  description String         @db.Text
  userEmail   String?        @map("user_email") @db.VarChar(255)
  userAgent   String?        @map("user_agent") @db.Text
  pageUrl     String?        @map("page_url") @db.Text
  userId      String?        @map("user_id") // 已登录用户的ID
  adminNotes  String?        @map("admin_notes") @db.Text
  // 附件存储 - JSON数组: [{filename, url, size, mimeType}]
  attachments Json?          @default("[]")

  // 新增：优先级和分配
  priority   FeedbackPriority @default(NORMAL)
  assignedTo String?          @map("assigned_to") // 分配给的管理员ID
  assignedAt DateTime?        @map("assigned_at")
  tags       String[]         @default([]) // 分类标签
  source     String           @default("web") @db.VarChar(20) // web, mobile, email, api

  // 回复计数（冗余字段，提升查询性能）
  replyCount Int @default(0) @map("reply_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  replies  FeedbackReply[] @relation("FeedbackReplies")
  assignee User?           @relation("FeedbackAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([createdAt(sort: Desc)])
  @@map("feedbacks")
}

// ============ Notion 集成 ============

enum NotionConnectionStatus {
  ACTIVE
  REVOKED
  EXPIRED
  ERROR
}

enum NotionSyncStatus {
  PENDING
  SYNCING
  SUCCESS
  FAILED
}

// 用户的 Notion 工作区连接
model NotionConnection {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // OAuth 凭证
  accessToken   String  @map("access_token") @db.Text
  botId         String  @map("bot_id")
  workspaceId   String  @map("workspace_id")
  workspaceName String? @map("workspace_name")
  workspaceIcon String? @map("workspace_icon")
  ownerType     String  @default("user") @map("owner_type") // user | workspace

  // 连接状态
  status     NotionConnectionStatus @default(ACTIVE)
  lastSyncAt DateTime?              @map("last_sync_at")
  lastError  String?                @map("last_error") @db.Text

  // 同步配置
  syncConfig Json @default("{}") @map("sync_config")
  // { autoSync: true, syncInterval: 60, syncPages: true, syncDatabases: true }

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages       NotionPage[]
  databases   NotionDatabase[]
  syncHistory NotionSyncHistory[]

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([status])
  @@map("notion_connections")
}

// 同步的 Notion 页面
model NotionPage {
  id           String @id @default(uuid())
  connectionId String @map("connection_id")
  notionPageId String @map("notion_page_id")

  // 页面元数据
  title    String  @db.VarChar(1000)
  icon     String? @db.VarChar(200)
  coverUrl String? @map("cover_url") @db.Text
  url      String  @db.Text

  // 父级信息
  parentType String? @map("parent_type") // page | database | workspace
  parentId   String? @map("parent_id")

  // 内容（JSON 块）
  blocks           Json    @default("[]")
  plainTextContent String? @map("plain_text_content") @db.Text // 用于搜索

  // Notion 时间戳
  notionCreatedAt DateTime @map("notion_created_at")
  notionUpdatedAt DateTime @map("notion_updated_at")

  // 同步状态
  syncStatus   NotionSyncStatus @default(PENDING) @map("sync_status")
  lastSyncedAt DateTime?        @map("last_synced_at")
  syncError    String?          @map("sync_error") @db.Text

  // 本地修改追踪
  isLocallyModified Boolean   @default(false) @map("is_locally_modified")
  localModifiedAt   DateTime? @map("local_modified_at")

  // 可选：链接到 Library 资源
  linkedResourceId String? @map("linked_resource_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  connection NotionConnection     @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  versions   NotionBlockVersion[]

  @@unique([connectionId, notionPageId])
  @@index([connectionId])
  @@index([notionPageId])
  @@index([syncStatus])
  @@index([notionUpdatedAt])
  @@map("notion_pages")
}

// 同步的 Notion 数据库
model NotionDatabase {
  id           String @id @default(uuid())
  connectionId String @map("connection_id")
  notionDbId   String @map("notion_db_id")

  // 数据库元数据
  title       String  @db.VarChar(1000)
  description String? @db.Text
  icon        String? @db.VarChar(200)
  coverUrl    String? @map("cover_url") @db.Text
  url         String  @db.Text

  // Schema 定义（列属性）
  properties Json @default("{}")

  // 缓存的条目
  items     Json @default("[]") // 数据库条目数组
  itemCount Int  @default(0) @map("item_count")

  // 同步状态
  syncStatus   NotionSyncStatus @default(PENDING) @map("sync_status")
  lastSyncedAt DateTime?        @map("last_synced_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  connection NotionConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, notionDbId])
  @@index([connectionId])
  @@index([notionDbId])
  @@map("notion_databases")
}

// 版本历史（冲突解决用）
model NotionBlockVersion {
  id     String @id @default(uuid())
  pageId String @map("page_id")

  version Int
  blocks  Json // 完整块快照
  source  String // "notion" | "local"

  createdAt DateTime @default(now()) @map("created_at")

  page NotionPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, version])
  @@map("notion_block_versions")
}

// 同步历史
model NotionSyncHistory {
  id           String @id @default(uuid())
  connectionId String @map("connection_id")

  syncType String // "full" | "incremental" | "manual"
  status   NotionSyncStatus

  pagesProcessed Int @default(0) @map("pages_processed")
  pagesCreated   Int @default(0) @map("pages_created")
  pagesUpdated   Int @default(0) @map("pages_updated")
  pagesDeleted   Int @default(0) @map("pages_deleted")

  errors Json? // 错误详情数组

  startedAt   DateTime  @map("started_at")
  completedAt DateTime? @map("completed_at")
  durationMs  Int?      @map("duration_ms")

  connection NotionConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, startedAt])
  @@map("notion_sync_history")
}

// ============ AI Studio Deep Research ============

enum DeepResearchStatus {
  PLANNING // AI 正在规划研究步骤
  PLAN_READY // 计划已生成，等待用户审批
  IDEATION // 团队头脑风暴讨论
  SEARCHING // 正在执行搜索
  FINDINGS // 团队汇报讨论发现
  REFLECTING // 正在自我反思评估
  SYNTHESIZING // 正在合成报告
  COMPLETED // 研究完成
  FAILED // 研究失败
  CANCELLED // 用户取消
}

model DeepResearchSession {
  id        String @id @default(uuid())
  projectId String @map("project_id")

  // 研究查询
  query String @db.Text

  // 研究模式
  mode String @default("single") @map("research_mode") // "single" | "iterative"

  // 状态
  status DeepResearchStatus @default(PLANNING)

  // AI 生成的研究计划
  plan Json? // { objective, steps: [{ id, type, query, rationale }] }

  // 搜索轮次记录
  searchRounds Json[] @default([]) @map("search_rounds") // [{ round, query, resultsCount, sources }]

  // 自我反思记录
  reflections Json[] @default([]) // [{ assessment, decision, reasoning }]

  // 思考链
  thinkingChain Json[] @default([]) @map("thinking_chain") // [{ step, content, timestamp }]

  // 最终报告
  report Json? // { executiveSummary, sections, conclusion, references }

  // 统计信息
  sourcesUsed Int @default(0) @map("sources_used")
  tokensUsed  Int @default(0) @map("tokens_used")

  // 错误信息
  error String? @db.Text

  // 讨论驱动型研究
  discussion Json[] @default([]) // DiscussionMessage[]
  directions Json? // { directions: ResearchDirection[] }

  // 时间戳
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  // 关系
  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ideas   ResearchIdea[]

  @@index([projectId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("deep_research_sessions")
}

// ============ 研究创意 & 演示 ============

enum ResearchIdeaType {
  INSIGHT // 观点荟萃 - 从讨论中提炼的分析判断和洞察
  CREATIVE_IDEA // 研究创意 - 从观点中衍生的创新方案
}

enum ResearchIdeaStatus {
  DISCOVERED // 从讨论中自动发现
  STARRED // 用户标记收藏
  ARCHIVED // 用户归档
}

enum ResearchDemoStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model ResearchIdea {
  id              String             @id @default(uuid())
  projectId       String             @map("project_id")
  sessionId       String?            @map("session_id")
  title           String             @db.VarChar(500)
  description     String             @db.Text
  sourceMessageId String?            @map("source_message_id")
  agentRole       String?            @map("agent_role") @db.VarChar(50)
  agentName       String?            @map("agent_name") @db.VarChar(100)
  type            ResearchIdeaType   @default(INSIGHT)
  status          ResearchIdeaStatus @default(DISCOVERED)
  tags            String[]           @default([])
  evidence        Json?
  metadata        Json?
  sourceInsightId String?            @map("source_insight_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  project       ResearchProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session       DeepResearchSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  demos         ResearchDemo[]
  sourceInsight ResearchIdea?        @relation("InsightToIdea", fields: [sourceInsightId], references: [id], onDelete: SetNull)
  derivedIdeas  ResearchIdea[]       @relation("InsightToIdea")

  @@index([projectId])
  @@index([sessionId])
  @@index([status])
  @@index([type])
  @@map("research_ideas")
}

model ResearchDemo {
  id          String             @id @default(uuid())
  ideaId      String             @map("idea_id")
  projectId   String             @map("project_id")
  title       String             @db.VarChar(500)
  htmlContent String             @map("html_content") @db.Text
  status      ResearchDemoStatus @default(PENDING)
  error       String?            @db.Text
  metadata    Json?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  idea    ResearchIdea    @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([ideaId])
  @@index([projectId])
  @@index([status])
  @@map("research_demos")
}

// ============ 统一导出系统 ============

enum ExportSourceType {
  DOCUMENT // AI Office 文档
  RESEARCH // Deep Research 会话
  REPORT // Content Report
  RAW // 原始内容 (Markdown/JSON)
  MISSION // AI Teams 任务报告
  PLANNING // AI Planning 规划报告
  WRITING // AI Writing 写作文档
  SOCIAL // AI Social 社交内容
  SLIDES // AI Slides 演示文稿
  TOPIC_REPORT // AI Insights 专题报告
  WIKI // ★ v1.5.3 LLM Wiki tarball export
}

enum ExportFormat {
  PDF
  DOCX
  PPTX
  XLSX
  MARKDOWN
  HTML
  TARBALL // ★ v1.5.3 LLM Wiki raw/+wiki/ directory tarball
}

enum ExportJobStatus {
  QUEUED // 排队中
  PROCESSING // 处理中
  COMPLETED // 已完成
  FAILED // 失败
}

enum ExportTemplateCategory {
  REPORT // 报告类
  PPT // 演示文稿
  DOCUMENT // 通用文档
  ACADEMIC // 学术论文
  BUSINESS // 商务文档
}

// 导出任务
model ExportJob {
  id String @id @default(cuid())

  // 来源信息
  sourceType ExportSourceType @map("source_type")
  sourceId   String?          @map("source_id") // 来源ID (如果有)
  sourceData Json?            @map("source_data") // 原始内容 (如果是RAW类型)

  // 导出配置
  format     ExportFormat @map("format")
  templateId String?      @map("template_id")
  options    Json         @default("{}") // 导出选项

  // 状态
  status   ExportJobStatus @default(QUEUED)
  progress Int             @default(0) // 0-100
  error    String?         @db.Text

  // 结果
  fileName    String?   @map("file_name")
  fileSize    Int?      @map("file_size")
  filePath    String?   @map("file_path") // 内部存储路径
  downloadUrl String?   @map("download_url") // 临时下载URL
  expiresAt   DateTime? @map("expires_at") // URL过期时间

  // 元数据
  userId String @map("user_id")

  // 时间戳
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  // 关联
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  template ExportTemplate? @relation(fields: [templateId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("export_jobs")
}

// 导出模板
model ExportTemplate {
  id String @id @default(cuid())

  // 基本信息
  name        String
  description String?                @db.Text
  category    ExportTemplateCategory

  // 配置 (JSON)
  themeConfig  Json  @map("theme_config") // 主题配置
  layoutConfig Json  @map("layout_config") // 布局配置
  styleConfig  Json? @map("style_config") // 额外样式

  // 适用性
  supportedFormats ExportFormat[]     @map("supported_formats")
  supportedSources ExportSourceType[] @map("supported_sources")

  // 状态
  isBuiltIn Boolean @default(false) @map("is_built_in") // 系统内置
  isDefault Boolean @default(false) @map("is_default") // 默认模板
  isPublic  Boolean @default(false) @map("is_public") // 公开模板

  // 预览
  previewImage String? @map("preview_image")

  // 版本
  version Int @default(1)

  // 归属
  userId      String? @map("user_id")
  workspaceId String? @map("workspace_id")

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关联
  user       User?       @relation(fields: [userId], references: [id])
  exportJobs ExportJob[]

  @@index([category, isBuiltIn])
  @@index([userId])
  @@map("export_templates")
}

// ============ Google Drive 集成 ============

enum GoogleDriveConnectionStatus {
  ACTIVE
  ERROR
  EXPIRED
  REVOKED
}

enum GoogleDriveSyncAction {
  IMPORT
  EXPORT
}

enum GoogleDriveSyncStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
}

// Google Drive 连接
model GoogleDriveConnection {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  // OAuth 凭证
  accessToken  String   @map("access_token") @db.Text
  refreshToken String   @map("refresh_token") @db.Text
  tokenExpiry  DateTime @map("token_expiry")

  // Google 账号信息
  googleId    String  @unique @map("google_id")
  email       String
  displayName String? @map("display_name")
  photoUrl    String? @map("photo_url")

  // 存储空间
  storageLimit BigInt? @map("storage_limit")
  storageUsage BigInt? @map("storage_usage")

  // 连接状态
  status     GoogleDriveConnectionStatus @default(ACTIVE)
  lastError  String?                     @map("last_error") @db.Text
  lastSyncAt DateTime?                   @map("last_sync_at")

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncHistory    GoogleDriveSyncHistory[]
  importedFiles  GoogleDriveImportedFile[]
  knowledgeBases KnowledgeBase[]

  @@index([userId, status])
  @@index([googleId])
  @@map("google_drive_connections")
}

// Google Drive 同步历史
model GoogleDriveSyncHistory {
  id           String @id @default(uuid())
  connectionId String @map("connection_id")

  // 同步操作
  action GoogleDriveSyncAction
  status GoogleDriveSyncStatus

  // 文件信息
  googleFileId   String? @map("google_file_id")
  googleFileName String? @map("google_file_name")
  resourceId     String? @map("resource_id")

  // 导出配置 (仅 EXPORT 时使用)
  exportFormat   String? @map("export_format")
  targetFolderId String? @map("target_folder_id")

  // 错误信息
  error String? @db.Text

  // 元数据
  metadata Json? // 额外的同步元数据

  // 时间戳
  startedAt   DateTime  @map("started_at")
  completedAt DateTime? @map("completed_at")

  // 关系
  connection GoogleDriveConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, startedAt])
  @@index([status, startedAt])
  @@map("google_drive_sync_history")
}

// Google Drive 导入文件映射
model GoogleDriveImportedFile {
  id           String @id @default(uuid())
  connectionId String @map("connection_id")

  // Google Drive 文件信息
  googleFileId       String   @map("google_file_id")
  googleFileName     String   @map("google_file_name")
  mimeType           String   @map("mime_type")
  googleModifiedTime DateTime @map("google_modified_time")

  // 本地资源映射
  resourceId String @unique @map("resource_id")

  // 同步状态
  lastSyncedAt DateTime @default(now()) @map("last_synced_at")

  // 关系
  connection GoogleDriveConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, googleFileId])
  @@index([connectionId, googleFileId])
  @@index([resourceId])
  @@map("google_drive_imported_files")
}

// ============ RAG Knowledge Base ============

enum KnowledgeBaseStatus {
  PENDING
  PROCESSING
  READY
  UPDATING
  ERROR
}

enum KnowledgeBaseSourceType {
  GOOGLE_DRIVE
  MANUAL
  URL
  BOOKMARK // 平台内书签
  NOTE // 平台内笔记
  IMAGE // 图片OCR
  WECHAT_ARTICLE // 微信公众号文章
  WECHAT_VIDEO // 微信视频号视频
}

// 知识库类型
enum KnowledgeBaseType {
  PERSONAL // 个人知识库
  TEAM // 团队知识库
}

// 用户数据源类型 (用于知识库)
enum UserDataSourceType {
  GOOGLE_DRIVE
  NOTION
  BOOKMARK // 平台内书签
  NOTE // 平台内笔记
  UPLOAD // 手动上传文件
  URL // URL 抓取
  IMAGE // 图片 (OCR)
  WECHAT // 微信同步 (公众号文章、视频号)
}

// 搜索优先级 (用于 AI Studio 等模块)
enum SearchPriority {
  KNOWLEDGE_BASE_FIRST // 知识库优先
  WEB_FIRST // 网络优先
  BALANCED // 平衡模式
}

model KnowledgeBase {
  id          String                  @id @default(uuid())
  name        String
  description String?                 @db.Text
  sourceType  KnowledgeBaseSourceType @default(MANUAL) @map("source_type") // 保留向后兼容
  sourceTypes Json                    @default("[\"MANUAL\"]") @map("source_types") // 多数据源类型数组
  status      KnowledgeBaseStatus     @default(PENDING)

  // 知识库类型 (个人/团队)
  type   KnowledgeBaseType @default(PERSONAL)
  teamId String?           @map("team_id") // 团队知识库关联的团队ID

  // User ownership
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Google Drive connection (for GOOGLE_DRIVE source)
  googleDriveConnectionId String?                @map("google_drive_connection_id")
  googleDriveConnection   GoogleDriveConnection? @relation(fields: [googleDriveConnectionId], references: [id], onDelete: SetNull)
  googleDriveFolderIds    Json                   @default("[]") @map("google_drive_folder_ids")
  googleDriveFileIds      Json                   @default("[]") @map("google_drive_file_ids") // 单独选择的文件 IDs

  // Sync metadata
  lastSyncedAt DateTime? @map("last_synced_at")
  lastError    String?   @map("last_error") @db.Text

  // 向量化进度（仅 PROCESSING 中非 null；shape: KbVectorizeProgress in embedding-processor）
  progressJson Json? @map("progress_json")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations - 文档
  documents KnowledgeBaseDocument[]

  // Relations - 数据源 (多对多)
  sources KnowledgeBaseSource[]

  // Relations - 成员 (团队知识库)
  members KnowledgeBaseMember[]

  // Relations - 被其他模块引用
  askSessions      AskSessionKnowledgeBase[]
  researchProjects ResearchProjectKnowledgeBase[]
  topics           TopicKnowledgeBase[]
  officeDocuments  OfficeDocumentKnowledgeBase[]

  // ★ v1.5.3 LLM Wiki 主形态（Library 默认 tab）
  wikiEnabled           Boolean                  @default(false) @map("wiki_enabled")
  wikiPages             WikiPage[]
  wikiDiffs             WikiDiff[]
  wikiOps               WikiOperationLog[]
  wikiFinds             WikiLintFinding[]
  wikiConfig            WikiKnowledgeBaseConfig?
  wikiDocumentCoverages WikiDocumentCoverage[]   @relation("WikiDocumentCoverageKnowledgeBase")

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([teamId])
  @@index([googleDriveConnectionId])
  @@map("knowledge_bases")
}

// 知识库成员角色
enum KnowledgeBaseMemberRole {
  OWNER // 所有者，完全控制权
  ADMIN // 管理员，可管理成员和内容
  EDITOR // 编辑者，可编辑内容
  VIEWER // 查看者，只读权限
}

// 团队知识库成员
model KnowledgeBaseMember {
  id String @id @default(uuid())

  knowledgeBaseId String        @map("knowledge_base_id")
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role KnowledgeBaseMemberRole @default(VIEWER)

  // 时间戳
  joinedAt  DateTime @default(now()) @map("joined_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([knowledgeBaseId, userId])
  @@index([knowledgeBaseId])
  @@index([userId])
  @@map("knowledge_base_members")
}

model KnowledgeBaseDocument {
  id              String        @id @default(uuid())
  knowledgeBaseId String        @map("knowledge_base_id")
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  // Document info
  title      String
  sourceType String  @map("source_type")
  sourceId   String? @map("source_id")
  sourceUrl  String? @map("source_url") @db.Text
  mimeType   String? @map("mime_type")

  // Content
  // rawContent: 写时落 DB；status=COMPLETED 后由 StorageOffloadService 搬到 R2，
  // 落 R2 后 DB 列置 ""，rawContentUri 写入 key（"kb-documents/{id}/raw.txt"）。
  // 读路径走 PrismaService.installKnowledgeBaseDocumentHydration 透明回填。
  // 调用方 select rawContent 必须同时 select rawContentUri（hydrate 守卫会警告）。
  rawContent     String  @map("raw_content") @db.Text
  rawContentUri  String? @map("raw_content_uri")
  rawContentSize Int?    @map("raw_content_size")

  // Processing status
  status      KnowledgeBaseStatus @default(PENDING)
  processedAt DateTime?           @map("processed_at")
  chunkCount  Int                 @default(0) @map("chunk_count")
  lastError   String?             @map("last_error") @db.Text

  // Metadata
  metadata Json @default("{}")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  parentChunks ParentChunk[]

  // ★ v1.5.3 LLM Wiki citation reverse relation
  wikiSources           WikiPageSource[]
  wikiDocumentCoverages WikiDocumentCoverage[] @relation("WikiDocumentCoverageDocument")

  @@index([knowledgeBaseId])
  @@index([sourceId])
  @@index([status])
  @@map("knowledge_base_documents")
}

model ParentChunk {
  id         String                @id @default(uuid())
  documentId String                @map("document_id")
  document   KnowledgeBaseDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Content
  content    String @db.Text
  tokenCount Int    @map("token_count")
  position   Int // Order within document

  // Document location info (for source citation)
  pageStart    Int?    @map("page_start")
  pageEnd      Int?    @map("page_end")
  sectionTitle String? @map("section_title") @db.VarChar(500)

  // Metadata (JSON for flexible storage)
  metadata Json? @default("{}")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  childChunks ChildChunk[]

  @@index([documentId])
  @@map("parent_chunks")
}

model ChildChunk {
  id            String      @id @default(uuid())
  parentChunkId String      @map("parent_chunk_id")
  parentChunk   ParentChunk @relation(fields: [parentChunkId], references: [id], onDelete: Cascade)

  // Denormalized document reference (for convenience queries)
  documentId String? @map("document_id")

  // Content
  content    String @db.Text
  tokenCount Int    @map("token_count")
  position   Int // Order within parent

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  embeddings ChildEmbedding[]

  @@index([parentChunkId])
  @@index([documentId])
  @@map("child_chunks")
}

// Note: 使用 pgvector 存储向量，支持 HNSW 索引和数据库级余弦相似度搜索
model ChildEmbedding {
  id           String     @id @default(uuid())
  childChunkId String     @unique @map("child_chunk_id")
  childChunk   ChildChunk @relation(fields: [childChunkId], references: [id], onDelete: Cascade)

  // 向量数据 - JSONB 存储（Railway PostgreSQL 不支持 pgvector 扩展）
  // 相似度搜索在应用层计算余弦距离
  embedding  Json
  model      String @default("text-embedding-3-small")
  dimensions Int    @default(1536)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([childChunkId])
  @@map("child_embeddings")
}

// ============ 用户数据源管理 (用于知识库) ============

// 用户连接的数据源 (区别于 DataSource 采集数据源)
model UserDataSource {
  id     String             @id @default(uuid())
  userId String             @map("user_id")
  type   UserDataSourceType

  // 连接状态
  isConnected Boolean   @default(false) @map("is_connected")
  lastSyncAt  DateTime? @map("last_sync_at")
  lastError   String?   @map("last_error") @db.Text

  // 配置 (JSON)
  // Google Drive: { folderId, accessToken, refreshToken }
  // Notion: { workspaceId, accessToken, selectedPages }
  config Json @default("{}")

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  kbSources KnowledgeBaseSource[]

  @@index([userId, type])
  @@map("user_data_sources")
}

// 知识库与用户数据源的多对多关系
model KnowledgeBaseSource {
  id              String @id @default(uuid())
  knowledgeBaseId String @map("knowledge_base_id")
  dataSourceId    String @map("data_source_id")

  // 同步配置
  syncEnabled  Boolean   @default(true) @map("sync_enabled")
  syncInterval Int       @default(3600) @map("sync_interval") // 秒
  lastSyncAt   DateTime? @map("last_sync_at")

  // 过滤规则 (可选)
  // 例如: { includeFolders: ['xxx'], excludePatterns: ['*.tmp'] }
  filterConfig Json @default("{}") @map("filter_config")

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")

  // 关系
  knowledgeBase KnowledgeBase  @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  dataSource    UserDataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@unique([knowledgeBaseId, dataSourceId])
  @@map("knowledge_base_sources")
}

