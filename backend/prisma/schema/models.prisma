  DRAFT // 初稿
  CHECKING // 校验中
  REVISING // 修订中
  FINAL // 定稿
}

// 章节
model WritingChapter {
  id       String        @id @default(uuid())
  volumeId String        @map("volume_id")
  volume   WritingVolume @relation(fields: [volumeId], references: [id], onDelete: Cascade)

