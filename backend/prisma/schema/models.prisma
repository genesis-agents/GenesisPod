}

// 写作项目
model WritingProject {
  id          String  @id @default(uuid())
  name        String  @db.VarChar(200)
  description String? @db.Text

  // 项目配置
  genre        String               @db.VarChar(50) // 类型：玄幻、都市、历史、科幻等
  targetWords  Int                  @default(100000) @map("target_words") // 目标字数
  currentWords Int                  @default(0) @map("current_words") // 当前字数
  status       WritingProjectStatus @default(PLANNING)
  visibility   ContentVisibility    @default(PRIVATE) // 可见性：私有/公开

  // 写作配置
  writingStyle   String? @map("writing_style") @db.VarChar(100) // 写作风格
  targetAudience String? @map("target_audience") @db.VarChar(100) // 目标读者
  pov            String? @db.VarChar(50) // 视角：第一人称、第三人称等
  tense          String? @db.VarChar(50) // 时态

