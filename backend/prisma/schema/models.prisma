  completedAt    DateTime? @map("completed_at")
  status         String // COMPLETED | FAILED | CANCELLED

  // ========== 研究目标 ==========
  researchGoal     String? @map("research_goal") @db.Text
  researchStrategy String? @map("research_strategy") @db.Text

