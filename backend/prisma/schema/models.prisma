  trustLevel       Int     @default(5) @map("trust_level") // 信任倾向 1-10
  assertiveness    Int     @default(5) // 主张性 1-10

  // 特殊标记
  uniqueMannerisms String[] @default([]) @map("unique_mannerisms") // 独特小动作/习惯
  voiceTone        String?  @map("voice_tone") @db.VarChar(100) // 语气特点

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("writing_character_personalities")
