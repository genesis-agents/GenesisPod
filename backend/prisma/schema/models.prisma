// ============ Session Latency Tracking 会话级时延跟踪 ============

model LatencySession {
  id     String @id @default(uuid())
  type   String @db.VarChar(100) // topic_insights_refresh, team_execution, etc.
  status String @db.VarChar(20) // running, completed, failed

  userId   String? @map("user_id")
  entityId String? @map("entity_id") // topicId, teamId, etc.

  // 时间
  startTime  DateTime  @map("start_time")
  endTime    DateTime? @map("end_time")
