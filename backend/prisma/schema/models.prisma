// ==================== Research Optimization Models ====================
// Phase 2 & 3 优化方案新增模型

/// 可信度报告 (Phase 2.1)
/// 记录报告的可信度评估结果
model CredibilityReport {
  id       String @id @default(cuid())
  reportId String @unique @map("report_id")

  // ========== 整体评分 ==========
  overallScore Float @map("overall_score") // 0-100

  // ========== 分项评分 ==========
  authorityScore  Float @map("authority_score") // 权威性评分
  diversityScore  Float @map("diversity_score") // 来源多样性评分
  timelinessScore Float @map("timeliness_score") // 时效性评分
  coverageScore   Float @map("coverage_score") // 覆盖度评分

  // ========== 详细数据 (JSON) ==========
  sourceBreakdown  Json @map("source_breakdown") // { government, academic, industry, news, blog }
  timeBreakdown    Json @map("time_breakdown") // { within1Month, within3Months, older }
  coverageDetails  Json @map("coverage_details") // { dimensionId: { count, target, status } }
  aiQualityMetrics Json @map("ai_quality_metrics") // { planningRounds, revisionAvg, approvalRate }

  // ========== AI 评审结果 (10 维) ==========
  aiEvaluation  Json?   @map("ai_evaluation") // 10 维评审结果 { dimensions: [...], overallScore, feedback }
  combinedScore Float?  @map("combined_score") // 综合评分 (来源可信度 ×0.4 + AI评审 ×0.6)
  combinedGrade String? @map("combined_grade") @db.VarChar(2) // A/B/C/D/F
  summaryText   String? @map("summary_text") // 一句话总评

  // ========== 局限性声明 ==========
  limitations String[] // 局限性列表

  // ========== 时间戳 ==========
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ========== 关系 ==========
  report TopicReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("credibility_reports")
}

/// 维度新鲜度检测 (Phase 3.1)
/// 记录每个维度的数据新鲜度评估
model DimensionFreshness {
  id          String @id @default(cuid())
  topicId     String @map("topic_id")
  dimensionId String @unique @map("dimension_id")

  // ========== 新鲜度指标 ==========
  lastAnalyzedAt      DateTime @map("last_analyzed_at")
  sourcesCount        Int      @map("sources_count")
  newSourcesCount     Int      @map("new_sources_count") // 新增来源数
