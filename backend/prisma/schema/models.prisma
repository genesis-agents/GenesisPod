/// TODO 任务类型
enum ResearchTodoType {
  LEADER_PLANNING // Leader 规划
  DIMENSION_RESEARCH // 维度研究
  REPORT_WRITING // 报告撰写
  QUALITY_REVIEW // 质量审核
