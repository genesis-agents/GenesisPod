  // ========== 时间戳 ==========
  createdAt DateTime @default(now()) @map("created_at")

  // ========== 关系 ==========
  mission ResearchMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  // ========== 索引 ==========
  @@index([missionId, type])
  @@index([createdAt(sort: Desc)])
  @@map("leader_decisions")
}

/// 报告修订历史
