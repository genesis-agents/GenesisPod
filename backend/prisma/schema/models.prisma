// Prisma Schema - Models
// Generator and datasource are defined in base.prisma

// ============ 用户相关 ============

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  username     String? @unique
  passwordHash String? @map("password_hash")

  // 角色权限
  role UserRole @default(USER)

  // OAuth
  oauthProvider String? @map("oauth_provider")
  oauthId       String? @map("oauth_id")

  // 订阅
  subscriptionTier      String    @default("free") @map("subscription_tier")
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")

  // 个人信息
  fullName  String? @map("full_name")
  avatarUrl String? @map("avatar_url")
  bio       String? @db.Text

  // 偏好设置
  preferences Json @default("{}")

  // 状态
  isActive   Boolean @default(true) @map("is_active")
  isVerified Boolean @default(false) @map("is_verified")

  // 时间戳
  createdAt   DateTime  @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")

  // 关系
  interests     UserInterest[]
  collections   Collection[]
  activities    UserActivity[]
  learningPaths LearningPath[]
  notes         Note[]
  comments      Comment[]
  reports       Report[]
  youtubeVideos YouTubeVideo[]
  workspaces    Workspace[]

  // AI Group 相关
  createdTopics    Topic[]                @relation("TopicCreator")
  topicMemberships TopicMember[]          @relation("TopicMemberships")
  topicMessages    TopicMessage[]         @relation("TopicMessageSender")
  topicReactions   TopicMessageReaction[] @relation("TopicReactionUser")
  addedAIMembers   TopicAIMember[]        @relation("TopicAIAdder")
  topicResources   TopicResource[]        @relation("TopicResourceAdder")
  topicSummaries   TopicSummary[]         @relation("TopicSummaryCreator")
  topicMentions    TopicMessageMention[]  @relation("TopicMentionUser")

  // AI Studio 研究项目
  researchProjects ResearchProject[]

  // AI Image 生成
  generatedImages GeneratedImage[]

  // AI Office 文档
  officeDocuments OfficeDocument[]

  // DeepDive Engine 品牌套件
  brandKits BrandKit[]

  // Team Mission 团队任务
  createdMissions TeamMission[] @relation("MissionCreator")

  // Agent Playground demo missions
  agentPlaygroundMissions AgentPlaygroundMission[]

  // ASK AI 会话
  askSessions AskSession[]

  // Topic 加入请求
  topicJoinRequests         TopicJoinRequest[] @relation("TopicJoinRequestUser")
  topicJoinRequestsReviewed TopicJoinRequest[] @relation("TopicJoinRequestReviewer")

  // 资源点赞
  resourceUpvotes ResourceUpvote[]

  // Notion 集成
  notionConnections NotionConnection[]

  // 统一导出系统
  exportJobs      ExportJob[]
  exportTemplates ExportTemplate[]

  // Google Drive 集成
  googleDriveConnection GoogleDriveConnection?

  // RAG 知识库
  knowledgeBases           KnowledgeBase[]
  knowledgeBaseMemberships KnowledgeBaseMember[]

  // 用户数据源连接 (用于知识库)
  userDataSources UserDataSource[]

  // 微信同步项目
  wechatItems WechatItem[]

  // 飞书同步项目
  feishuItems FeishuItem[]

  // 积分系统
  creditAccount CreditAccount?

  // Slides v3.0 会话
  slidesSessions       SlidesSession[]
  slidesTeamExecutions SlidesTeamExecution[]

  // Webhook 订阅
  webhooks WebhookSubscription[]

  // AI Slides v5.0 Team Orchestrator
  slidesMissions          SlidesMission[]          @relation("SlidesMissionUser")
  slidesTeamMemberConfigs SlidesTeamMemberConfig[] @relation("SlidesTeamMemberConfigUser")

  // AI Writing 长篇写作
  writingProjects       WritingProject[]       @relation("WritingProjectOwner")
  writingStyleTemplates WritingStyleTemplate[] @relation("WritingStyleTemplateOwner")

  // Topic Research 专题研究
  researchTopics     ResearchTopic[]     @relation("UserResearchTopics")
  topicCollaborators TopicCollaborator[] @relation("TopicCollaborators")
  topicInvitations   TopicCollaborator[] @relation("TopicInvitations")
  topicReviewedApps  TopicCollaborator[] @relation("TopicReviewer") // 审核的协作申请

  // 报告编辑相关
  reportChangesCheckedIn    ReportChange[]     @relation("ReportChangeCheckedInBy")
  reportAnnotationsCreated  ReportAnnotation[] @relation("ReportAnnotationCreator")
  reportAnnotationsResolved ReportAnnotation[] @relation("ReportAnnotationResolver")
  reviewTasksAssigned       ReviewTask[]       @relation("ReviewTaskAssignee") // 审核任务 (Phase 3.3)

  // 通知系统
  notifications          Notification[]          @relation("UserNotifications")
  notificationPreference NotificationPreference? @relation("UserNotificationPreference")

  // 团队邀请系统
  sentInvitations     TopicInvitation[] @relation("TopicInvitationInviter")
  receivedInvitations TopicInvitation[] @relation("TopicInvitationInvitee")

  // 反馈系统
  feedbackReplies   FeedbackReply[] @relation("FeedbackReplyUser")
  assignedFeedbacks Feedback[]      @relation("FeedbackAssignee")

  // 研究反馈闭环系统

  // AI Social 社交媒体发布
  socialPlatformConnections SocialPlatformConnection[]
  socialContents            SocialContent[]

  // 登录历史
  loginHistory LoginHistory[]

  // BYOK: 用户自有 API Key
  apiKeys UserApiKey[]

  // BYOK v2: 引导完成时间（为 null 说明新用户尚未走过引导）
  byokOnboardedAt DateTime? @map("byok_onboarded_at")

  // BYOK v2: 管理员分配给我的 Key
  keyAssignments KeyAssignment[]

  // BYOK v2: 我提交的 Key 申请工单
  keyRequests KeyRequest[]

  // BYOK v3: 我自己配置的多模型实例（同一个 Key 可以绑多个不同用途的模型）
  modelConfigs UserModelConfig[]

  // 2026-05-05 PR-1: 我自定义的 AIProvider（scope=user）
  customProviders AIProvider[] @relation("UserAIProviders")

  // 2026-05-11 P3: 我自定义的 ApiFormat / ModelType（scope=user）
  customApiFormats ApiFormat[] @relation("UserApiFormats")
  customModelTypes ModelType[] @relation("UserModelTypes")

  // 2026-05-05 E R4 Phase 2: 我自定义的 agent 定义
  customAgentDefinitions CustomAgentDefinition[]
  // 2026-05-05 R-CA: 我用 custom agent 启动过的 mission 映射
  customAgentLaunches    CustomAgentLaunch[]

  // 2026-05-08 YouTube 视频页 AI 聊天历史（user × videoId）
  youtubeAiChatMessages YouTubeAiChatMessage[]

  @@map("users")
}

// 用户登录历史记录
model LoginHistory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  loginAt   DateTime @default(now()) @map("login_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent") @db.Text
  device    String? // desktop, mobile, tablet
  browser   String? // Chrome, Firefox, Safari, etc.
  os        String? // Windows, macOS, Linux, iOS, Android
  location  String? // 城市/国家（可选，基于 IP）

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loginAt])
  @@map("login_history")
}

model UserInterest {
  id       String  @id @default(uuid())
  userId   String  @map("user_id")
  tag      String
  category String?
  weight   Decimal @default(1.0) @db.Decimal(5, 4)
  source   String  @default("manual")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tag])
  @@index([userId])
  @@index([tag])
  @@map("user_interests")
}

// ============ 资源相关 ============

enum ResourceType {
  PAPER
  BLOG
  REPORT
  YOUTUBE_VIDEO
  NEWS
  PROJECT
  EVENT
  RSS
  POLICY
}

enum WorkspaceStatus {
  ACTIVE
  ARCHIVED
}

enum TaskStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model Resource {
  id   String       @id @default(uuid())
  type ResourceType

  // 基础信息
  title        String  @db.VarChar(1000)
  abstract     String? @db.Text
  content      String? @db.Text
  sourceUrl    String  @map("source_url") @db.Text
  pdfUrl       String? @map("pdf_url") @db.Text
  thumbnailUrl String? @map("thumbnail_url") @db.Text
  codeUrl      String? @map("code_url") @db.Text

  // 作者/机构
  authors       Json?
  organizations Json?

  // 时间
  publishedAt DateTime? @map("published_at")

  // AI生成字段
  aiSummary       String? @map("ai_summary") @db.Text
  keyInsights     Json?   @map("key_insights")
  methodology     String? @db.Text // 研究方法/技术方案
  difficultyLevel Int?    @map("difficulty_level")
  prerequisites   Json?

  // 结构化AI摘要（新增，为前端最新版本组件提供支持）
  structuredAISummary Json? @map("structured_ai_summary")

  // 分类
  primaryCategory String? @map("primary_category")
  categories      Json?   @default("[]")
  tags            Json?   @default("[]")
  autoTags        Json?   @default("[]") @map("auto_tags")

  // 质量评分
  qualityScore  Decimal? @map("quality_score") @db.Decimal(5, 2)
  trendingScore Decimal? @map("trending_score") @db.Decimal(10, 2)

  // 统计
  viewCount    Int @default(0) @map("view_count")
  saveCount    Int @default(0) @map("save_count")
  upvoteCount  Int @default(0) @map("upvote_count")
  commentCount Int @default(0) @map("comment_count")

  // 元数据
  metadata Json? @default("{}")

  // 去重相关字段
  normalizedUrl      String? @map("normalized_url") @db.Text
  contentFingerprint String? @map("content_fingerprint") @db.VarChar(64)
  titleFingerprint   String? @map("title_fingerprint") @db.VarChar(32)

  // 质量评估字段
  sourceCredibility   Int? @map("source_credibility")
  contentCompleteness Int? @map("content_completeness")
  freshnessScore      Int? @map("freshness_score")

  // 技术洞察字段
  citationCount  Int?    @map("citation_count")
  influenceScore Int?    @map("influence_score")
  maturityStage  String? @map("maturity_stage") @db.VarChar(50)

  // RawData 关联（双向关系）
  rawDataId      String?  @unique @map("raw_data_id")
  primaryRawData RawData? @relation("PrimaryRawData", fields: [rawDataId], references: [id], onDelete: SetNull)

  // 向量引用
  embeddingId String? @map("embedding_id")

  // 链接健康检查
  linkHealth         String?   @default("UNKNOWN") @map("link_health") @db.VarChar(20) // HEALTHY, BROKEN, UNKNOWN
  lastHealthCheckAt  DateTime? @map("last_health_check_at")
  linkCheckFailCount Int       @default(0) @map("link_check_fail_count")

  // 数据采集相关（新增）
  sourceType       String?         @map("source_type") // arxiv, medium, youtube等
  externalId       String?         @map("external_id") // 外部系统ID
  collectionTaskId String?         @map("collection_task_id")
  collectionTask   CollectionTask? @relation(fields: [collectionTaskId], references: [id])

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  collectionItems    CollectionItem[]
  activities         UserActivity[]
  notes              Note[]
  comments           Comment[]
  workspaceResources WorkspaceResource[]
  translations       ResourceTranslation[]

  // AI Group 相关
  topicAttachments TopicMessageAttachment[] @relation("TopicAttachmentResource")
  topicResources   TopicResource[]          @relation("TopicSharedResource")

  // Raw data collection (replaces MongoDB) - 历史记录
  rawDataRecords RawData[] @relation("ResourceRawDataHistory")

  // AI Office 文档引用
  officeDocumentRefs OfficeDocumentResourceRef[]

  // 用户点赞
  upvotes ResourceUpvote[]

  @@index([type, publishedAt(sort: Desc)])
  @@index([qualityScore(sort: Desc)])
  @@index([trendingScore(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([sourceType, createdAt(sort: Desc)])
  @@index([externalId])
  @@index([collectionTaskId])
  @@index([normalizedUrl])
  @@index([contentFingerprint])
  @@index([titleFingerprint])
  @@index([linkHealth, lastHealthCheckAt])
  @@map("resources")
}

// Resource lifecycle event log — 不可变审计轨迹。
// 记录所有 link health / archival / hard-deletion 决策（带原因和操作来源），
// 即使原 Resource 被物理删除也保留快照，便于回溯。
model ResourceLifecycleEvent {
  id         String  @id @default(uuid())
  resourceId String  @map("resource_id") // 不加 FK，删除后保留事件
  // 删除时的快照（resource 已不存在时仍可看）
  sourceUrl  String? @map("source_url") @db.Text
  title      String? @db.VarChar(1000)
  type       String? @db.VarChar(50) // ResourceType 枚举值快照

  // HEALTH_CHECK_BROKEN | ARCHIVED | HARD_DELETED | RECOVERED | INGESTION_REJECTED
  action String @db.VarChar(40)

  // 触发原因（机器可读）—— oembed-400-malformed-id / oembed-401-private /
  // oembed-404-deleted / stale-30d / orphaned-broken-no-attachments / manual-cleanup 等
  reason String @db.VarChar(80)

  // SCHEDULER | MANUAL_SCRIPT | API_ADMIN | INGESTION_RSS
  actor String @db.VarChar(40)

  // 失败计数、HTTP 状态、批次 id 等附加上下文
  metadata Json? @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([resourceId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([reason, createdAt(sort: Desc)])
  @@map("resource_lifecycle_events")
}

// 用户对资源的点赞记录
model ResourceUpvote {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  resourceId String   @map("resource_id")
  createdAt  DateTime @default(now()) @map("created_at")

  // 关系
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  // 唯一约束：每个用户对每个资源只能点赞一次
  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
  @@map("resource_upvotes")
}

model ResourceTranslation {
  id         String  @id @default(uuid())
  resourceId String  @map("resource_id")
  language   String  @db.VarChar(10) // e.g., 'zh-CN'
  title      String? @db.Text
  content    String  @db.Text // The full translated text
  summary    String? @db.Text // Optional: translated summary

  // Translation metadata
  modelUsed  String? @map("model_used") @db.VarChar(50)
  tokensUsed Int?    @map("tokens_used")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, language])
  @@index([resourceId])
  @@map("resource_translations")
}

// ============ 收藏相关 ============

model Collection {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  name        String  @db.VarChar(200)
  description String? @db.Text
  icon        String? @db.VarChar(10) // Emoji icon
  color       String? @db.VarChar(20) // Hex color code
  isPublic    Boolean @default(false) @map("is_public")
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([userId])
  @@index([userId, sortOrder])
  @@map("collections")
}

model CollectionItem {
  id           String  @id @default(uuid())
  collectionId String  @map("collection_id")
  resourceId   String  @map("resource_id")
  note         String? @db.Text
  position     Int     @default(0)

  // Reading status tracking
  readStatus   ReadStatus @default(UNREAD) @map("read_status")
  readProgress Int        @default(0) @map("read_progress") // 0-100%
  lastReadAt   DateTime?  @map("last_read_at")

  // Personal tags (stored as JSON array)
  tags Json? @default("[]") // ["important", "to-read", "research"]

  addedAt DateTime @default(now()) @map("added_at")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  resource   Resource   @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([collectionId, resourceId])
  @@index([collectionId])
  @@index([collectionId, addedAt(sort: Desc)])
  @@index([collectionId, readStatus])
  @@index([resourceId])
  @@index([readStatus])
  @@map("collection_items")
}

enum ReadStatus {
  UNREAD
  READING
  COMPLETED
  ARCHIVED
}

// ============ 用户行为 ============

enum ActivityType {
  VIEW
  CLICK
  SAVE
  UNSAVE
  UPVOTE
  COMMENT
  SHARE
}

model UserActivity {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  resourceId   String       @map("resource_id")
  activityType ActivityType @map("activity_type")

  durationSeconds Int?     @map("duration_seconds")
  scrollDepth     Decimal? @map("scroll_depth") @db.Decimal(5, 2)
  metadata        Json?

  deviceType String? @map("device_type")
  userAgent  String? @map("user_agent") @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([resourceId])
  @@index([activityType])
  @@map("user_activities")
}

// ============ 学习路径 ============

enum LearningPathStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model LearningPath {
  id       String             @id @default(uuid())
  userId   String             @map("user_id")
  title    String             @db.VarChar(200)
  goal     String?            @db.Text
  status   LearningPathStatus @default(ACTIVE)
  progress Decimal            @default(0) @db.Decimal(5, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps LearningPathStep[]

  @@index([userId])
  @@map("learning_paths")
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model LearningPathStep {
  id        String     @id @default(uuid())
  pathId    String     @map("path_id")
  stepOrder Int        @map("step_order")
  conceptId String     @map("concept_id")
  resources Json?
  status    StepStatus @default(PENDING)

  completedAt DateTime? @map("completed_at")

  path LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@unique([pathId, stepOrder])
  @@index([pathId])
  @@map("learning_path_steps")
}

// ============ 笔记系统 ============

model Note {
  id         String  @id @default(uuid())
  userId     String  @map("user_id")
  resourceId String? @map("resource_id")

  // 笔记标题 (standalone notes)
  title String? @db.VarChar(500)

  // 笔记内容
  content String @db.Text

  // 笔记来源 (e.g., 'ai-chat', 'pdf', 'youtube')
  source String? @db.VarChar(50)

  // 高亮标注数据 (JSON)
  highlights Json? @default("[]")

  // AI解释和洞察
  aiInsights Json? @map("ai_insights")

  // 关联的知识图谱节点
  graphNodes Json? @default("[]") @map("graph_nodes")

  // 标签
  tags Json? @default("[]")

  // 是否公开
  isPublic Boolean @default(false) @map("is_public")

  // 是否收藏
  isBookmarked Boolean @default(false) @map("is_bookmarked")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource? @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceId])
  @@index([createdAt(sort: Desc)])
  @@map("notes")
}

// ============ 评论系统 ============

model Comment {
  id         String  @id @default(uuid())
  userId     String  @map("user_id")
  resourceId String? @map("resource_id")

  // 评论内容
  content String @db.Text

  // 评论来源 (e.g., 'youtube:VIDEO_ID', 'paper:PAPER_ID')
  source String? @db.VarChar(100)

  // 嵌套回复支持
  parentId String? @map("parent_id")

  // 统计
  upvoteCount Int @default(0) @map("upvote_count")
  replyCount  Int @default(0) @map("reply_count")

  // 状态
  isEdited  Boolean @default(false) @map("is_edited")
  isDeleted Boolean @default(false) @map("is_deleted")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource? @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([userId])
  @@index([resourceId])
  @@index([source])
  @@index([parentId])
  @@index([createdAt(sort: Desc)])
  @@map("comments")
}

// ============ 报告系统 ============

model Report {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // 报告基本信息
  title        String @db.VarChar(500)
  template     String @db.VarChar(50) // comparison, trend, learning-path, literature-review
  templateName String @map("template_name") @db.VarChar(100) // 对比分析, 趋势报告, etc.
  templateIcon String @map("template_icon") @db.VarChar(10) // 📊, 📈, etc.

  // 报告内容
  summary  String @db.Text // 核心摘要
  sections Json // [{ title: string, content: string }]

  // 关联的资源
  resourceIds   Json @map("resource_ids") // [resourceId1, resourceId2, ...]
  resourceCount Int  @map("resource_count")

  // AI生成元数据
  metadata    Json? // { model, tokensUsed, generationTime, ... }
  workspaceId String? @map("workspace_id")
  taskId      String? @map("task_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  task      WorkspaceTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([template])
  @@index([workspaceId])
  @@index([taskId])
  @@index([createdAt(sort: Desc)])
  @@map("reports")
}

model ReportTemplate {
  id           String   @id
  name         String
  category     String
  version      Int
  description  String?
  schema       Json
  promptConfig Json
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tasks WorkspaceTask[]

  @@map("report_templates")
}

model Workspace {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  status    WorkspaceStatus @default(ACTIVE)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  resources       WorkspaceResource[]
  tasks           WorkspaceTask[]
  reports         Report[]
  officeDocuments OfficeDocument[]

  @@index([userId])
  @@map("workspaces")
}

model WorkspaceResource {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  resourceId  String   @map("resource_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  resource  Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, resourceId])
  @@index([workspaceId])
  @@index([resourceId])
  @@map("workspace_resources")
}

model WorkspaceTask {
  id             String     @id @default(uuid())
  workspaceId    String     @map("workspace_id")
  templateId     String     @map("template_id")
  externalTaskId String?    @unique @map("external_task_id")
  model          String
  status         TaskStatus @default(PENDING)
  queuePosition  Int?       @map("queue_position")
  estimatedTime  Int?       @map("estimated_time")
  startedAt      DateTime?  @map("started_at")
  finishedAt     DateTime?  @map("finished_at")
  parameters     Json?
  result         Json?
  error          Json?
  cost           Json?
  metadata       Json?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  template  ReportTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  reports   Report[]

  @@index([workspaceId])
  @@index([templateId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("workspace_tasks")
}

