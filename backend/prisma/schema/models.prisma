  vocabularyRichness Decimal @map("vocabulary_richness") @db.Decimal(3, 2) // 词汇丰富度
  sentenceVariety    Decimal @map("sentence_variety") @db.Decimal(3, 2) // 句式变化度
  expressionNovelty  Decimal @map("expression_novelty") @db.Decimal(3, 2) // 表达新颖度

  // 角色一致性评分
  characterConsistency Decimal @map("character_consistency") @db.Decimal(3, 2)
  dialogueAuthenticity Decimal @map("dialogue_authenticity") @db.Decimal(3, 2) // 对话真实度

  // 情节评分
  plotNovelty   Decimal @map("plot_novelty") @db.Decimal(3, 2) // 情节新颖度
  narrativeFlow Decimal @map("narrative_flow") @db.Decimal(3, 2) // 叙事流畅度

  // 史实/设定准确性
  settingAccuracy Decimal @map("setting_accuracy") @db.Decimal(3, 2)

  // 综合评分
  overallScore Decimal @map("overall_score") @db.Decimal(3, 2)

  // 问题列表
  issues Json @default("[]") // QualityIssue[]

  // 是否通过质量门禁
  passedGate   Boolean @default(false) @map("passed_gate")
  rewriteCount Int     @default(0) @map("rewrite_count") // 重写次数

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")

  @@index([projectId, chapterId])
  @@index([projectId, passedGate])
  @@index([overallScore])
  @@map("writing_quality_scores")
