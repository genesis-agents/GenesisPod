  URL_FANQIE // 番茄小说
  URL_OTHER // 其他网址
}

// 导入状态
enum ImportStatus {
  PENDING // 待处理
  PARSING // 解析中
  PREVIEWING // 预览中（等待用户确认）
  IMPORTING // 导入中
  POST_PROCESSING // 后处理中（一致性检查、提取）
  COMPLETED // 完成
  FAILED // 失败
}

// 章节导入记录
model ChapterImport {
