/// 证据类型枚举
enum EvidenceType {
  CITATION // 引用
  REFERENCE // 参考
  INSPIRATION // 灵感来源
  FACT // 事实
  QUOTE // 引述
}

/// 证据管理
/// 用于存储和管理研究证据、引用来源
model Evidence {
  id   String       @id @default(cuid())
  type EvidenceType

  // ========== 来源信息 ==========
  sourceUrl         String?   @map("source_url") @db.Text
  sourceTitle       String    @map("source_title") @db.VarChar(500)
  sourceAuthor      String?   @map("source_author") @db.VarChar(200)
  sourcePublishedAt DateTime? @map("source_published_at")
  sourceDomain      String?   @map("source_domain") @db.VarChar(200)
  sourcePublisher   String?   @map("source_publisher") @db.VarChar(200)

  // ========== 内容信息 ==========
  contentOriginal    String  @map("content_original") @db.Text
  contentSnippet     String? @map("content_snippet") @db.Text
  contentUsedPortion String? @map("content_used_portion") @db.Text

  // ========== 关联信息 ==========
  entityType String  @map("entity_type") @db.VarChar(50) // research_topic, writing_project, etc.
  entityId   String  @map("entity_id")
  location   String? @db.VarChar(200) // 在文档中的位置
  context    String? @db.Text // 使用上下文

  // ========== 质量评分 ==========
  relevanceScore   Float  @default(0.5) @map("relevance_score")
  credibilityScore Float? @map("credibility_score")
  citationCount    Int    @default(0) @map("citation_count")

  // ========== 元数据 ==========
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ========== 索引 ==========
  @@index([entityType, entityId])
  @@index([sourceUrl])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@index([entityId, credibilityScore]) // 证据排序优化
  @@map("engine_evidences")
}

/// 审查状态枚举
enum ReviewStatus {
