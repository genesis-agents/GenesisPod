// 角色关系
model CharacterRelationship {
  id          String           @id @default(uuid())
  characterId String           @map("character_id")
  character   WritingCharacter @relation("CharacterRelationships", fields: [characterId], references: [id], onDelete: Cascade)

  targetCharacterId String           @map("target_character_id")
  targetCharacter   WritingCharacter @relation("TargetCharacter", fields: [targetCharacterId], references: [id], onDelete: Cascade)

  relationshipType String  @map("relationship_type") @db.VarChar(50) // 父子、师徒、仇敌、恋人等
  description      String? @db.Text

  // 关系的起止章节
