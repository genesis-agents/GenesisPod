  // 语言风格
  speechStyle      String   @default("") @map("speech_style") @db.VarChar(200) // 说话风格描述
  commonPhrases    String[] @default([]) @map("common_phrases") // 常用词汇/口头禅
  forbiddenPhrases String[] @default([]) @map("forbidden_phrases") // 禁用词汇
  sentencePattern  String?  @map("sentence_pattern") @db.VarChar(200) // 句式特点

  // 行为模式
  thinkingStyle    String? @map("thinking_style") @db.VarChar(200) // 思维模式
  emotionPattern   String? @map("emotion_pattern") @db.VarChar(200) // 情绪反应模式
  decisionStyle    String? @map("decision_style") @db.VarChar(200) // 决策风格
  conflictBehavior String? @map("conflict_behavior") @db.VarChar(200) // 冲突时行为

