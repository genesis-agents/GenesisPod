  @@index([type, createdAt(sort: Desc)])
  @@index([entityId])
  @@index([userId])
  @@map("latency_sessions")
}

// ============ Topic Research 专题研究 ============

// ==================== Enums ====================

/// 研究专题类型
enum ResearchTopicType {
  MACRO // 宏观洞察：国家/行业/领域分析 (如"美国 AI 宏观洞察")
  TECHNOLOGY // 技术专项：技术深度分析 (如"空芯光纤技术洞察")
  COMPANY // 企业洞察：企业/初创分析 (如"OpenAI 企业洞察")
  EVENT // 事件洞察：基于新闻/线索深挖事件来龙去脉 (如"英伟达收购 Run:ai")
}

/// 研究专题状态
enum ResearchTopicStatus {
  DRAFT // 草稿：已创建但未开始研究
  ACTIVE // 活跃：正在使用，定期刷新
  PAUSED // 暂停：临时停止刷新
  ARCHIVED // 归档：不再使用
}

/// 刷新频率
enum RefreshFrequency {
  MANUAL // 手动刷新：用户主动触发
  DAILY // 每日刷新
  WEEKLY // 每周刷新
  BIWEEKLY // 双周刷新（每两周）
  MONTHLY // 每月刷新
}

/// 维度研究状态
enum DimensionStatus {
  PENDING // 待处理：维度已定义但未研究
  RESEARCHING // 研究中：正在执行研究任务
  COMPLETED // 已完成：研究完成
  FAILED // 失败：研究过程出错
}

/// 刷新日志状态
enum RefreshLogStatus {
  PENDING // 待处理：已计划但未开始
  RUNNING // 运行中：正在执行刷新
  COMPLETED // 已完成：刷新成功
  FAILED // 失败：刷新出错
  CANCELLED // 已取消：手动取消
}

// ==================== Core Models ====================

/// 研究专题主表
/// 存储专题的基本信息和配置
model ResearchTopic {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // ========== 基本信息 ==========
  name        String              @db.VarChar(200) // 专题名称，如"美国 AI 宏观洞察"
  description String?             @db.Text // 专题描述
  icon        String?             @db.VarChar(10) // Emoji 图标
  color       String?             @db.VarChar(20) // 十六进制颜色代码
  type        ResearchTopicType // 专题类型
  status      ResearchTopicStatus @default(DRAFT) // 专题状态
  visibility  TopicVisibility     @default(PRIVATE) // 可见性：私有/共享/公开
  language    String              @default("zh") @db.VarChar(10) // 报告语言：zh/en

  // ========== 类型特定配置 ==========
  // JSON 字段，根据 type 存储不同的配置
  // MACRO: { country, industry, domain, focusAreas }
  // TECHNOLOGY: { technology, maturityLevel, applicationAreas }
  // COMPANY: { companyName, companyType, industry, foundedYear }
  topicConfig Json @default("{}") @map("topic_config")

  // ========== 刷新设置 ==========
  refreshFrequency RefreshFrequency @default(MANUAL) @map("refresh_frequency") // 刷新频率
  lastRefreshAt    DateTime?        @map("last_refresh_at") // 上次刷新时间
  nextRefreshAt    DateTime?        @map("next_refresh_at") // 下次计划刷新时间

  // ========== AI Team 配置 ==========
  teamConfigId String? @map("team_config_id") // 未来扩展：用户自定义 AI Team

  // ========== 统计数据 ==========
  totalReports Int @default(0) @map("total_reports") // 生成的报告总数
  totalSources Int @default(0) @map("total_sources") // 收集的来源总数

  // 关联研究项目 ID 列表（从 AI 研究沉淀过来的项目）
  linkedResearchIds Json? @default("[]") @map("linked_research_ids")
  // JSON 结构: string[] - 关联的 Research Project ID 列表

  // ========== 时间戳 ==========
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ========== 关系 ==========
  user               User                    @relation("UserResearchTopics", fields: [userId], references: [id], onDelete: Cascade)
  dimensions         TopicDimension[]
  reports            TopicReport[]
  schedules          TopicSchedule[]
  refreshLogs        TopicRefreshLog[]
  missions           ResearchMission[] // Leader 驱动的研究任务
  collaborators      TopicCollaborator[] // 协作者列表
  teamMessages       ResearchTeamMessage[] // 团队互动消息
  agentActivities    ResearchAgentActivity[] // Agent 活动记录
  dimensionFreshness DimensionFreshness[] // 维度新鲜度 (Phase 3.1)
  researchHistories  ResearchHistory[] // 研究历史 (Phase 2.3)
  researchTodos      ResearchTodo[] // 研究 TODO 列表 (UX Enhancement)

  // ========== 索引 ==========
  @@index([userId, status]) // 按用户和状态查询
  @@index([userId, createdAt(sort: Desc)]) // 用户专题列表查询优化
  @@index([visibility]) // 公开专题查询
  @@index([type]) // 按类型过滤
  @@index([nextRefreshAt]) // 定时任务查询
  @@index([createdAt(sort: Desc)]) // 按创建时间排序
  @@map("research_topics")
}

/// 专题可见性
enum TopicVisibility {
  PRIVATE // 私有：仅所有者可见
  SHARED // 共享：所有者和协作者可见
  PUBLIC // 公开：所有人可见
}

/// 内容可见性（通用）
enum ContentVisibility {
  PRIVATE // 私有：仅所有者可见
  PUBLIC // 公开：所有人可见
}

/// 协作者角色
enum TopicCollaboratorRole {
  VIEWER // 只读
  EDITOR // 可编辑
  ADMIN // 管理员（可邀请/移除成员）
}

/// 协作者申请状态
enum CollaboratorStatus {
  PENDING // 待审核
  ACCEPTED // 已通过
  REJECTED // 已拒绝
}

/// 专题协作者
/// 用于实现专题的成员共享功能
model TopicCollaborator {
  id      String @id @default(uuid())
  topicId String @map("topic_id")
  userId  String @map("user_id")

  // 协作者角色
  role TopicCollaboratorRole @default(VIEWER)

  // 邀请信息
  invitedById String    @map("invited_by")
  invitedAt   DateTime  @default(now()) @map("invited_at")
  acceptedAt  DateTime? @map("accepted_at")

  // 申请状态（申请审核机制）
  status       CollaboratorStatus @default(PENDING)
  requestedAt  DateTime?          @map("requested_at") // 用户主动申请时间
  reviewedAt   DateTime?          @map("reviewed_at") // 审核时间
  reviewedById String?            @map("reviewed_by") // 审核人 ID
  rejectReason String?            @map("reject_reason") @db.Text // 拒绝原因

  // 状态
  isActive Boolean @default(true) @map("is_active")

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  topic      ResearchTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user       User          @relation("TopicCollaborators", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy  User          @relation("TopicInvitations", fields: [invitedById], references: [id], onDelete: Cascade)
  reviewedBy User?         @relation("TopicReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  // 索引
  @@unique([topicId, userId])
  @@index([userId])
  @@index([topicId, isActive])
  @@index([topicId, status])
  @@map("research_topic_collaborators")
}

/// 专题维度定义
/// 每个专题由多个维度组成，如"政策法规"、"市场概览"等
model TopicDimension {
  id        String  @id @default(uuid())
  topicId   String  @map("topic_id")
  // ★ 每个 dim 归属到一次 mission（NULL = legacy/topic-template）。
  //   引入此字段是为了根治"重复任务"bug：原本 dim 只按 topicId 隔离，
  //   旧 mission 失败/卡死后残留的 dim 会被新 mission 一并拉走，
  //   产生重复 ResearchTask（参见 Screenshot_48 / 51）。
  //   现严格按 (topicId, missionId) 隔离，每个 mission 拥有独立 dim 集。
  missionId String? @map("mission_id")

  // ========== 维度信息 ==========
  name        String  @db.VarChar(200) // 维度名称，如"政策法规"
  description String? @db.Text // 维度描述
  sortOrder   Int     @default(0) @map("sort_order") // 排序顺序，数字越小越靠前
  isEnabled   Boolean @default(true) @map("is_enabled") // 是否启用

  // ========== 研究配置 ==========
  searchQueries Json? @map("search_queries") // 建议的搜索查询词
  searchSources Json? @map("search_sources") // 首选数据源
  minSources    Int   @default(5) @map("min_sources") // 最小来源数量要求

  // ========== 最新状态 ==========
  status           DimensionStatus @default(PENDING)
  lastResearchedAt DateTime?       @map("last_researched_at")

  // ========== 关系 ==========
  topic     ResearchTopic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  mission   ResearchMission?    @relation(fields: [missionId], references: [id], onDelete: SetNull)
  analyses  DimensionAnalysis[]
  freshness DimensionFreshness? // 新鲜度检测 (Phase 3.1)

  // ========== 索引 ==========
  @@index([topicId, sortOrder]) // 按专题和顺序查询
  @@index([topicId]) // 单独 topicId 查询（高频操作）
  @@index([status]) // 按状态过滤
  @@index([topicId, name]) // 按专题和名称查询
  @@index([missionId]) // 按 mission 反查 dim 列表
  @@index([topicId, missionId, isEnabled]) // 主查询路径：当前 mission 启用的 dim
  @@map("topic_dimensions")
}

/// 维度分析结果
/// 每次报告生成时，每个维度都会有一个对应的分析结果
model DimensionAnalysis {
  id          String @id @default(uuid())
  dimensionId String @map("dimension_id")
  reportId    String @map("report_id")

  // ========== 分析内容 ==========
  summary        String  @db.Text // 维度摘要（2-3 段文字，保留 DB——平均 <1KB）
  // summaryUri/summarySize 预留，当前 summary 全部都小于 2KB 未实际使用；
  // 真正的空间大头是 dataPoints，下方走 off-load。
  summaryUri     String? @map("summary_uri")
  summarySize    Int?    @map("summary_size")
  keyFindings    Json    @map("key_findings") // 关键发现（结构化）
  dataPoints     Json?   @map("data_points") // 数据点（图表）— avg 62KB，max 1.3MB
  // dataPoints off-load：非空表示 JSON 正文存在对象存储。key="dimension-analyses/{id}/data_points.json"
  dataPointsUri  String? @map("data_points_uri")
  dataPointsSize Int?    @map("data_points_size")

  // ========== 来源追踪 ==========
  sourcesUsed Int @default(0) @map("sources_used") // 使用的来源数量

  // ========== AI 元数据 ==========
  modelUsed  String? @map("model_used") // 使用的模型
  tokensUsed Int?    @map("tokens_used") // 消耗的 tokens

  // ========== 时间戳 ==========
  createdAt DateTime @default(now()) @map("created_at")

  // ========== 关系 ==========
  dimension TopicDimension  @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  report    TopicReport     @relation(fields: [reportId], references: [id], onDelete: Cascade)
  evidences TopicEvidence[]

  // ========== 索引 ==========
  @@index([dimensionId])
  @@index([reportId])
  @@index([reportId, dimensionId])
  @@map("dimension_analyses")
}

/// 研究报告（版本化）
/// 每次刷新生成一个新版本的报告
model TopicReport {
  id      String @id @default(uuid())
  topicId String @map("topic_id")

  // ========== 版本信息 ==========
  version      Int     @default(1) // 版本号，从 1 开始递增
  versionLabel String? @map("version_label") // 版本标签，如"2026-01 更新"

  // ========== 报告内容 ==========
  executiveSummary String  @map("executive_summary") @db.Text // 执行摘要（短文本，保留 DB）
  fullReport       String  @map("full_report") @db.Text // 完整报告（Markdown）
  // 正文外链：非空表示 fullReport 内容存在对象存储（B2/R2）。
  // 约定 key 格式："topic-reports/{reportId}/v{version}.md"
  // 读取时若此字段有值，优先从对象存储取内容；fullReport DB 字段置空字符串以回收 TOAST。
  fullReportUri    String? @map("full_report_uri") // e.g. "topic-reports/{id}/v1.md"
  fullReportSize   Int?    @map("full_report_size") // 正文原始字节数（用于列表展示 / 监控）
  highlights       Json    @default("[]") // 核心亮点（结构化）
  charts           Json    @default("[]") // 图表数据（结构化）

  // ========== 统计数据 ==========
  totalDimensions Int @default(0) @map("total_dimensions") // 研究的维度数量
  totalSources    Int @default(0) @map("total_sources") // 使用的来源总数
  totalTokens     Int @default(0) @map("total_tokens") // 消耗的总 tokens

  // ========== 生成元数据 ==========
  generatedAt      DateTime @default(now()) @map("generated_at")
  generationTimeMs Int?     @map("generation_time_ms") // 生成耗时（毫秒）

  // ========== 刷新追踪 ==========
  isIncremental   Boolean @default(false) @map("is_incremental") // 是否增量刷新
  changesFromPrev Json?   @map("changes_from_prev") // 与上一版本的变化摘要

  // ========== 质量追踪 ==========
  qualityTrace Json? @map("quality_trace") // 全链路质量追踪 (ReportQualityTrace JSONB)

  // ========== 关系 ==========
  topic             ResearchTopic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  dimensionAnalyses DimensionAnalysis[]
  evidences         TopicEvidence[]
  revisions         TopicReportRevision[] // 修订历史
  changes           ReportChange[] // 变更记录
  annotations       ReportAnnotation[] // 批注
  credibilityReport CredibilityReport? // 可信度报告 (Phase 2.1)
  reviewTasks       ReviewTask[] // 协作审核任务 (Phase 3.3)

  // ========== 唯一约束 ==========
  @@unique([topicId, version])
  // ========== 索引 ==========
  @@index([topicId, generatedAt(sort: Desc)]) // 按专题查询最新报告
  @@index([generatedAt(sort: Desc)]) // 按时间排序
  @@map("topic_reports")
}

/// 证据/引用
/// NotebookLM 风格的来源管理
model TopicEvidence {
  id         String  @id @default(uuid())
  reportId   String  @map("report_id")
  analysisId String? @map("analysis_id") // 可选：关联到特定维度分析

  // ========== 来源信息 ==========
  title       String  @db.VarChar(500) // 来源标题
  url         String  @db.Text // 来源 URL
  domain      String? @db.VarChar(200) // 域名
  snippet     String? @db.Text // 内容片段/摘要
  // 正文外链：非空表示 snippet 内容存在对象存储。key 格式："topic-evidences/{id}/snippet.txt"
  snippetUri  String? @map("snippet_uri")
  snippetSize Int?    @map("snippet_size")

  // ========== 元数据 ==========
  publishedAt DateTime? @map("published_at") // 发布时间
  accessedAt  DateTime  @default(now()) @map("accessed_at") // 访问/收集时间
  sourceType  String?   @map("source_type") // 来源类型

  // ========== 质量评估 ==========
  credibilityScore Int? @map("credibility_score") // 可信度评分 (0-100)

  // ========== 引用索引 ==========
  citationIndex Int? @map("citation_index") // 用于报告正文中的引用标记

  // ========== 关系 ==========
  report   TopicReport        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  analysis DimensionAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)

  // ========== 索引 ==========
  @@index([reportId])
  @@index([analysisId])
  @@index([sourceType])
  @@index([credibilityScore(sort: Desc)])
  @@map("topic_evidences")
}

// ==================== Refresh Scheduling ====================

/// 定时刷新配置
/// 管理专题的自动刷新计划
model TopicSchedule {
  id      String @id @default(uuid())
  topicId String @map("topic_id")

  // ========== 计划配置 ==========
  frequency RefreshFrequency // 刷新频率

  // 对于 WEEKLY：0-6 表示周日到周六
  dayOfWeek Int? @map("day_of_week")

  // 对于 MONTHLY：1-31 表示每月几号
  dayOfMonth Int? @map("day_of_month")

  // UTC 时间的小时数（0-23）
  hourOfDay Int @default(9) @map("hour_of_day")

  // ========== 状态 ==========
  isActive  Boolean   @default(true) @map("is_active") // 是否启用
  lastRunAt DateTime? @map("last_run_at") // 上次执行时间
  nextRunAt DateTime? @map("next_run_at") // 下次计划执行时间

  // ========== 关系 ==========
  topic ResearchTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // ========== 索引 ==========
  @@index([isActive, nextRunAt]) // 定时任务查询
  @@index([topicId])
  @@map("topic_schedules")
}

/// 刷新执行日志
/// 记录每次刷新的执行情况
model TopicRefreshLog {
  id      String @id @default(uuid())
  topicId String @map("topic_id")

  // ========== 执行信息 ==========
  triggerType String    @map("trigger_type") // manual, scheduled
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  // ========== 结果 ==========
  status   RefreshLogStatus @default(PENDING) // 执行状态
  reportId String?          @map("report_id") // 生成的报告 ID（如果成功）
  error    String?          @db.Text // 错误信息（如果失败）

  // ========== 统计 ==========
  dimensionsRefreshed Int? @map("dimensions_refreshed") // 刷新的维度数量
  sourcesFound        Int? @map("sources_found") // 发现的来源数量
  tokensUsed          Int? @map("tokens_used") // 消耗的 tokens

  // ========== 关系 ==========
  topic ResearchTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // ========== 索引 ==========
  @@index([topicId, startedAt(sort: Desc)]) // 按专题查询历史
  @@index([status])
  @@index([startedAt(sort: Desc)])
  @@map("topic_refresh_logs")
}

// ==================== Research Mission System ====================
// Leader 驱动的研究任务系统

/// 研究任务状态
enum ResearchMissionStatus {
  PLANNING // Leader 规划中
  PLAN_READY // 规划完成，等待用户审批
  EXECUTING // 执行中
  REVIEWING // Leader 审核中
  COMPLETED // 完成
  FAILED // 失败
  CANCELLED // 已取消
}

/// 研究任务状态
/// ★ SOTA v1 (30-sota-task-centric-architecture.md)：扩展为完整 FSM
enum ResearchTaskStatus {
  PENDING // 待分配（legacy，保留）
  ASSIGNED // 已分配（legacy，保留）
  EXECUTING // 执行中（legacy，保留）
  COMPLETED // 完成
  NEEDS_REVISION // 需要修订
  FAILED // 失败
  // ===== SOTA FSM 新增状态 =====
  CREATED // 新建但未进入 queue
  QUEUED // 已入 BullMQ queue
  SCHEDULED // 已被 worker 领取但未开始
  RUNNING // ReAct loop 正在执行
  PAUSED // 用户手动暂停
  AWAITING_HUMAN // 等待 HITL 干预
  VERIFYING // ReAct loop 完成后进入 judge 阶段
  CANCELLED // 用户取消
}

/// ★ SOTA v1: AgentStep 类型（ReAct loop 每步）
enum AgentStepType {
  OBSERVE
  THINK
  PLAN
  TOOL_CALL
  TOOL_RESULT
  REFLECT
  SELF_EVAL
  JUDGE_EVAL
  HUMAN_INPUT
  CHECKPOINT
  DONE
}

/// Leader 决策类型
enum LeaderDecisionType {
  PLAN // 初始规划
  REVIEW // 审核决策
  ADJUST // 调整策略
  INTERVENE // 用户干预响应
}

/// 研究 Mission
/// Leader 驱动的研究任务，包含规划、执行、审核全流程
model ResearchMission {
  id      String @id @default(uuid())
  topicId String @map("topic_id")

  // ========== Leader 信息 ==========
  leaderModelId   String? @map("leader_model_id") // 使用的推理模型 ID
  leaderModelName String? @map("leader_model_name") // 模型名称（如 claude-opus-4）

  // ========== 研究配置 ==========
  researchDepth String? @map("research_depth") // quick | standard | thorough

  // ========== 状态 ==========
  status ResearchMissionStatus @default(PLANNING)

  // ========== Leader 规划 ==========
  // 包含：任务理解、维度规划、Agent 分配策略、执行计划
  leaderPlan Json? @map("leader_plan")

  // ========== 用户输入 ==========
  userPrompt  String? @map("user_prompt") @db.Text // 用户的研究指令
  userContext Json?   @map("user_context") // 用户补充的上下文

  // ========== 进度统计 ==========
  totalTasks      Int @default(0) @map("total_tasks")
  completedTasks  Int @default(0) @map("completed_tasks")
  progressPercent Int @default(0) @map("progress_percent")

  // ========== 时间戳 ==========
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // ========== 关系 ==========
  topic      ResearchTopic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  tasks      ResearchTask[]
  decisions  LeaderDecision[]
  dimensions TopicDimension[]

  // ========== 索引 ==========
  @@index([topicId, status])
  @@index([topicId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("research_missions")
}

/// 研究任务
/// Leader 分配给各个 Agent 的具体任务
model ResearchTask {
  id        String @id @default(uuid())
  missionId String @map("mission_id")

  // ========== 任务信息 ==========
  title       String @db.VarChar(500) // 任务标题
  description String @db.Text // 任务描述
  taskType    String @map("task_type") // 任务类型：dimension_research, quality_review, report_synthesis

  // ========== 维度关联（可选）==========
  dimensionId   String? @map("dimension_id") // 关联的维度 ID（如果是维度研究任务）
  dimensionName String? @map("dimension_name") // Leader 定义的维度名称

  // ========== Agent 分配 ==========
  assignedAgent     String   @map("assigned_agent") // 分配的 Agent ID/名称
  assignedAgentType String?  @map("assigned_agent_type") // Agent 类型
  modelId           String?  @map("model_id") @db.VarChar(100) // ★ Agent 使用的 AI 模型 ID
  priority          Int      @default(0)
  skills            String[] @default([]) // Leader 分配的技能
  tools             String[] @default([]) // Leader 分配的工具

  // ========== 依赖关系 ==========
  dependencies String[] @default([]) // 依赖的任务 ID 列表

  // ========== 执行状态 ==========
  status      ResearchTaskStatus @default(PENDING)
  progress    Int                @default(0) // ★ 任务进度 0-100
  startedAt   DateTime?          @map("started_at")
  completedAt DateTime?          @map("completed_at")

  // ========== 任务结果 ==========
  result        Json? // 任务产出（JSON 格式）— avg 26KB/行，off-load 到对象存储
  // result off-load：非空表示 JSON 正文在 R2。key 格式："research-tasks/{id}/result.json"
  resultUri     String? @map("result_uri")
  resultSize    Int?    @map("result_size")
  resultSummary String? @map("result_summary") @db.Text // 结果摘要（短文本保留 DB）

  // ========== Leader 审核 ==========
  leaderReview  Json?   @map("leader_review") // Leader 审核意见
  reviewStatus  String? @map("review_status") // approved, needs_revision, rejected
  revisionCount Int     @default(0) @map("revision_count") // 修订次数

  // ========== 时间戳 ==========
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  queuedAt    DateTime? @map("queued_at") // ★ SOTA
  scheduledAt DateTime? @map("scheduled_at") // ★ SOTA
  pausedAt    DateTime? @map("paused_at") // ★ SOTA
  resumedAt   DateTime? @map("resumed_at") // ★ SOTA

  // ========== SOTA v1 (30-sota)：ReAct 执行状态 ==========
  currentIteration Int     @default(0) @map("current_iteration") // ReAct loop 当前迭代
  maxIterations    Int     @default(20) @map("max_iterations") // 硬上限（protocol 配置）
  lastCheckpointId String? @map("last_checkpoint_id") // 恢复锚点

  // retry + verification
  retryCount       Int     @default(0) @map("retry_count")
  maxRetries       Int     @default(2) @map("max_retries")
  requiresRevision Boolean @default(false) @map("requires_revision")

  // budget accounting
  tokenBudget Int?     @map("token_budget")
  tokensUsed  Int      @default(0) @map("tokens_used")
  costUsd     Decimal? @map("cost_usd") @db.Decimal(10, 6)
  latencyMs   Int      @default(0) @map("latency_ms")

  // parent-child（动态 spawn sub-task）
  parentTaskId String?        @map("parent_task_id")
  parent       ResearchTask?  @relation("TaskTree", fields: [parentTaskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     ResearchTask[] @relation("TaskTree")

  // ResultScore (0-100)
  resultScore Int? @map("result_score")

  // ========== 关系 ==========
  mission       ResearchMission      @relation(fields: [missionId], references: [id], onDelete: Cascade)
  steps         AgentStep[]
  checkpoints   TaskCheckpoint[]
  verifications VerificationRecord[]

  // ========== 索引 ==========
  @@index([missionId, status])
  @@index([assignedAgent])
  @@index([dimensionId])
  @@index([missionId, status, taskType]) // 任务查询优化
  @@index([status, scheduledAt]) // ★ SOTA: queue puller
  @@index([parentTaskId])
  @@map("research_tasks")
}

/// ★ SOTA v1: AgentStep — ReAct loop 每步细粒度记录
/// 替代 ResearchAgentActivity（后者保留为 legacy 展示副本）
model AgentStep {
  id        String @id @default(uuid())
  taskId    String @map("task_id")
  missionId String @map("mission_id")
  topicId   String @map("topic_id")

  iteration Int
  stepIndex Int           @map("step_index")
  stepType  AgentStepType @map("step_type")

  // LLM call 细节
  modelId          String?  @map("model_id") @db.VarChar(100)
  promptTokens     Int?     @map("prompt_tokens")
  completionTokens Int?     @map("completion_tokens")
  costUsd          Decimal? @map("cost_usd") @db.Decimal(10, 6)

  // tool call 细节
  toolName      String?  @map("tool_name") @db.VarChar(100)
  toolArgs      Json?    @map("tool_args")
  toolResult    Json?    @map("tool_result")
  toolLatencyMs Int?     @map("tool_latency_ms")
  toolSuccess   Boolean? @map("tool_success")

  // 内容（thought / plan / reflection）
  content        String? @db.Text
  structuredData Json?   @map("structured_data")

  // OTel 追踪
  traceId      String? @map("trace_id") @db.VarChar(64)
  spanId       String? @map("span_id") @db.VarChar(64)
  parentSpanId String? @map("parent_span_id") @db.VarChar(64)

  createdAt DateTime @default(now()) @map("created_at")

  task ResearchTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, iteration, stepIndex])
  @@index([missionId, createdAt])
  @@index([traceId])
  @@map("agent_steps")
}

/// ★ SOTA v1: TaskCheckpoint — ReAct loop 崩溃恢复锚点
model TaskCheckpoint {
  id        String @id @default(uuid())
  taskId    String @map("task_id")
  iteration Int
  stepIndex Int    @default(0) @map("step_index")

  // 恢复快照
  observations          Json // 历史观察
  reasoningMemory       Json @map("reasoning_memory") // scratchpad
  toolInvocationHistory Json @default("[]") @map("tool_invocation_history")
  budgetSnapshot        Json @map("budget_snapshot")

  status ResearchTaskStatus
  reason String?            @db.VarChar(200) // budget_exhausted / human_pause / crash_recovery / ...

  createdAt DateTime @default(now()) @map("created_at")

  task ResearchTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("task_checkpoints")
}

/// ★ SOTA v1: VerificationRecord — multi-judge 审核结果
model VerificationRecord {
  id        String @id @default(uuid())
  taskId    String @map("task_id")
  iteration Int

  judgeVerdicts Json    @map("judge_verdicts") // [{judgeId, score, critique, criteria}, ...]
  consensus     String  @db.VarChar(50) // pass / fail / escalate_to_meta / escalate_to_human
  decidedScore  Int     @map("decided_score")
  metaJudgeNote String? @map("meta_judge_note") @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  task ResearchTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("verification_records")
}

/// 研究记忆
/// 跨研究积累的关键发现，用于后续研究参考
model ResearchMemory {
  id        String @id @default(cuid())
  topicId   String @map("topic_id")
  missionId String @map("mission_id")

  // ========== 内容 ==========
  entity     String // 关键实体/概念
  finding    String @db.Text // 发现/洞察
  category   String // 类别：fact, trend, relationship, contradiction
  confidence Float  @default(0.8) // 置信度 0-1

  // ========== 来源追踪 ==========
  sourceDimension String?  @map("source_dimension") // 来源维度名称
  sourceUrls      String[] @map("source_urls") // 参考 URL 列表

  // ========== 元数据 ==========
  tags String[] // 标签

  // ========== 时间戳 ==========
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ========== 索引 ==========
  @@index([topicId])
  @@index([missionId])
  @@index([entity])
  @@index([category])
  @@index([tags])
  @@index([topicId, category])
  @@map("research_memories")
}

/// Leader 决策记录
/// 记录 Leader 在研究过程中的所有决策
model LeaderDecision {
  id        String @id @default(uuid())
  missionId String @map("mission_id")

  // ========== 决策信息 ==========
  type      LeaderDecisionType
  input     Json // 输入上下文（触发决策的信息）
  decision  Json // 决策内容
  reasoning String             @db.Text // 决策理由（可展示给用户）

  // ========== 元数据 ==========
  modelUsed  String? @map("model_used") // 使用的模型
  tokensUsed Int?    @map("tokens_used") // 消耗的 tokens
