  id        String         @id @default(uuid())
  chapterId String         @map("chapter_id")
  chapter   WritingChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  // 版本信息
  versionNumber Int                @map("version_number")
  content       String             @db.Text // 该版本的完整内容
  wordCount     Int                @default(0) @map("word_count")
  changeType    RevisionChangeType @map("change_type")
  changeSummary String?            @map("change_summary") @db.VarChar(500) // 修改说明
  changedBy     String             @map("changed_by") @db.VarChar(50) // 修改者: "user" | "ai_polish" | "ai_rewrite"

  // AI 修改时的元数据
  aiParams Json? @map("ai_params") // { operation, targetSection, userFeedback, etc. }

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([chapterId, versionNumber])
  @@index([chapterId])
  @@index([changeType])
  @@map("chapter_revisions")
}

// 批注类型
enum AnnotationType {
  COMMENT // 普通评论
  SUGGESTION // 修改建议
  ISSUE // 问题标记
  REFERENCE // 参考说明
}

// 批注状态
enum AnnotationStatus {
  OPEN // 待处理
  RESOLVED // 已解决
  DISMISSED // 已忽略
}

// 章节批注
model ChapterAnnotation {
  id        String         @id @default(uuid())
  chapterId String         @map("chapter_id")
  chapter   WritingChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  // 批注位置
  startOffset Int @map("start_offset") // 起始位置（字符偏移）
  endOffset   Int @map("end_offset") // 结束位置

  // 批注内容
  content      String           @db.Text
  type         AnnotationType   @default(COMMENT)
  status       AnnotationStatus @default(OPEN)
  selectedText String?          @map("selected_text") @db.Text // 被批注的原文

  // 时间戳
  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  @@index([chapterId])
  @@index([status])
  @@map("chapter_annotations")
}

// 导入来源
enum ImportSource {
  PASTE // 粘贴文本
  FILE_TXT // TXT 文件
  FILE_DOCX // Word 文档
  FILE_EPUB // EPUB 电子书
  FILE_MD // Markdown 文件
  URL_QIDIAN // 起点中文网
