// ============================================================================
// Data Management Module - Source Whitelist, Collection Rules, and Monitoring
// ============================================================================

enum ImportTaskStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
}

model SourceWhitelist {
  id           String @id @default(cuid())
  resourceType String // Store as string to avoid PostgreSQL enum type casting issues

  // 允许的域名或正则模式（存储为JSON数组）
  allowedDomains Json // Array<string> 支持完整域名或通配符 (e.g., ["arxiv.org", "*.ieee.org"])
  description    String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 字段用于跟踪验证统计
  totalValidated  Int       @default(0)
  totalRejected   Int       @default(0)
  lastValidatedAt DateTime?

  @@unique([resourceType])
  @@index([isActive])
  @@map("source_whitelist")
}

model CollectionRule {
  id           String @id @default(cuid())
  resourceType String // Store as string to avoid PostgreSQL enum type casting issues

  // 调度配置
  cronExpression String @default("0 */6 * * *") // 默认每6小时
  maxConcurrent  Int    @default(3) // 最大并发任务数
  timeout        Int    @default(300) // 超时时间（秒）

  // 采集过滤条件（存储为JSON）
  filters Json? // 包含 { keywords: string[], excludeKeywords: string[], domains: string[], etc. }

  // 去重策略
  deduplicationStrategy String @default("CONTENT_HASH") // CONTENT_HASH, URL_ONLY, TITLE_ONLY, CUSTOM

  // 质量评分配置
  minimumQualityScore Float @default(0.5) // 0-1 之间，低于此分数的数据将被过滤

  // 启用状态和优先级
  isActive Boolean @default(true)
  priority Int     @default(0) // 更高的值表示更高的优先级

  description     String?
  lastExecutedAt  DateTime?
  nextScheduledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关系
  importTasks ImportTask[]

  @@unique([resourceType])
  @@index([isActive])
  @@index([nextScheduledAt])
  @@map("collection_rules")
}

model ImportTask {
  id String @id @default(cuid())

  resourceType String // Store as string to avoid PostgreSQL enum type casting issues
  ruleId       String?
  rule         CollectionRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  // 源信息
  sourceUrl    String
  sourceDomain String? // 提取的域名，用于快速查询

  // 新增：关联到实际创建的资源
  resourceId    String? // 关联到实际资源 (Paper.id, Blog.id等)
  resourceModel String? // 资源类型表名 (papers, blogs等)

  // 新增：关联到ParsedMetadata
  parsedMetadataId String?
  parsedMetadata   ParsedMetadata? @relation(fields: [parsedMetadataId], references: [id], onDelete: SetNull)

  // 任务状态
  status       ImportTaskStatus @default(PENDING)
  statusReason String?

  // 处理统计
  itemsFound     Int @default(0)
  itemsProcessed Int @default(0)
  itemsSaved     Int @default(0)
  itemsRejected  Int @default(0) // 被过滤或去重的项目

  // 错误跟踪
  errorMessage String?
  errorDetails Json? // 详细的错误信息

  // 去重信息
  duplicatesFound      Int   @default(0)
  deduplicationDetails Json? // 去重的详细信息

  // 时间戳
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 性能指标
  executionTimeMs Int? // 执行时间（毫秒）

  // 元数据 - 存储用户编辑后的完整元数据
  metadata Json?

  @@index([resourceType])
  @@index([status])
  @@index([sourceDomain])
  @@index([resourceId])
  @@index([createdAt(sort: Desc)])
  @@index([completedAt])
  @@index([status, createdAt]) // 导入队列处理优化
  @@map("import_tasks")
}

// ============ 元数据提取与缓存 ============

model ParsedMetadata {
  id String @id @default(cuid())

  // URL信息
  sourceUrl String @unique // 唯一的源URL
  domain    String // 提取的域名，用于快速查询

  // 页面元数据
  title         String // HTML <title> 或 Open Graph title
  description   String?   @db.Text // 页面描述
  imageUrl      String? // Open Graph image URL
  authors       Json? // 作者列表 (string[])
  publishedDate DateTime? // 发布日期

  // 页面信息
  language     String  @default("en") // 页面语言代码 (en, zh, ja等)
  contentType  String  @default("html") // html, pdf, video等
  siteName     String? // 网站名称
  canonicalUrl String? // 规范URL
  favicon      String? // 网站favicon URL
  wordCount    Int? // 文章字数（仅适用于文本内容）

  // 内容识别
  contentHash String? // SHA256 hash for duplicate detection

  // 解析元数据
  parseError   String? // 解析错误消息
  parseSuccess Boolean @default(true)

  // 缓存管理
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime? @default(dbgenerated("(now() + interval '7 days')")) // 7天过期

  // 关系
  importTasks ImportTask[]

  @@index([domain])
  @@index([sourceUrl])
  @@index([expiresAt])
  @@map("parsed_metadata")
}

model DataQualityMetric {
  id String @id @default(cuid())

  // 关联的资源
  resourceType String // Store as string to avoid PostgreSQL enum type casting issues
  resourceId   String // 实际资源ID (paper.id, project.id, news.id, etc.)
  sourceUrl    String? // 原始来源URL

  // 质量评分（0-100）
  qualityScore      Float @default(0)
  completenessScore Float @default(0) // 完整性评分
  relevanceScore    Float @default(0) // 相关性评分

  // 去重信息
  duplicateScore       Float   @default(0) // 相似度 (0 = 完全不同, 100 = 重复)
  potentialDuplicateOf String? // 指向可能的重复项
  isDuplicate          Boolean @default(false)

  // 问题标记
  issues Json? // Array of { type: string, severity: 'LOW'|'MEDIUM'|'HIGH', message: string }

  // 标签和分类
  tags     String[]
  category String?

  // 审核状态
  reviewStatus String    @default("PENDING") // PENDING, APPROVED, REJECTED, NEEDS_REVIEW
  reviewedBy   String?
  reviewNote   String?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([resourceType, resourceId])
  @@index([resourceType])
  @@index([isDuplicate])
  @@index([qualityScore])
  @@index([reviewStatus])
  @@map("data_quality_metrics")
}

model CollectionStatistics {
  id String @id @default(cuid())

  resourceType String // Store as string to avoid PostgreSQL enum type casting issues

  // 统计数据
  totalItems      Int @default(0)
  totalCollected  Int @default(0)
  totalSuccessful Int @default(0)
  totalFailed     Int @default(0)
  totalDuplicates Int @default(0)
  totalRejected   Int @default(0)

  // 质量统计
  averageQualityScore        Float @default(0)
  itemsAboveQualityThreshold Int   @default(0)
  itemsBelowQualityThreshold Int   @default(0)

  // 时间统计
  lastCollectionAt            DateTime?
  nextScheduledAt             DateTime?
  averageCollectionDurationMs Int? // 平均采集耗时

  // 成功率
  successRate Float @default(0)

  // 时间段统计
  period String? // DAY, WEEK, MONTH (用于时间序列分析)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([resourceType])
  @@index([period])
  @@map("collection_statistics")
}

// ============================================================================
// Collection Configuration - 专业采集器配置
// ============================================================================

model CollectionConfiguration {
  id String @id @default(cuid())

  resourceType String  @db.VarChar(255) // Store as string to avoid PostgreSQL enum type casting issues
  name         String  @db.VarChar(255)
  description  String? @db.Text

  // 关键词和过滤
  keywords        Json? // Array<string> - 包含关键词
  excludeKeywords Json? // Array<string> - 排除关键词
  urlPatterns     Json? // Array<string> - URL匹配模式，支持*通配符

  // 采集调度
  cronExpression String @default("0 */6 * * *") // Cron表达式
  maxConcurrent  Int    @default(3) // 最大并发
  timeout        Int    @default(300) // 超时时间（秒）

  // 状态
  isActive Boolean @default(true)

  // 统计
  totalCollected  Int       @default(0)
  lastCollectedAt DateTime?

  // 时间戳
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([resourceType, name])
  @@index([resourceType])
  @@index([isActive])
  @@map("collection_configurations")
}

// ============================================================================
// Enhanced Data Collection System - 增强的数据采集系统
// ============================================================================

// 数据源配置表
enum DataSourceType {
  ARXIV
  PUBMED
  IEEE
  ACL_ANTHOLOGY
  MEDIUM
  DEVTO
  SUBSTACK
  HASHNODE
  YOUTUBE
  BILIBILI
  HACKERNEWS
  TECHCRUNCH
  THE_VERGE
  GITHUB
  PRODUCTHUNT
  POLICY_US
  POLICY_EU
  POLICY_CN
  GARTNER
  MCKINSEY
  IDC
  CUSTOM
  RSS
}

enum DataSourceStatus {
  ACTIVE
  PAUSED
  FAILED
  MAINTENANCE
  DEPRECATED
}

model DataSource {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  type        DataSourceType
  category    ResourceType // 对应的资源类型

  // 连接配置
  baseUrl     String  @map("base_url")
  apiEndpoint String? @map("api_endpoint")
  authType    String? @map("auth_type") // NONE|API_KEY|OAUTH|COOKIE
  credentials String? @db.Text // 加密存储

  // 采集配置
  crawlerType   String @map("crawler_type") // API|SCRAPER|RSS
  crawlerConfig Json   @map("crawler_config") // {selectors, patterns}
  rateLimit     Int?   @map("rate_limit") // 每秒请求数

  // 内容过滤
  keywords        String[] // ["AI", "Machine Learning"]
  categories      String[] // ["cs.AI", "cs.LG"]
  languages       Json? // ["en", "zh"]
  minQualityScore Float    @default(0) @map("min_quality_score")

  // 去重配置
  deduplicationConfig Json? @map("deduplication_config") // {methods, thresholds}

  // 状态管理
  status           DataSourceStatus @default(ACTIVE)
  isVerified       Boolean          @default(false) @map("is_verified")
  lastTestedAt     DateTime?        @map("last_tested_at")
  lastSuccessAt    DateTime?        @map("last_success_at")
  lastErrorMessage String?          @map("last_error")

  // 统计信息
  totalCollected  Int   @default(0) @map("total_collected")
  totalSuccess    Int   @default(0) @map("total_success")
  totalFailed     Int   @default(0) @map("total_failed")
  totalDuplicates Int   @default(0) @map("total_duplicates")
  successRate     Float @default(0) @map("success_rate")
  averageQuality  Float @default(0) @map("average_quality")

  // 审计字段
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")

  // 关系
  tasks CollectionTask[]

  @@index([type, status])
  @@index([category, status])
  @@map("data_sources")
}

// 采集任务表（增强版）
enum CollectionTaskType {
  SCHEDULED
  MANUAL
  IMPORT
  RETRY
}

enum CollectionTaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  PAUSED
}

model CollectionTask {
  id          String             @id @default(uuid())
  name        String
  description String?
  type        CollectionTaskType

  // 数据源配置
  sourceId     String     @map("source_id")
  source       DataSource @relation(fields: [sourceId], references: [id])
  sourceConfig Json       @map("source_config") // {maxResults, category, dateRange}

  // 执行配置
  schedule       String? // Cron表达式
  priority       Int     @default(5) // 1-10
  maxConcurrency Int     @default(5) @map("max_concurrency")
  timeout        Int     @default(300) // 秒
  retryCount     Int     @default(3) @map("retry_count")

  // 去重配置
  deduplicationRules Json @map("deduplication_rules") // {methods, thresholds}

  // 执行状态
  status      CollectionTaskStatus @default(PENDING)
  progress    Float                @default(0) // 0-100
  currentStep String?              @map("current_step")

  // 统计信息
  totalItems     Int @default(0) @map("total_items")
  processedItems Int @default(0) @map("processed_items")
  successItems   Int @default(0) @map("success_items")
  failedItems    Int @default(0) @map("failed_items")
  duplicateItems Int @default(0) @map("duplicate_items")
  skippedItems   Int @default(0) @map("skipped_items")

  // 时间信息
  scheduledAt DateTime? @map("scheduled_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  nextRunAt   DateTime? @map("next_run_at")

  // 错误信息
  errorMessage String? @map("error_message") @db.Text
  errorStack   String? @map("error_stack") @db.Text
  warnings     Json? // ["warning1", "warning2"]

  // 结果数据
  resultSummary Json? @map("result_summary") // {avg_quality, sources, etc}
  logs          Json? // 日志摘要

  // 审计字段
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")

  // 关系
  resources            Resource[]
  deduplicationRecords DeduplicationRecord[]

  @@index([status, scheduledAt])
  @@index([sourceId, status])
  @@index([type, createdAt])
  @@map("collection_tasks")
}

// 去重记录表
enum DuplicateDecision {
  AUTO_SKIP // 自动跳过（高相似度）
  MANUAL_SKIP // 人工确认跳过
  MERGED // 合并资源
  FALSE_POSITIVE // 误判，实际不重复
  PENDING_REVIEW // 待人工审核
}

model DeduplicationRecord {
  id String @id @default(uuid())

  // 关联信息
  taskId        String?         @map("task_id")
  task          CollectionTask? @relation(fields: [taskId], references: [id])
  resourceId    String?         @map("resource_id") // 如果保留，指向保留的资源
  duplicateOfId String?         @map("duplicate_of_id") // 指向原始资源

  // 检测方式
  method     String // URL_HASH|TITLE_SIMILARITY|CONTENT_FINGERPRINT|AUTHOR_TIME
  similarity Float // 相似度 0-1
  confidence Float  @default(1.0) // 置信度

  // 去重依据
  urlHash            String? @map("url_hash")
  titleHash          String? @map("title_hash")
  contentFingerprint String? @map("content_fingerprint")
  authorTimeKey      String? @map("author_time_key")

  // 原始数据
  originalData Json  @map("original_data") // 被去重的原始数据（标题、URL等）
  comparedWith Json? @map("compared_with") // 比较的资源信息

  // 决策信息
  decision  DuplicateDecision
  isCorrect Boolean?          @map("is_correct") // 人工验证结果

  // 处理信息
  processedBy String?  @map("processed_by") // USER_ID or SYSTEM
  processedAt DateTime @default(now()) @map("processed_at")
  notes       String?

  // 审计
  createdAt DateTime @default(now()) @map("created_at")

  // 防止同一对资源被重复记录（同一任务内）
  @@unique([taskId, resourceId, duplicateOfId], name: "dedup_record_unique")
  @@index([urlHash])
  @@index([titleHash])
  @@index([contentFingerprint])
  @@index([resourceId])
  @@index([decision])
  @@index([taskId])
  @@map("deduplication_records")
}

// ============================================================================
// AI Group - 多人多AI协作社区
// ============================================================================

enum TopicType {
  PUBLIC
  PRIVATE
  ARCHIVED
}

enum TopicRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum MessageContentType {
  TEXT
  RICH_TEXT
  CODE
  IMAGE
  FILE
  SYSTEM
}

enum MentionType {
  USER
  AI
  ALL
  ALL_AI
}

// AI能力类型枚举
enum AICapability {
  TEXT_GENERATION // 文本生成
  CODE_GENERATION // 代码生成
  CODE_REVIEW // 代码审查
  IMAGE_GENERATION // 图片生成
  IMAGE_ANALYSIS // 图片分析
  WEB_SEARCH // 网络搜索
  URL_FETCH // URL抓取
  DOCUMENT_ANALYSIS // 文档分析
  REASONING // 深度推理
  MATH // 数学计算
  TRANSLATION // 翻译
  SUMMARIZATION // 摘要生成
}

// 消息转发目标类型
enum ForwardTargetType {
  TOPIC // 转发到其他Topic
  USER // 私信转发给用户
  EXTERNAL // 导出为文件
}

// 消息合并模式
enum MergeMode {
  SEPARATE // 保持原样，分别发送
  MERGED // 合并为一条消息
  SUMMARY // AI生成摘要后转发
}

enum AttachmentType {
  FILE
  IMAGE
  LINK
  RESOURCE
}

enum TopicResourceType {
  LINK
  FILE
  LIBRARY_RESOURCE
}

// ============ Team Mission Enums ============

enum AgentWorkStyle {
  AUTONOMOUS // 自主型：独立完成任务，主动汇报
  COLLABORATIVE // 协作型：频繁与其他Agent交流
  SUPPORTIVE // 支持型：主要协助其他Agent
  ANALYTICAL // 分析型：深度分析，谨慎输出
  CREATIVE // 创意型：发散思维，提供创新方案
}

enum MissionStatus {
  PENDING // 待开始
  PLANNING // 规划中（Leader正在分解任务）
  IN_PROGRESS // 执行中
  PAUSED // 已暂停（可恢复）
  REVIEW // 审核中（Leader整合结果）
  COMPLETED // 已完成
  FAILED // 失败
  CANCELLED // 已取消
}

enum TaskPriority {
  CRITICAL // 关键（阻塞其他任务）
  HIGH // 高优先级
  MEDIUM // 中等优先级
  LOW // 低优先级
}

enum TaskType {
  RESEARCH // 调研分析
  DESIGN // 设计规划
  IMPLEMENTATION // 执行实现
  REVIEW // 审查检验
  DOCUMENTATION // 文档编写
  COORDINATION // 协调沟通
  CREATIVE // 创意发想
  SYNTHESIS // 综合整理
}

enum AgentTaskStatus {
  PENDING // 待开始（等待依赖）
  IN_PROGRESS // 进行中
  BLOCKED // 被阻塞
  AWAITING_REVIEW // 等待Leader审核
  REVISION_NEEDED // 需要修改
  COMPLETED // 已完成
  CANCELLED // 已取消
}

enum MissionLogType {
  MISSION_CREATED // 任务创建
  MISSION_STARTED // 任务启动
  PLANNING_STARTED // 开始规划
  PLANNING_COMPLETED // 规划完成
  TASK_ASSIGNED // 任务分配
  TASK_STARTED // 任务开始
  TASK_PROGRESS // 任务进度更新
  TASK_COMPLETED // 任务完成
  TASK_FAILED // 任务失败
  TASK_REVISION // 任务修改
  AGENT_COLLABORATION // Agent协作
  AGENT_QUESTION // Agent提问
  LEADER_FEEDBACK // Leader反馈
  LEADER_DECISION // Leader决策
  RESULT_INTEGRATION // 结果整合
  MISSION_COMPLETED // 任务完成
  MISSION_FAILED // 任务失败
}

// Topic 群组
model Topic {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(200)
  description String?   @db.Text
  type        TopicType @default(PRIVATE)
  avatar      String?   @db.Text

  createdById String @map("created_by_id")
  createdBy   User   @relation("TopicCreator", fields: [createdById], references: [id], onDelete: Cascade)

  settings Json? // 群组设置
  metadata Json? // 扩展元数据

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  archivedAt DateTime? @map("archived_at")

  members        TopicMember[]
  aiMembers      TopicAIMember[]
  messages       TopicMessage[]
  resources      TopicResource[]
  summaries      TopicSummary[]
  missions       TeamMission[]
  joinRequests   TopicJoinRequest[]
  knowledgeBases TopicKnowledgeBase[] // 关联的知识库
  voteProposals  VoteProposal[] // 投票提案
  invitations    TopicInvitation[] // 邀请列表

  @@index([createdById])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@map("topics")
}

// Topic 成员
model TopicMember {
  id String @id @default(uuid())

  topicId String @map("topic_id")
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation("TopicMemberships", fields: [userId], references: [id], onDelete: Cascade)

  role     TopicRole @default(MEMBER)
  nickname String?   @db.VarChar(100) // 群昵称

  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastReadAt DateTime? @map("last_read_at")

  @@unique([topicId, userId])
  @@index([topicId])
  @@index([userId])
  @@map("topic_members")
}

// Topic AI成员
model TopicAIMember {
  id String @id @default(uuid())

  topicId String @map("topic_id")
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  aiModel         String  @map("ai_model") @db.VarChar(50) // grok, gpt-4, claude, gemini
  displayName     String  @map("display_name") @db.VarChar(100) // 显示名称，如 "AI-Grok"
  avatar          String? @db.Text
  roleDescription String? @map("role_description") @db.VarChar(200) // 角色描述，如 "技术专家"

  systemPrompt  String? @map("system_prompt") @db.Text // 系统提示词
  contextWindow Int     @default(20) @map("context_window") // 上下文消息数
  responseStyle String? @map("response_style") @db.VarChar(50) // concise, detailed, academic
  autoRespond   Boolean @default(false) @map("auto_respond") // 是否自动参与

  // AI能力配置（新增）
  capabilities       AICapability[] // AI能力列表
  canMentionOtherAI  Boolean        @default(false) @map("can_mention_other_ai") // 是否可以@其他AI
  collaborationStyle String?        @map("collaboration_style") @db.VarChar(50) // independent, collaborative, supportive

  // 团队角色配置
  agentName      String?         @map("agent_name") @db.VarChar(100) // Agent名称（如"架构师张三"）
  agentIdentity  String?         @map("agent_identity") @db.VarChar(500) // 身份描述
  isLeader       Boolean         @default(false) @map("is_leader") // 是否为团队Leader
  expertiseAreas String[]        @default([]) @map("expertise_areas") // 擅长领域列表
  workStyle      AgentWorkStyle? @map("work_style") // 工作风格

  addedById String @map("added_by_id")
  addedBy   User   @relation("TopicAIAdder", fields: [addedById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages      TopicMessage[]
  mentions      TopicMessageMention[]
  ledMissions   TeamMission[]         @relation("MissionLeader")
  assignedTasks AgentTask[]           @relation("TaskAssignee")

  // 投票系统关系
  initiatedProposals VoteProposal[] @relation("ProposalInitiator")
  voteRecords        VoteRecord[]   @relation("VoteRecordVoter")

  @@unique([topicId, aiModel, displayName])
  @@index([topicId])
  @@index([isLeader])
  @@map("topic_ai_members")
}

// Topic 消息
model TopicMessage {
  id String @id @default(uuid())

  topicId String @map("topic_id")
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // 发送者（人或AI）
  senderId   String?        @map("sender_id") // 如果是人
  sender     User?          @relation("TopicMessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  aiMemberId String?        @map("ai_member_id") // 如果是AI
  aiMember   TopicAIMember? @relation(fields: [aiMemberId], references: [id], onDelete: SetNull)

  content     String             @db.Text
  contentType MessageContentType @default(TEXT) @map("content_type")

  // AI消息特有
  prompt     String? @db.Text // AI收到的Prompt（透明化）
  modelUsed  String? @map("model_used") @db.VarChar(50) // 实际使用的模型
  tokensUsed Int?    @map("tokens_used") // Token消耗

  // 回复/引用
  replyToId String?        @map("reply_to_id")
  replyTo   TopicMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   TopicMessage[] @relation("MessageReplies")

  // 关系
  mentions        TopicMessageMention[]
  attachments     TopicMessageAttachment[]
  reactions       TopicMessageReaction[]
  sourceResources TopicResource[]          @relation("TopicResourceSource")
  embedding       TopicMessageEmbedding? // 长文上下文检索用

  // 解析的 URL 内容（用于 AI 上下文增强）
  parsedUrls Json? @map("parsed_urls") // ParsedUrl[] - 检测到的 URL 及其解析结果

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([topicId, createdAt(sort: Desc)])
  @@index([senderId])
  @@index([aiMemberId])
  @@map("topic_messages")
}

// Topic 消息嵌入（用于长文上下文检索）
// 存储消息的向量嵌入，支持语义相似度搜索
model TopicMessageEmbedding {
  id        String       @id @default(uuid())
  messageId String       @unique @map("message_id")
  message   TopicMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // 向量数据 - JSONB 存储（Railway PostgreSQL 不支持 pgvector 扩展）
  // 相似度搜索在应用层计算余弦距离
  embedding  Json
  model      String @default("text-embedding-3-small") @db.VarChar(100)
  dimensions Int    @default(1536)

  // 内容摘要（用于快速预览）
  contentSummary String? @map("content_summary") @db.Text

  // 元数据
  tokenCount Int? @map("token_count") // 原始内容的 token 数

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([messageId])
  @@map("topic_message_embeddings")
}

// 消息@提及
model TopicMessageMention {
  id String @id @default(uuid())

  messageId String       @map("message_id")
  message   TopicMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // 被@的对象
  userId      String?        @map("user_id")
  user        User?          @relation("TopicMentionUser", fields: [userId], references: [id], onDelete: Cascade)
  aiMemberId  String?        @map("ai_member_id")
  aiMember    TopicAIMember? @relation(fields: [aiMemberId], references: [id], onDelete: Cascade)
  mentionType MentionType    @map("mention_type") // USER, AI, ALL, ALL_AI

  @@index([messageId])
  @@index([userId])
  @@index([aiMemberId])
  @@map("topic_message_mentions")
}

// 消息附件
model TopicMessageAttachment {
  id String @id @default(uuid())

  messageId String       @map("message_id")
  message   TopicMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  type     AttachmentType
  name     String         @db.VarChar(500)
  url      String         @db.Text
  size     Int? // bytes
  mimeType String?        @map("mime_type") @db.VarChar(100)

  // 如果是从Library导入的资源
  resourceId String?   @map("resource_id")
  resource   Resource? @relation("TopicAttachmentResource", fields: [resourceId], references: [id], onDelete: SetNull)

  // 链接预览数据
  linkPreview Json? @map("link_preview") // { title, description, image, favicon }

  createdAt DateTime @default(now()) @map("created_at")

  @@index([messageId])
  @@map("topic_message_attachments")
}

// 消息反应
model TopicMessageReaction {
  id String @id @default(uuid())

  messageId String       @map("message_id")
  message   TopicMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation("TopicReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  emoji String @db.VarChar(20) // 表情符号

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("topic_message_reactions")
}

// Topic 共享资源
model TopicResource {
  id String @id @default(uuid())

  topicId String @map("topic_id")
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  type TopicResourceType
  name String            @db.VarChar(500)
  url  String?           @db.Text

  // 如果是从Library导入
  resourceId String?   @map("resource_id")
  resource   Resource? @relation("TopicSharedResource", fields: [resourceId], references: [id], onDelete: SetNull)

  // 如果是上传的文件
  fileUrl  String? @map("file_url") @db.Text
  fileSize Int?    @map("file_size")
  mimeType String? @map("mime_type") @db.VarChar(100)

  // 来源消息（可追溯）
  sourceMessageId String?       @map("source_message_id")
  sourceMessage   TopicMessage? @relation("TopicResourceSource", fields: [sourceMessageId], references: [id], onDelete: SetNull)

  addedById String @map("added_by_id")
  addedBy   User   @relation("TopicResourceAdder", fields: [addedById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([topicId])
  @@index([type])
  @@map("topic_resources")
}

// Topic 讨论纪要
model TopicSummary {
  id String @id @default(uuid())

  topicId String @map("topic_id")
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  title   String @db.VarChar(500)
  content String @db.Text

  // 纪要范围
  fromMessageId String? @map("from_message_id")
  toMessageId   String? @map("to_message_id")

  // 生成信息
  generatedBy String  @map("generated_by") @db.VarChar(50) // AI模型
  prompt      String? @db.Text

  createdById String @map("created_by_id")
  createdBy   User   @relation("TopicSummaryCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([topicId, createdAt(sort: Desc)])
  @@map("topic_summaries")
}

// 消息转发记录
model TopicMessageForward {
  id String @id @default(uuid())

  // 原始消息（支持多选）
  originalMessageIds String[] @map("original_message_ids") // 原始消息ID数组
  sourceTopicId      String   @map("source_topic_id") // 来源Topic

  // 转发目标
  targetType    ForwardTargetType @map("target_type")
  targetTopicId String?           @map("target_topic_id") // 目标Topic（如果是TOPIC类型）
  targetUserId  String?           @map("target_user_id") // 目标用户（如果是USER类型）

  // 转发配置
  mergeMode   MergeMode @default(SEPARATE) @map("merge_mode")
  forwardNote String?   @map("forward_note") @db.Text // 转发备注

  // 转发后生成的消息
  forwardedMessageId String? @map("forwarded_message_id") // 转发后创建的消息ID

  // 转发者
  forwardedById String   @map("forwarded_by_id")
  forwardedAt   DateTime @default(now()) @map("forwarded_at")

  @@index([sourceTopicId])
  @@index([targetTopicId])
  @@index([forwardedById])
  @@index([forwardedAt(sort: Desc)])
  @@map("topic_message_forwards")
}

// 消息收藏
model TopicMessageBookmark {
  id String @id @default(uuid())

  messageId String @map("message_id")
  userId    String @map("user_id")

  // 收藏分类
  category String? @db.VarChar(100) // 自定义分类
  note     String? @db.Text // 收藏备注
  tags     Json?   @default("[]") // 标签

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([messageId, userId])
  @@index([userId])
  @@index([category])
  @@map("topic_message_bookmarks")
}

// Topic 加入请求
model TopicJoinRequest {
  id String @id @default(uuid())

  topicId String @map("topic_id")
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation("TopicJoinRequestUser", fields: [userId], references: [id], onDelete: Cascade)

  status         JoinRequestStatus @default(PENDING)
  requestMessage String?           @map("request_message") @db.Text // 申请理由
  responseNote   String?           @map("response_note") @db.Text // 审核备注

  reviewedById String?   @map("reviewed_by_id")
  reviewedBy   User?     @relation("TopicJoinRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime? @map("reviewed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([topicId, userId, status])
  @@index([topicId])
  @@index([userId])
  @@index([status])
  @@map("topic_join_requests")
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ============ Team Mission System - AI团队协作 ============

// 团队任务
model TeamMission {
  id String @id @default(uuid())

  topicId String @map("topic_id")
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // 任务信息
  title        String   @db.VarChar(500)
  description  String   @db.Text
  objectives   String[] @default([]) // 任务目标列表
  constraints  String[] @default([]) // 约束条件
  deliverables String[] @default([]) // 期望交付物

  // 执行信息
  status   MissionStatus @default(PENDING)
  leaderId String        @map("leader_id")
  leader   TopicAIMember @relation("MissionLeader", fields: [leaderId], references: [id])

  // 任务分解（Leader生成的分解方案，JSON格式）
  taskBreakdown Json? @map("task_breakdown")

  // Mission Context Package (Leader 解析任务后生成的上下文，包含实体定义、约束等)
  contextPackage Json? @map("context_package")

  // 结构化输入（长内容处理）
  inputBackground  String? @map("input_background") @db.Text // 背景描述
  inputConstraints Json?   @map("input_constraints") // 约束列表 [{type, rule, severity}]
  inputEntities    Json?   @map("input_entities") // 实体定义 [{name, type, definition}]
  inputExamples    Json?   @map("input_examples") // 示例 [{title, content}]
  inputProcessed   Boolean @default(false) @map("input_processed") // 是否已处理
  inputSummary     String? @map("input_summary") @db.Text // 输入摘要（用于长内容）

  // 约束追踪
  mustConstraints      Json? @map("must_constraints") // 提取的硬约束
  constraintViolations Json? @map("constraint_violations") // 违规记录

  // 进度统计
  totalTasks      Int @default(0) @map("total_tasks")
  completedTasks  Int @default(0) @map("completed_tasks")
  progressPercent Int @default(0) @map("progress_percent")

  // Token 消耗统计
  totalTokensUsed Int @default(0) @map("total_tokens_used") // 任务累计消耗的 token 数

  // 时间线
  createdById String    @map("created_by_id")
  createdBy   User      @relation("MissionCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // 结果
  finalResult String? @map("final_result") @db.Text // 最终交付成果
  summary     String? @db.Text // 执行总结

  // 通知配置
  notificationEmail String? @map("notification_email") @db.VarChar(255) // 任务完成后通知的邮箱

  // 关系
  tasks AgentTask[]
  logs  MissionLog[]

  @@index([topicId, status])
  @@index([leaderId])
  @@index([createdById])
  @@index([createdAt(sort: Desc)])
  @@map("team_missions")
}

// Agent任务（子任务）
model AgentTask {
  id String @id @default(uuid())

  missionId String      @map("mission_id")
  mission   TeamMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  // 任务信息
  title       String       @db.VarChar(500)
  description String       @db.Text
  priority    TaskPriority @default(MEDIUM)
  taskType    TaskType     @map("task_type")

  // 分配信息
  assignedToId   String        @map("assigned_to_id")
  assignedTo     TopicAIMember @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedAt     DateTime      @default(now()) @map("assigned_at")
  assignedReason String?       @map("assigned_reason") @db.Text // 分配原因

  // 依赖关系（存储依赖的任务ID列表）
  dependsOnIds String[] @default([]) @map("depends_on_ids")

  // 执行状态
  status      AgentTaskStatus @default(PENDING)
  startedAt   DateTime?       @map("started_at")
  completedAt DateTime?       @map("completed_at")

  // 产出
  result          String? @db.Text // 任务产出内容
  resultMessageId String? @map("result_message_id") // 产出消息ID（关联到群聊消息）

  // Leader反馈
  leaderFeedback    String? @map("leader_feedback") @db.Text
  feedbackMessageId String? @map("feedback_message_id")
  needsRevision     Boolean @default(false) @map("needs_revision")
  revisionCount     Int     @default(0) @map("revision_count")
  maxRevisions      Int     @default(3) @map("max_revisions")

  // 审核追踪（长内容增强）
  reviewHistory        Json? @map("review_history") // 审核历史 [{time, result, feedback, confidence}]
  constraintViolations Json? @map("constraint_violations") // 约束违规 [{constraintId, text, position}]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([missionId, status])
  @@index([assignedToId])
  @@index([priority])
  @@map("agent_tasks")
}

// 任务执行日志
model MissionLog {
  id String @id @default(uuid())

  missionId String      @map("mission_id")
  mission   TeamMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  // 日志信息
  type      MissionLogType
  agentId   String?        @map("agent_id") // 相关Agent ID
  agentName String?        @map("agent_name") @db.VarChar(100) // Agent名称（快照）
  taskId    String?        @map("task_id") // 相关任务ID
  taskTitle String?        @map("task_title") @db.VarChar(500) // 任务标题（快照）
  content   String         @db.Text // 日志内容
  messageId String?        @map("message_id") // 关联的群聊消息ID
  metadata  Json? // 额外元数据

  createdAt DateTime @default(now()) @map("created_at")

  @@index([missionId, createdAt(sort: Desc)])
  @@index([agentId])
  @@index([taskId])
  @@map("mission_logs")
}

// ============ AI Teams - 投票提案系统 ============

enum VoteStrategy {
  MAJORITY // 简单多数 (>50%)
  SUPERMAJORITY // 超级多数 (>66%)
  UNANIMOUS // 全票通过 (100%)
}

enum ProposalStatus {
  OPEN // 开放投票中
  CLOSED // 已关闭
}

enum VoteValue {
  APPROVE // 赞成
  REJECT // 反对
  ABSTAIN // 弃权
}

// 投票提案
model VoteProposal {
  id String @id @default(cuid())

  topicId String @map("topic_id")
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  title       String @db.VarChar(500)
  description String @db.Text

  // 发起者 (AI成员)
  initiatorId String        @map("initiator_id")
  initiator   TopicAIMember @relation("ProposalInitiator", fields: [initiatorId], references: [id])

  // 投票配置
  strategy VoteStrategy   @default(MAJORITY)
  options  String[]       @default([]) // 自定义选项(可选)
  status   ProposalStatus @default(OPEN)

  // 时间
  createdAt DateTime  @default(now()) @map("created_at")
  closedAt  DateTime? @map("closed_at")

  // 结果
  decision String? @db.VarChar(100) // 最终决定 (APPROVE/REJECT/NO_CONSENSUS)
  summary  String? @db.Text // 投票总结

  // 关系
  votes VoteRecord[]

  @@index([topicId, status])
  @@index([initiatorId])
  @@index([createdAt(sort: Desc)])
  @@map("vote_proposals")
}

// 投票记录
model VoteRecord {
  id String @id @default(cuid())

  proposalId String       @map("proposal_id")
  proposal   VoteProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  // 投票者 (AI成员)
  voterId String        @map("voter_id")
  voter   TopicAIMember @relation("VoteRecordVoter", fields: [voterId], references: [id])

  // 投票内容
  value      VoteValue
  reason     String?   @db.Text // 投票理由
  confidence Float? // 信心度 (0-1)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([proposalId, voterId])
  @@index([proposalId])
  @@index([voterId])
  @@map("vote_records")
}

// ============ AI Studio - 研究项目 ============

enum ResearchProjectStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

// 研究类型
enum ResearchType {
  FAST // 快速研究 - 源管理 + 聊天
  DEEP // 深度研究 - 多轮迭代研究
}

model ResearchProject {
  id           String                @id @default(uuid())
  userId       String                @map("user_id")
  name         String                @db.VarChar(500)
  description  String?               @db.Text
  icon         String?               @db.VarChar(10) // Emoji icon
  color        String?               @db.VarChar(20) // Hex color code
  status       ResearchProjectStatus @default(ACTIVE)
  visibility   String                @default("PRIVATE") @db.VarChar(20)
  researchType ResearchType          @default(FAST) @map("research_type")

  // 项目统计
  sourceCount Int @default(0) @map("source_count")
  noteCount   Int @default(0) @map("note_count")
  chatCount   Int @default(0) @map("chat_count")

  // 时间戳
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastAccessAt DateTime? @map("last_access_at")

