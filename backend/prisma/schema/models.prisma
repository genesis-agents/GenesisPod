// 表达类型
enum ExpressionType {
  IDIOM // 成语
  METAPHOR // 比喻
  DESCRIPTION // 描写手法
  EMOTION // 情感表达
  ACTION // 动作描写
  DIALOGUE // 对话模式
  TRANSITION // 过渡语
  PLOT_PATTERN // 情节模式
  CHAPTER_OPENING // 章节开场模式（防止每章开场雷同）
  SCENE_STRUCTURE // 场景结构模式（防止场景安排重复）
  NARRATIVE_PACING // 叙事节奏模式（防止节奏单一）
}

// 表达记忆库 - 追踪已使用的表达，防止重复
model WritingExpressionMemory {
  id        String         @id @default(uuid())
  projectId String         @map("project_id")
  project   WritingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 表达信息
  expression     String         @db.VarChar(200) // 表达内容（如"心中一震"）
  expressionType ExpressionType @map("expression_type")
  category       String?        @db.VarChar(50) // 细分类别

  // 使用统计
  useCount              Int      @default(1) @map("use_count") // 使用次数
  lastUsedAt            DateTime @default(now()) @map("last_used_at") // 最后使用时间
  lastChapterId         String?  @map("last_chapter_id") // 最后使用的章节ID
  lastUsedChapterNumber Int?     @map("last_used_chapter_number") // ★ 最后使用的章节号（用于精确冷却计算）

  // 冷却控制 - ★ 改用章节数而非时间
  cooldownUntil        DateTime? @map("cooldown_until") // 冷却截止时间（已弃用，保留兼容）
  cooldownUntilChapter Int?      @map("cooldown_until_chapter") // ★ 冷却到哪一章（章节号）
  isCoolingDown        Boolean   @default(false) @map("is_cooling_down")

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, expression])
  @@index([projectId, expressionType])
  @@index([projectId, isCoolingDown])
  @@index([projectId, useCount(sort: Desc)])
  @@map("writing_expression_memories")
}

// 角色人格档案 - 深化角色语言和行为特征
model WritingCharacterPersonality {
  id          String           @id @default(uuid())
  characterId String           @unique @map("character_id")
