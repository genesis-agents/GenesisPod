// ============================================================================
// Knowledge Ontology v1 — P0 Data Layer + W-A Meta-Model
// 5 tables: OntologyObjectType / OntologyLinkType / OntologyObject / OntologyLink / OntologyEdit
// ============================================================================

/// 本体对象类型元模型：声明 typeKey 的规范定义与 JSON Schema 约束
model OntologyObjectType {
  id             String   @id @default(uuid())
  /// 可选话题作用域；为 null 时为全局共享类型
  topicId        String?  @map("topic_id")
  /// 类型键，如 "company" / "technology"，全局或话题内唯一
  key            String   @db.VarChar(64)
  /// 显示标签
  label          String   @db.VarChar(128)
  /// JSON Schema（object 型），约束该类型对象的 properties 字段
  propertySchema Json     @default("{}") @map("property_schema")
  /// 显示颜色 hex 或 CSS 颜色名，可选
  color          String?  @db.VarChar(32)
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([topicId, key])
  @@index([topicId])
  @@map("ontology_object_types")
}

/// 本体关系类型元模型：声明 linkTypeKey 的规范定义、方向及端点类型约束
model OntologyLinkType {
  id             String   @id @default(uuid())
  /// 可选话题作用域；为 null 时为全局共享类型
  topicId        String?  @map("topic_id")
  /// 关系键，如 "depends_on" / "part_of"，全局或话题内唯一
  key            String   @db.VarChar(64)
  /// 显示标签
  label          String   @db.VarChar(128)
  /// 允许的起始节点 typeKey（空字符串表示无约束）
  fromTypeKey    String   @default("") @map("from_type_key") @db.VarChar(64)
  /// 允许的终止节点 typeKey（空字符串表示无约束）
  toTypeKey      String   @default("") @map("to_type_key") @db.VarChar(64)
  /// true = 有向边（fromId→toId 有语义方向）；false = 无向关联
  directed       Boolean  @default(true)
  /// JSON Schema（object 型），约束该类型边的 properties 字段
  propertySchema Json     @default("{}") @map("property_schema")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([topicId, key])
  @@index([topicId])
  @@map("ontology_link_types")
}

/// 本体对象：知识图谱中的节点（概念、实体、技术等）
model OntologyObject {
  id         String   @id @default(uuid())
  topicId    String?  @map("topic_id")
  typeKey    String   @map("type_key") @db.VarChar(64)
  label      String   @db.VarChar(200)
  /// 别名列表 string[]
  aliases    Json     @default("[]")
  /// 扩展属性 {[key: string]: unknown}
  properties Json     @default("{}")
  confidence Float    @default(1.0)
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  outLinks OntologyLink[] @relation("LinkFrom")
  inLinks  OntologyLink[] @relation("LinkTo")
  edits    OntologyEdit[]

  @@unique([topicId, typeKey, label])
  @@index([topicId, typeKey])
  @@index([createdBy])
  @@map("ontology_objects")
}

/// 本体关系：知识图谱中的有向边
model OntologyLink {
  id          String   @id @default(uuid())
  topicId     String?  @map("topic_id")
  linkTypeKey String   @map("link_type_key") @db.VarChar(64)
  fromId      String   @map("from_id")
  toId        String   @map("to_id")
  from        OntologyObject @relation("LinkFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to          OntologyObject @relation("LinkTo",   fields: [toId],   references: [id], onDelete: Cascade)
  /// 边属性 {[key: string]: unknown}
  properties  Json     @default("{}")
  confidence  Float    @default(1.0)
  createdAt   DateTime @default(now()) @map("created_at")

  edits OntologyEdit[]

  @@unique([fromId, toId, linkTypeKey])
  @@index([fromId])
  @@index([toId])
  @@index([linkTypeKey])
  @@map("ontology_links")
}

/// 议题级本体自动摄入开关：控制 mission 完成后是否自动回写本体
/// topicId 使用 TEXT @id（非 uuid），与 TeamTopic.id 同类型，无 FK（跨数据库解耦）
model OntologyTopicSetting {
  /// 议题 ID，与 TeamTopic.id / ForesightTopic.id 对应
  topicId    String   @id @map("topic_id")
  /// 是否开启自动摄入（默认 false）
  autoIngest Boolean  @default(false) @map("auto_ingest")
  /// 最后修改人（userId），可选
  updatedBy  String?  @map("updated_by")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("ontology_topic_settings")
}

/// 本体编辑日志：对象/关系的所有变更审计轨迹
model OntologyEdit {
  id         String   @id @default(uuid())
  objectId   String?  @map("object_id")
  linkId     String?  @map("link_id")
  /// create | update | delete | merge | split
  action     String   @db.VarChar(32)
  /// human | agent | import | system
  actorType  String   @map("actor_type") @db.VarChar(32)
  actorId    String   @map("actor_id")
  before     Json?
  after      Json?
  reason     String?  @db.Text
  evidenceId String?  @map("evidence_id")
  createdAt  DateTime @default(now()) @map("created_at")

  object OntologyObject? @relation(fields: [objectId], references: [id], onDelete: SetNull)
  link   OntologyLink?   @relation(fields: [linkId],   references: [id], onDelete: SetNull)

  @@index([objectId])
  @@index([linkId])
  @@index([createdAt(sort: Desc)])
  @@map("ontology_edits")
}
