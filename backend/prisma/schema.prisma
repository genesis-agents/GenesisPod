  messageId String @map("message_id")
  userId    String @map("user_id")

  // 收藏分类
  category String? @db.VarChar(100) // 自定义分类
  note     String? @db.Text // 收藏备注
  tags     Json?   @default("[]") // 标签

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([messageId, userId])
  @@index([userId])
  @@index([category])
  @@map("topic_message_bookmarks")
}

// ============ Team Mission System - AI团队协作 ============

// 团队任务
model TeamMission {
  id String @id @default(uuid())

  topicId String @map("topic_id")
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // 任务信息
  title        String   @db.VarChar(500)
  description  String   @db.Text
  objectives   String[] @default([]) // 任务目标列表
  constraints  String[] @default([]) // 约束条件
  deliverables String[] @default([]) // 期望交付物

  // 执行信息
  status   MissionStatus @default(PENDING)
  leaderId String        @map("leader_id")
  leader   TopicAIMember @relation("MissionLeader", fields: [leaderId], references: [id])

  // 任务分解（Leader生成的分解方案，JSON格式）
  taskBreakdown Json? @map("task_breakdown")

  // 进度统计
  totalTasks      Int @default(0) @map("total_tasks")
  completedTasks  Int @default(0) @map("completed_tasks")
  progressPercent Int @default(0) @map("progress_percent")

  // 时间线
  createdById String    @map("created_by_id")
  createdBy   User      @relation("MissionCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // 结果
  finalResult String? @map("final_result") @db.Text // 最终交付成果
  summary     String? @db.Text // 执行总结

  // 关系
  tasks AgentTask[]
  logs  MissionLog[]

  @@index([topicId, status])
  @@index([leaderId])
  @@index([createdById])
  @@index([createdAt(sort: Desc)])
  @@map("team_missions")
}

// Agent任务（子任务）
model AgentTask {
  id String @id @default(uuid())

  missionId String      @map("mission_id")
  mission   TeamMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  // 任务信息
  title       String       @db.VarChar(500)
  description String       @db.Text
  priority    TaskPriority @default(MEDIUM)
  taskType    TaskType     @map("task_type")

  // 分配信息
  assignedToId   String        @map("assigned_to_id")
  assignedTo     TopicAIMember @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedAt     DateTime      @default(now()) @map("assigned_at")
  assignedReason String?       @map("assigned_reason") @db.Text // 分配原因

  // 依赖关系（存储依赖的任务ID列表）
  dependsOnIds String[] @default([]) @map("depends_on_ids")

  // 执行状态
  status      AgentTaskStatus @default(PENDING)
  startedAt   DateTime?       @map("started_at")
  completedAt DateTime?       @map("completed_at")

  // 产出
  result          String? @db.Text // 任务产出内容
  resultMessageId String? @map("result_message_id") // 产出消息ID（关联到群聊消息）

  // Leader反馈
  leaderFeedback    String? @map("leader_feedback") @db.Text
  feedbackMessageId String? @map("feedback_message_id")
  needsRevision     Boolean @default(false) @map("needs_revision")
  revisionCount     Int     @default(0) @map("revision_count")
  maxRevisions      Int     @default(3) @map("max_revisions")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([missionId, status])
  @@index([assignedToId])
  @@index([priority])
  @@map("agent_tasks")
}

// 任务执行日志
model MissionLog {
  id String @id @default(uuid())

  missionId String      @map("mission_id")
  mission   TeamMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  // 日志信息
  type      MissionLogType
  agentId   String?        @map("agent_id") // 相关Agent ID
  agentName String?        @map("agent_name") @db.VarChar(100) // Agent名称（快照）
  taskId    String?        @map("task_id") // 相关任务ID
  taskTitle String?        @map("task_title") @db.VarChar(500) // 任务标题（快照）
  content   String         @db.Text // 日志内容
  messageId String?        @map("message_id") // 关联的群聊消息ID
  metadata  Json? // 额外元数据

  createdAt DateTime @default(now()) @map("created_at")

  @@index([missionId, createdAt(sort: Desc)])
  @@index([agentId])
  @@index([taskId])
  @@map("mission_logs")
}

// ============ AI Studio - 研究项目 ============

enum ResearchProjectStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model ResearchProject {
  id          String                @id @default(uuid())
  userId      String                @map("user_id")
  name        String                @db.VarChar(500)
  description String?               @db.Text
  icon        String?               @db.VarChar(10) // Emoji icon
  color       String?               @db.VarChar(20) // Hex color code
  status      ResearchProjectStatus @default(ACTIVE)

  // 项目统计
  sourceCount Int @default(0) @map("source_count")
  noteCount   Int @default(0) @map("note_count")
  chatCount   Int @default(0) @map("chat_count")

  // 时间戳
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastAccessAt DateTime? @map("last_access_at")

  // 关系
  user    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources ResearchProjectSource[]
  notes   ResearchProjectNote[]
  chats   ResearchProjectChat[]
  outputs ResearchProjectOutput[]

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([lastAccessAt(sort: Desc)])
  @@map("research_projects")
}

// 项目资料来源
enum SourceAnalysisStatus {
  PENDING
  ANALYZING
  COMPLETED
  FAILED
}

model ResearchProjectSource {
  id        String @id @default(uuid())
  projectId String @map("project_id")

  // 资料信息
  title        String  @db.VarChar(1000)
  sourceType   String  @map("source_type") @db.VarChar(50) // paper, github, news, blog, video, file
  sourceUrl    String? @map("source_url") @db.Text
  thumbnailUrl String? @map("thumbnail_url") @db.Text

  // 资料内容
  abstract String? @db.Text
  content  String? @db.Text

  // 元数据
  authors     Json? // 作者列表
  publishedAt DateTime? @map("published_at")
  metadata    Json? // 其他元数据

  // AI 分析
  analysisStatus SourceAnalysisStatus @default(PENDING) @map("analysis_status")
  aiSummary      String?              @map("ai_summary") @db.Text
  keyInsights    Json?                @map("key_insights")

  // 关联的资源库资源（可选）
  resourceId String? @map("resource_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([sourceType])
  @@index([analysisStatus])
  @@map("research_project_sources")
}

// 项目笔记
model ResearchProjectNote {
  id        String @id @default(uuid())
  projectId String @map("project_id")

  title   String? @db.VarChar(500)
  content String  @db.Text

  // 来源（可能来自对话或手动创建）
  sourceType String? @map("source_type") @db.VarChar(50) // manual, ai-chat, generated
  chatId     String? @map("chat_id") // 关联的对话ID

  // 标签
  tags Json? @default("[]")

  // 是否固定
  isPinned Boolean @default(false) @map("is_pinned")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([isPinned])
  @@map("research_project_notes")
}

// 项目对话
model ResearchProjectChat {
  id        String @id @default(uuid())
  projectId String @map("project_id")

  // 对话消息 (JSON array)
  messages Json @default("[]")

  // 对话元数据
  title      String? @db.VarChar(500) // 对话标题（可自动生成）
  modelUsed  String? @map("model_used") @db.VarChar(50)
  tokensUsed Int?    @map("tokens_used")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project ResearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt(sort: Desc)])
  @@map("research_project_chats")
}

// 项目生成产出
enum OutputType {
  STUDY_GUIDE // 学习指南
  BRIEFING_DOC // 简报文档
  FAQ // 常见问题
  TIMELINE // 时间线
