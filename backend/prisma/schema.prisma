// ============ 系统设置 ============

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique @db.VarChar(100) // setting key, e.g., "search.provider"
  value String @db.Text // JSON-encoded value

  description String? @db.Text
  category    String  @default("general") @db.VarChar(50) // general, search, ai, etc.

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("system_settings")
}

// ============ AI模型配置 ============

// AI模型类型枚举
enum AIModelType {
  CHAT // 文本聊天模型 (GPT-4, Claude, Gemini Pro)
  IMAGE_GENERATION // 图片生成模型 (DALL-E 3, Imagen 4, Midjourney)
  IMAGE_EDITING // 图片编辑模型 (Imagen 3, DALL-E 2 edit)
  MULTIMODAL // 多模态模型 (Gemini 2.0 Flash - 同时支持文本和图片)
}

model AIModel {
  id          String @id @default(uuid())
  name        String @db.VarChar(50) // 内部名称 (grok, gpt-4, claude, gemini) - 不再唯一，允许同一provider多个模型
  displayName String @map("display_name") @db.VarChar(100)
  provider    String @db.VarChar(50) // xAI, OpenAI, Anthropic, Google
  modelId     String @unique @map("model_id") @db.VarChar(200) // 实际模型ID - 唯一约束

  // 模型类型 - 用于按业务需求选择合适的模型
  modelType AIModelType @default(CHAT) @map("model_type")

  // 显示设置
  icon  String @db.Text // emoji or icon URL path
  color String @db.VarChar(100) // Tailwind gradient class

  // API配置
  apiEndpoint String  @map("api_endpoint") @db.Text // API endpoint URL
  apiKey      String? @map("api_key") @db.Text // 加密存储的API Key

  // 模型参数
  maxTokens   Int   @default(4096) @map("max_tokens")
  temperature Float @default(0.7)

  // 状态
  isEnabled Boolean @default(true) @map("is_enabled")
  isDefault Boolean @default(false) @map("is_default") // 是否为该类型的默认模型

  description String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([modelType, isEnabled]) // 按类型快速查询启用的模型
  @@map("ai_models")
}

// ============================================================================
// Debate System - 基于业界最佳实践的多AI辩论系统
// 参考: AutoGen (Microsoft), MAD (Multi-Agents-Debate), DebateLLM
// ============================================================================

enum DebateStatus {
  PENDING // 等待开始
  ACTIVE // 进行中
  PAUSED // 暂停
  COMPLETED // 已完成
  CANCELLED // 已取消
}

enum DebateRole {
  RED // 红方/正方
  BLUE // 蓝方/反方
  JUDGE // 裁判
  OBSERVER // 观察者
}

// 辩论会话 - 每次辩论是独立的Session，与Topic消息历史隔离
model DebateSession {
  id String @id @default(uuid())

  // 关联Topic（辩论发生在哪个Topic）
  topicId String @map("topic_id")

  // 辩论主题
  topic       String  @db.VarChar(500)
  description String? @db.Text

  // 辩论状态
  status DebateStatus @default(PENDING)

  // 辩论配置
  maxRounds      Int @default(3) @map("max_rounds") // 最大轮次
  currentRound   Int @default(0) @map("current_round") // 当前轮次
  roundTimeoutMs Int @default(120000) @map("round_timeout_ms") // 每轮超时

  // 发起者
  initiatedById String   @map("initiated_by_id")
  initiatedAt   DateTime @default(now()) @map("initiated_at")

  // 结束信息
  completedAt DateTime? @map("completed_at")
  conclusion  String?   @db.Text // 辩论结论（可由Judge生成）
  winnerId    String?   @map("winner_id") // 获胜方Agent ID

  // 元数据
  metadata Json? // 扩展配置

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  agents   DebateAgent[]
  messages DebateMessage[]

  @@index([topicId])
  @@index([status])
  @@index([initiatedById])
  @@index([createdAt(sort: Desc)])
  @@map("debate_sessions")
}

// 辩论参与者 - 每个AI在辩论中的角色和独立历史
model DebateAgent {
  id String @id @default(uuid())

  // 关联辩论会话
  sessionId String        @map("session_id")
  session   DebateSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // 关联AI成员
  aiMemberId  String @map("ai_member_id")
  displayName String @map("display_name") @db.VarChar(100)
  aiModel     String @map("ai_model") @db.VarChar(50)

  // 辩论角色
  role DebateRole

  // 立场描述（系统生成或用户指定）
  stance       String? @db.VarChar(200) // 如 "支持先有鸡"
  stancePrompt String? @map("stance_prompt") @db.Text // 完整的角色prompt

  // 独立的对话历史（核心！不与Topic历史共享）
  // 每个Agent只看到自己的历史，防止角色混乱
  conversationHistory Json @default("[]") @map("conversation_history")

  // 统计
  messageCount Int @default(0) @map("message_count")
  totalTokens  Int @default(0) @map("total_tokens")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  messages DebateMessage[]

  @@unique([sessionId, aiMemberId])
  @@index([sessionId])
  @@index([role])
  @@map("debate_agents")
}

// 辩论消息 - 独立于Topic消息的辩论专用消息
model DebateMessage {
  id String @id @default(uuid())

  // 关联辩论会话
  sessionId String        @map("session_id")
  session   DebateSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // 发送者Agent
  agentId String      @map("agent_id")
  agent   DebateAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // 消息内容
  content String @db.Text

  // 轮次信息
  round Int // 第几轮

  // AI生成元数据
  modelUsed  String? @map("model_used") @db.VarChar(50)
  tokensUsed Int?    @map("tokens_used")
  latencyMs  Int?    @map("latency_ms") // 响应延迟

  // 同步到Topic的消息ID（可选，用于在Topic中显示）
  topicMessageId String? @map("topic_message_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId, round])
  @@index([agentId])
  @@index([createdAt])
  @@map("debate_messages")
}

// ============ Raw Data Collection (replaces MongoDB) ============

model RawData {
  id String @id @default(uuid())

  // Data source type (arxiv, github, hackernews, rss, blog, etc.)
  source String @db.VarChar(50)

  // External ID for deduplication (e.g., arXiv ID, GitHub repo name)
  externalId String? @map("external_id") @db.VarChar(500)

  // Complete raw data stored as JSONB
  data Json

  // Reference to PostgreSQL Resource (bidirectional link)
  resourceId String?   @map("resource_id")
  resource   Resource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  // Processing status
  processedAt     DateTime? @map("processed_at")
  processingError String?   @map("processing_error") @db.Text
  isProcessed     Boolean   @default(false) @map("is_processed")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Indexes for performance
  @@index([source])
  @@index([externalId])
  @@index([resourceId])
  @@index([createdAt])
  @@index([isProcessed])
  // GIN index for JSONB data (created via raw SQL migration)
  @@map("raw_data")
}

// ============ AI Generated Images ============

model GeneratedImage {
  id String @id @default(uuid())

  // User who generated the image
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Generation parameters
  prompt         String  @db.Text
  enhancedPrompt String? @map("enhanced_prompt") @db.Text
  style          String  @default("realistic") @db.VarChar(50)
  aspectRatio    String  @default("1:1") @map("aspect_ratio") @db.VarChar(10)
  negativePrompt String? @map("negative_prompt") @db.Text

  // Generated image
  imageUrl String @map("image_url") @db.Text
  width    Int    @default(1024)
  height   Int    @default(1024)

  // Provider info
  provider String @default("stability") @db.VarChar(50)

  // Processing details (for history display)
  textModelUsed   String? @map("text_model_used") @db.VarChar(100)
  imageModelUsed  String? @map("image_model_used") @db.VarChar(100)
  processingSteps Json?   @map("processing_steps")
  promptInsights  Json?   @map("prompt_insights")

  // Bookmark status
  isBookmarked Boolean @default(false) @map("is_bookmarked")

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@index([isBookmarked])
  @@map("generated_images")
}

// ============================================================================
// DeepDive Engine v2.1 - 品牌套件系统
// ============================================================================

model BrandKit {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 基础信息
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)

  // 品牌配置 (JSON)
  colors Json // BrandColor[]
  fonts  Json // BrandFont[]
  logos  Json // { primary?, secondary?, icon? }
  voice  Json? // { tone, keywords }

  // 默认设计风格
  defaultStyle String @default("consulting") @map("default_style") @db.VarChar(50)

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("brand_kits")
}

// ============================================================================
// AI Office - 智能文档生成系统
// 支持 PPT、Word、Excel 等多种格式，Genspark 风格版本管理
// ============================================================================

// 文档类型枚举
enum OfficeDocumentType {
  ARTICLE // 文章/博客 → DOCX
  PPT // 演示文稿 → PPTX
  SPREADSHEET // 数据表格 → XLSX
  REPORT // 分析报告 → DOCX/PDF
  PROPOSAL // 提案/计划书 → DOCX/PPTX
  RESEARCH // 研究文档 → DOCX
}

// 文档状态枚举
enum OfficeDocumentStatus {
  DRAFT // 草稿
  GENERATING // 生成中
  COMPLETED // 已完成
  ARCHIVED // 已归档
}

// 版本触发方式枚举
enum VersionTrigger {
  AI_GENERATION // AI生成新版本
  USER_EDIT // 用户编辑触发
  MANUAL_SAVE // 手动保存
  AUTO_SAVE // 自动保存
}

// 资源引用类型枚举
enum ResourceRefType {
  PRIMARY // 主要参考资源
  SUPPORTING // 辅助参考
  CITED // 引用来源
}

// AI Office 文档主表
model OfficeDocument {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  workspaceId String? @map("workspace_id")

  // 基础信息
  title  String               @db.VarChar(500)
  type   OfficeDocumentType
  status OfficeDocumentStatus @default(DRAFT)

  // 内容存储
  content       Json // 结构化内容 (每页/每节数据)
  markdown      String? @db.Text // Markdown 源码 (可选)
  htmlSnapshots Json?   @map("html_snapshots") // HTML 页面快照数组

  // 版本管理
  currentVersionId String? @map("current_version_id")

  // 元数据
  metadata Json @default("{}") // { slideCount, wordCount, duration, ... }

  // AI 配置 (动态，不硬编码模型)
  aiConfig       Json? @map("ai_config") // { textModelId, imageModelId, temperature, style }
  generationLogs Json? @map("generation_logs") // 生成过程日志

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关联
  user         User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace?                  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  versions     OfficeDocumentVersion[]
  resourceRefs OfficeDocumentResourceRef[]

  @@index([userId, createdAt])
  @@index([workspaceId])
  @@index([type, status])
  @@map("office_documents")
}

// 文档版本表 (Genspark 风格保存点)
model OfficeDocumentVersion {
  id            String @id @default(uuid())
  documentId    String @map("document_id")
  versionNumber Int    @map("version_number") // 递增版本号 (1, 2, 3...)

  // 版本标识
  name        String  @db.VarChar(100) // "保存点-14" (自动生成)
  description String? @db.Text // AI 生成的版本描述

  // 内容快照
  contentSnapshot  Json    @map("content_snapshot") // 完整内容快照
  markdownSnapshot String? @map("markdown_snapshot") @db.Text // Markdown 快照

  // 触发信息
  trigger       VersionTrigger
  triggerSource String?        @map("trigger_source") @db.VarChar(200) // 触发来源详情

  // 元数据快照
  metadataSnapshot Json @map("metadata_snapshot") // { slideCount, wordCount }

  // 缩略图
  thumbnail String? @db.Text // Base64 or URL

  // AI 信息 (记录使用的模型，不硬编码)
  aiModelId  String? @map("ai_model_id") // 关联到 AIModel 表
  promptUsed String? @map("prompt_used") @db.Text // 生成时使用的 Prompt

  // 时间
  createdAt DateTime @default(now()) @map("created_at")

  // 关联
  document OfficeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, versionNumber])
  @@index([documentId, createdAt])
  @@map("office_document_versions")
}

// 文档资源引用表 (@ 引用系统)
model OfficeDocumentResourceRef {
  id         String @id @default(uuid())
  documentId String @map("document_id")
  resourceId String @map("resource_id")

  // 引用类型
  refType ResourceRefType @default(PRIMARY) @map("ref_type")

  // 使用追踪
  usedInPages       Int[]   @map("used_in_pages") // 在哪些页面使用了此资源
  extractionSummary String? @map("extraction_summary") @db.Text // AI 从资源提取的关键信息摘要

  // 时间
  createdAt DateTime @default(now()) @map("created_at")

  // 关联
  document OfficeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  resource Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([documentId, resourceId])
  @@index([documentId])
  @@index([resourceId])
  @@map("office_document_resource_refs")
}

// 文档模板表
enum TemplateCategory {
  BUSINESS // 商业
  ACADEMIC // 学术
  MARKETING // 营销
  TECHNICAL // 技术
  CREATIVE // 创意
  GENERAL // 通用
}

model OfficeDocumentTemplate {
  id String @id @default(uuid())

  // 基础信息
  name        String           @db.VarChar(200) // "商业计划书模板"
  description String?          @db.Text
  category    TemplateCategory @default(GENERAL)

  // 模板配置
  style         String @db.VarChar(50) // genspark, consulting, tech, ...
  defaultLayout String @default("cards") @map("default_layout") @db.VarChar(50) // cards, timeline, ...
  colorScheme   Json   @map("color_scheme") // { primary, accent, background, text }

  // 结构定义
  structure Json // 预定义的章节结构

  // 预览
  thumbnail String? @db.Text

  // 元数据
  usageCount Int     @default(0) @map("usage_count")
  isBuiltin  Boolean @default(false) @map("is_builtin")
  isPublic   Boolean @default(true) @map("is_public")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isBuiltin, isPublic])
  @@map("office_document_templates")
}

// ============ ASK AI 会话管理 ============

model AskSession {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  title   String @db.VarChar(200)
  summary String? @db.Text // AI 生成的会话摘要
  modelId String? @map("model_id") // 默认使用的模型

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AskMessage[]

  @@index([userId, updatedAt])
  @@map("ask_sessions")
}

model AskMessage {
  id        String @id @default(uuid())
  sessionId String @map("session_id")
  role      String @db.VarChar(20) // user, assistant, system
  content   String @db.Text
  modelId   String? @map("model_id") // 使用的模型 ID
  modelName String? @map("model_name") @db.VarChar(100) // 使用的模型名称

  // 元数据
  tokens    Int?    // token 使用量
  webSearch Boolean @default(false) @map("web_search") // 是否启用网页搜索

  createdAt DateTime @default(now()) @map("created_at")

  session AskSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("ask_messages")
}
