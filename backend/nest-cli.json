{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "incremental": true,
    "webpack": false,
    "preserveSymlinks": true,
    "assets": [
      { "include": "**/*.skill.md", "watchAssets": true },
      { "include": "**/SKILL.md", "watchAssets": true },
      { "include": "**/strategies/*.md", "watchAssets": true },
      { "include": "**/presets/*.json", "watchAssets": true },
      { "include": "**/duties/*.md", "watchAssets": true },
      { "include": "**/email/templates/*.hbs", "watchAssets": true }
    ]
  },
  "monorepo": false,
  "root": "."
}
