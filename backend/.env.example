# Database (PostgreSQL only - MongoDB migrated to JSONB)
DATABASE_URL=postgresql://user:password@localhost:5432/deepdive

# Blog Collection Configuration
BLOG_COLLECTION_ENABLED=true
BLOG_COLLECTION_CRON=0 */6 * * *
BLOG_COLLECTION_MAX_CONCURRENT=3
BLOG_COLLECTION_RETRY_ATTEMPTS=2

# API Configuration
API_PORT=4000
API_HOST=0.0.0.0

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=DeepDive <noreply@deepdive.ai>
ADMIN_EMAIL=admin@your-domain.com

# Application URL (for email links)
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# GitHub OAuth (for AI Coding feature)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/ai-coding/github/callback

# Other configurations
NODE_ENV=development

# Google OAuth (uses same credentials as user auth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Drive Integration
# Local: http://localhost:4000/api/v1/google-drive/callback
# Railway: https://backend-production-8638.up.railway.app/api/v1/google-drive/callback
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:4000/api/v1/google-drive/callback
