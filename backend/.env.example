# Database (PostgreSQL only - MongoDB migrated to JSONB)
DATABASE_URL=postgresql://user:password@localhost:5432/deepdive

# Blog Collection Configuration
BLOG_COLLECTION_ENABLED=true
BLOG_COLLECTION_CRON=0 */6 * * *
BLOG_COLLECTION_MAX_CONCURRENT=3
BLOG_COLLECTION_RETRY_ATTEMPTS=2

# API Configuration
API_PORT=4000
API_HOST=0.0.0.0

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=DeepDive <noreply@deepdive.ai>
ADMIN_EMAIL=admin@your-domain.com

# Application URL (for email links)
APP_URL=http://localhost:3000

# Other configurations
NODE_ENV=development
