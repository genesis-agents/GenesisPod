# GenesisPod Backend - 环境变量示例
# 复制此文件为 .env 并填写实际值

# ====================
# 必须配置（缺少将拒绝启动）
# ====================
DATABASE_URL=postgresql://genesis:change_this_strong_password@localhost:5432/genesis
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_32_chars

# ====================
# 强烈推荐配置（生产必须）
# ====================
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
ADMIN_EMAILS=admin@example.com
STORAGE_ADMIN_KEY=change_this_admin_key
CORS_ORIGINS=http://localhost:3000

# ====================
# Redis 缓存（可选，缺少时退化为内存缓存）
# ====================
# 本地开发：密码必须与 docker-compose.yml 的 REDIS_PASSWORD 保持一致
# 本地默认: redis://:genesis_redis_dev_password@localhost:6379
# 生产(Railway): redis://default:PASSWORD@host:port（由 Railway 自动注入）
REDIS_URL=redis://:genesis_redis_dev_password@localhost:6379
REDIS_PUBLIC_URL=

# ====================
# 服务器端口
# ====================
PORT=4000
BACKEND_PORT=4000

# ====================
# Railway 部署（生产环境自动注入，本地留空）
# ====================
# RAILWAY_ENVIRONMENT=production
# RAILWAY_DOMAIN=genesis-ai
# RAILWAY_FRONTEND_URL=https://genesis-ai.up.railway.app
# RAILWAY_PUBLIC_DOMAIN=genesis-ai-backend.up.railway.app

# ====================
# 品牌配置（可选，有默认值）
# ====================
BRAND_NAME=Genesis
BRAND_FULL_NAME=GenesisPod
BRAND_SUBTITLE=
BRAND_EMAIL_FROM=Genesis <noreply@genesis.ai>
BRAND_CONTACT_EMAIL=contact@genesis.ai

# ====================
# 邮件服务（配置其一）
# ====================
EMAIL_ENABLED=false
# 方案一：SMTP
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=your@gmail.com
# 方案二：Resend
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxx

# ====================
# 第三方搜索/内容 API（配置后启用对应工具）
# ====================
TAVILY_API_KEY=
JINA_API_KEY=
FIRECRAWL_API_KEY=
SERPER_API_KEY=
PERPLEXITY_API_KEY=

# ====================
# OAuth 集成（可选）
# ====================
# Google Drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Notion
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_CALLBACK_URL=http://localhost:4000/api/v1/notion/oauth/callback

# ====================
# 功能开关
# ====================
WORKSPACE_AI_V2_ENABLED=false

# ====================
# 基础设施（可选，有默认值）
# ====================
# FlareSolverr（Cloudflare 绕过代理）
FLARESOLVERR_URL=http://localhost:8191/v1
# Puppeteer（容器内已预装 Chromium，本地开发可留空）
PUPPETEER_EXECUTABLE_PATH=
# 导出文件目录
EXPORT_DIR=
# PostgreSQL 连接池
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=10
CACHE_MAX_ITEMS=5000
