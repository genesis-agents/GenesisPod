# backend Dockerfile 在自己目录下 build，context = backend/
# 这份 .dockerignore 控制哪些文件进 builder 镜像

# Node / TypeScript 构建产物（builder 内会重新 build）
node_modules
dist
*.tsbuildinfo
.tsbuildinfo

# 测试 / 规范文件 —— 不需要进 builder（即使最终镜像不含也省 COPY 时间）
tests
__tests__
**/*.spec.ts
**/*.test.ts
coverage
jest.config.*
.jestcache

# Git / IDE / OS
.git
.gitignore
.gitattributes
.github
.vscode
.idea
.DS_Store
Thumbs.db

# 环境 / 密钥（绝对不进镜像）
.env
.env.*
!.env.example

# Claude / AI 助手内部上下文
.claude
CLAUDE.md

# 文档 / 内部资料
docs
*.md
!README.md

# 临时 / 日志 / 缓存
*.log
.cache
.eslintcache
tmp
temp

# Prisma 客户端会在 builder 内重新 generate
prisma/generated
node_modules/.prisma
