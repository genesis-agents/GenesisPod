    "pdfkit": "^0.17.2",
    "pdfkit-table": "^0.1.99",
    "pg": "^8.16.3",
    "pptxgenjs": "^4.0.1",
    "prisma": "^6.19.2",
    "puppeteer": "^24.30.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^4.0.0",
    "rss-parser": "^3.12.0",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "string-similarity-js": "^2.1.4",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.20.6",
    "turndown": "^7.2.2",
    "xml2js": "^0.6.2",
    "youtube-transcript": "^1.2.1",
    "youtubei.js": "^16.0.1",
