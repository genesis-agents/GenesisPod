{
  "name": "genesis-backend",
  "version": "40.3.0",
  "description": "Genesis.ai Backend API",
  "private": true,
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && prisma generate && tsc -p tsconfig.json --incremental false && tsc-alias -p tsconfig.json && node scripts/copy-build-assets.js",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,tests}/**/*.ts\"",
    "lint:fix": "eslint \"{src,tests}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "verify:arch": "jest src/__tests__/architecture --no-coverage --forceExit",
    "test": "jest",
    "test:quick": "jest --forceExit --testPathIgnorePatterns=\"python-executor|jwt-auth.guard|jwt.strategy|team-collaboration|team-member.agent|ai-image.service|proxy.controller|guardrails|mcp-adapter|mcp-server|ai-social|news-extractor|collection-task|openai.provider|file-conversion|planning-orchestrator.service.spec|topic-research.gateway.spec\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./tests/e2e/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:studio:railway": "dotenv -e .env.railway -- prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed": "tsx prisma/seed.ts",
    "seed:templates": "tsx scripts/seed/seed-report-templates.ts",
    "seed:simulation": "tsx scripts/seed/seed-simulation-providers.ts",
    "seed:youtube": "tsx scripts/seed/seed-youtube-sources.ts",
    "thumbnails:generate": "tsx scripts/thumbnails/generate-thumbnails.ts",
    "thumbnails:arxiv": "tsx scripts/thumbnails/update-arxiv-thumbnails.ts",
    "thumbnails:all": "tsx scripts/thumbnails/generate-all-thumbnails.ts",
    "diagnose": "tsx prisma/diagnose-db.ts",
    "deploy": "tsx prisma/deploy-migrations.ts && npm run prisma:seed",
    "deploy:migrate": "tsx prisma/deploy-migrations.ts",
    "release:preview": "tsx ../infra/railway/scripts/release-notify.ts --dry-run",
    "release:notify": "tsx ../infra/railway/scripts/release-notify.ts",
    "dev:circular": "tsx scripts/dev-tools/detect-circular-deps.ts",
    "verify:file-governance": "tsx scripts/dev-tools/audit-base-layer-file-governance.ts",
    "maintenance:policy": "tsx scripts/maintenance/update-policy-whitelist.ts",
    "maintenance:validate": "tsx scripts/maintenance/validate-data-integrity.ts"
  },
  "prisma": {
    "schema": "prisma/schema",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@aws-sdk/client-s3": "^3.943.0",
    "@aws-sdk/s3-request-presigner": "^3.943.0",
