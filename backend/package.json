    "jest": "^29.5.0",
    "prettier": "^3.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
