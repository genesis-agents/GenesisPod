<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{topic.name}} · 今日精选</title>
  {{!-- preheader: inbox preview line (hidden via CSS) --}}
  <style>
    .preheader { display: none !important; max-height: 0; overflow: hidden; mso-hide: all; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; line-height: 1.6; color: #1e293b; background: #f8fafc; margin: 0; padding: 0; }
    .wrapper { max-width: 600px; margin: 0 auto; background: #ffffff; }
    .header { background: #4f46e5; color: #ffffff; padding: 24px 32px; }
    .header-meta { font-size: 13px; color: #c7d2fe; margin-top: 4px; }
    .body { padding: 24px 32px; }
    .overview { background: #f1f5f9; border-radius: 8px; padding: 16px 20px; margin-bottom: 24px; font-size: 14px; color: #475569; }
    .signal-card { border: 1px solid #e2e8f0; border-radius: 8px; padding: 20px; margin-bottom: 16px; }
    .signal-header { font-size: 16px; font-weight: 700; color: #0f172a; margin-bottom: 12px; }
    .signal-tier { margin-right: 8px; }
    .signal-section { margin-bottom: 10px; font-size: 14px; }
    .signal-label { font-weight: 600; color: #64748b; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px; }
    .signal-value { color: #1e293b; }
    .why-callout { background: #f5f3ff; border-left: 4px solid #7c3aed; border-radius: 0 6px 6px 0; padding: 10px 14px; margin: 10px 0; font-size: 14px; color: #3730a3; }
    .chips { margin: 8px 0; font-size: 13px; color: #475569; }
    .actions { margin-top: 14px; font-size: 13px; }
    .actions a { color: #4f46e5; text-decoration: none; margin-right: 16px; }
    .narrative { background: #fafafa; border: 1px solid #e2e8f0; border-radius: 6px; padding: 10px 14px; margin-top: 10px; font-size: 13px; color: #475569; }
    .divider { border: none; border-top: 1px solid #e2e8f0; margin: 24px 0; }
    .footer { padding: 20px 32px; background: #f8fafc; border-top: 1px solid #e2e8f0; font-size: 12px; color: #94a3b8; }
    .footer a { color: #64748b; text-decoration: underline; }
    .unsubscribe { margin-top: 12px; font-size: 11px; color: #cbd5e1; }
    .unsubscribe a { color: #94a3b8; }
  </style>
</head>
<body>
  {{!-- Hidden preheader text --}}
  <span class="preheader">{{truncate signals.[0].whyItMatters 120}}</span>

  <div class="wrapper">
    {{!-- Header --}}
    <div class="header">
      <div style="font-size: 20px; font-weight: 700;">{{topic.name}} · 今日精选</div>
      <div class="header-meta">
        {{briefingDateFull}} {{briefingTime}}
        &nbsp;&middot;&nbsp;
        AI 替你看了 {{candidatesCount}} 条，筛出 {{signals.length}} 条值得关注
      </div>
    </div>

    <div class="body">
      {{!-- Overview stats --}}
      <div class="overview">
        今日共评估 <strong>{{candidatesCount}}</strong> 条候选信号，
        精选出 <strong>{{signals.length}}</strong> 条值得关注
      </div>

      {{!-- Signal cards --}}
      {{#each signals}}
      <div class="signal-card">
        <div class="signal-header">
          <span class="signal-tier">{{tierBadge this.tier}}</span>{{this.title}}
        </div>

        <div class="signal-section">
          <div class="signal-label">⚡ 一句话</div>
          <div class="signal-value">{{this.oneLineTakeaway}}</div>
        </div>

        <div class="why-callout">
          <div class="signal-label" style="color:#5b21b6;">💡 为什么重要</div>
          {{this.whyItMatters}}
        </div>

        <div class="signal-section">
          <div class="signal-label">🔮 接下来看什么</div>
          <div class="signal-value">{{this.whatsNext}}</div>
        </div>

        <div class="chips">
          📡 {{join this.signalTags " · "}}
        </div>
        {{#if this.entities}}
        <div class="chips">
          🏢 {{join this.entities " · "}}
        </div>
        {{/if}}

        <div class="signal-section" style="font-size:13px; color:#64748b;">
          📚 {{length this.evidenceItemIds}} 处证据
          {{#if this.evidenceItemIds}}来自 {{evidenceSources this.evidenceItemIds}}{{/if}}
        </div>

        {{#if this.narrativeId}}
        {{#if (lookup ../narrativeMap this.narrativeId)}}
        <div class="narrative">
          📰 {{lookup ../narrativeMap this.narrativeId "label"}}
          &middot; 第 {{lookup ../narrativeMap this.narrativeId "episode"}} 集
          &nbsp;&nbsp;
          <a href="{{lookup ../narrativeMap this.narrativeId "timelineUrl"}}">查看前情 &rarr;</a>
        </div>
        {{/if}}
        {{/if}}

        <div class="actions">
          {{#if this.id}}
          <a href="{{detailUrl this.id}}">查看详情与原文 &rarr;</a>
          <a href="mailto:?subject={{urlEncode this.title}}&amp;body={{urlEncode this.whyItMatters}}%0A%0A{{urlEncode (detailUrl this.id)}}">📤 转发给同事</a>
          {{/if}}
        </div>
      </div>
      {{/each}}

      <hr class="divider" />

      {{!-- Topic link --}}
      <div style="text-align:center; padding: 8px 0 16px;">
        <a href="{{topicUrl}}"
           style="display:inline-block; padding:10px 24px; background:#4f46e5; color:#fff; text-decoration:none; border-radius:6px; font-size:14px; font-weight:600;">
          打开雷达 &rarr;
        </a>
        &nbsp;&nbsp;
        <a href="{{settingsUrl}}" style="font-size:13px; color:#64748b;">调整推送频率</a>
      </div>
    </div>

    {{!-- Footer --}}
    <div class="footer">
      <div>你订阅了「{{topic.name}}」雷达的每日精选推送。</div>
      <div class="unsubscribe">
        退订：
        <a href="{{unsubscribeTopicUrl}}">退订该雷达</a>
        &nbsp;&middot;&nbsp;
        <a href="{{unsubscribeRadarUrl}}">退订所有 AI 雷达</a>
        &nbsp;&middot;&nbsp;
        <a href="{{unsubscribeAllUrl}}">退订全部通知</a>
        <br />
        <span style="color:#e2e8f0;">（退订链接含 7 天 JWT token，单击即退订无需登录）</span>
      </div>
    </div>
  </div>
</body>
</html>
