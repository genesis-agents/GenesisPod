<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{topic.name}} · 本周精选周报</title>
  {{!-- preheader: inbox preview line (hidden via CSS) --}}
  <style>
    .preheader { display: none !important; max-height: 0; overflow: hidden; mso-hide: all; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; line-height: 1.6; color: #1e293b; background: #f8fafc; margin: 0; padding: 0; }
    .wrapper { max-width: 600px; margin: 0 auto; background: #ffffff; }
    .header { background: #0f172a; color: #ffffff; padding: 24px 32px; }
    .header-meta { font-size: 13px; color: #94a3b8; margin-top: 4px; }
    .body { padding: 24px 32px; }
    .stats-grid { display: flex; gap: 12px; background: #f1f5f9; border-radius: 8px; padding: 16px 20px; margin-bottom: 24px; font-size: 13px; color: #475569; flex-wrap: wrap; }
    .stat-item { flex: 1; min-width: 100px; text-align: center; }
    .stat-value { font-size: 22px; font-weight: 700; color: #0f172a; display: block; }
    .stat-label { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: 0.04em; }
    .section-title { font-size: 15px; font-weight: 700; color: #0f172a; margin: 24px 0 12px; padding-bottom: 6px; border-bottom: 2px solid #e2e8f0; }
    .narrative-item { border: 1px solid #e2e8f0; border-radius: 8px; padding: 14px 16px; margin-bottom: 10px; font-size: 14px; }
    .narrative-label { font-weight: 600; color: #0f172a; margin-bottom: 4px; }
    .narrative-meta { font-size: 12px; color: #64748b; margin-bottom: 6px; }
    .narrative-latest { color: #475569; font-size: 13px; }
    .signal-row { display: flex; gap: 12px; align-items: flex-start; padding: 12px 0; border-bottom: 1px solid #f1f5f9; font-size: 14px; }
    .signal-row:last-child { border-bottom: none; }
    .signal-num { color: #94a3b8; font-weight: 600; min-width: 24px; }
    .signal-date { color: #94a3b8; font-size: 12px; min-width: 36px; }
    .signal-body { flex: 1; }
    .signal-title { font-weight: 600; color: #0f172a; margin-bottom: 2px; }
    .signal-takeaway { color: #475569; font-size: 13px; margin-bottom: 4px; }
    .why-inline { color: #3730a3; font-size: 13px; background: #f5f3ff; border-left: 3px solid #7c3aed; padding: 4px 10px; border-radius: 0 4px 4px 0; margin: 4px 0; }
    .evidence-meta { font-size: 12px; color: #94a3b8; }
    .actions a { font-size: 12px; color: #4f46e5; text-decoration: none; }
    .divider { border: none; border-top: 1px solid #e2e8f0; margin: 24px 0; }
    .footer { padding: 20px 32px; background: #f8fafc; border-top: 1px solid #e2e8f0; font-size: 12px; color: #94a3b8; }
    .footer a { color: #64748b; text-decoration: underline; }
    .unsubscribe { margin-top: 12px; font-size: 11px; color: #cbd5e1; }
    .unsubscribe a { color: #94a3b8; }
  </style>
</head>
<body>
  {{!-- Hidden preheader text --}}
  <span class="preheader">本周 {{topSignals.length}} 条 ⭐⭐⭐ 信号 / {{narrativeCount}} 条延续叙事</span>

  <div class="wrapper">
    {{!-- Header --}}
    <div class="header">
      <div style="font-size: 20px; font-weight: 700;">{{topic.name}} · 本周精选周报</div>
      <div class="header-meta">
        {{weekRangeFull}}
        &nbsp;&middot;&nbsp;
        共 {{candidatesTotal}} 条信号，{{topSignals.length}} 条最高评级
      </div>
    </div>

    <div class="body">
      {{!-- Stats overview --}}
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-value">{{tier3Count}}</span>
          <span class="stat-label">⭐⭐⭐ 信号</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">{{tier2Count}}</span>
          <span class="stat-label">⭐⭐ 信号</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">{{narrativeCount}}</span>
          <span class="stat-label">延续叙事</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">{{newEntityCount}}</span>
          <span class="stat-label">新实体</span>
        </div>
      </div>

      {{!-- Narrative threads --}}
      {{#if narrativeMap}}
      <div class="section-title">📰 本周延续叙事（按进度排序）</div>
      {{#each narrativeMap}}
      <div class="narrative-item">
        <div class="narrative-label">{{this.label}}</div>
        <div class="narrative-meta">{{join this.episodes " &rarr; "}}（{{length this.episodes}} 集进展）</div>
        <div class="narrative-latest">最新：{{this.latestTitle}}</div>
        <div style="margin-top:6px;">
          <a href="{{this.timelineUrl}}" style="font-size:12px; color:#4f46e5;">查看完整时间线 &rarr;</a>
        </div>
      </div>
      {{/each}}
      {{/if}}

      {{!-- Top signals list --}}
      <div class="section-title">⭐⭐⭐ 本周 TOP {{topSignals.length}} 信号</div>
      <div>
        {{#each topSignals}}
        <div class="signal-row">
          <div class="signal-num">{{add @index 1}}.</div>
          <div class="signal-date">{{this.dateShort}}</div>
          <div class="signal-body">
            <div class="signal-title">{{tierBadge this.tier}} {{this.title}}</div>
            <div class="signal-takeaway">⚡ {{this.oneLineTakeaway}}</div>
            <div class="why-inline">💡 {{this.whyItMatters}}</div>
            <div class="evidence-meta">
              📚 {{length this.evidenceItemIds}} 处证据
              {{#if this.id}}
              &nbsp;&middot;&nbsp;
              <a href="{{detailUrl this.id}}" style="color:#4f46e5; font-size:12px; text-decoration:none;">查看详情 &rarr;</a>
              {{/if}}
            </div>
          </div>
        </div>
        {{/each}}
      </div>

      <hr class="divider" />

      {{!-- CTA --}}
      <div style="text-align:center; padding: 8px 0 16px;">
        <a href="{{topicUrl}}"
           style="display:inline-block; padding:10px 24px; background:#0f172a; color:#fff; text-decoration:none; border-radius:6px; font-size:14px; font-weight:600;">
          打开雷达 &rarr;
        </a>
        &nbsp;&nbsp;
        <a href="{{settingsUrl}}" style="font-size:13px; color:#64748b;">调整周报频率</a>
      </div>
    </div>

    {{!-- Footer --}}
    <div class="footer">
      <div>你订阅了「{{topic.name}}」雷达的每周精选周报。</div>
      <div style="margin-top:4px; color:#cbd5e1; font-size:11px;">周报由模板拼装生成（无 LLM）</div>
      <div class="unsubscribe">
        退订：
        <a href="{{unsubscribeWeeklyUrl}}">退订周报</a>
        &nbsp;&middot;&nbsp;
        <a href="{{unsubscribeAllUrl}}">退订全部通知</a>
        <br />
        <span style="color:#e2e8f0;">（退订链接含 7 天 JWT token，单击即退订无需登录）</span>
      </div>
    </div>
  </div>
</body>
</html>
