{
  "$schema": "node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.4.0",
    "generators": {
      "typescript-sdk": {
        "generatorName": "typescript-fetch",
        "output": "#{cwd}/sdk/typescript",
        "inputSpec": "#{cwd}/backend/openapi.json",
        "additionalProperties": {
          "npmName": "@genesis-ai/sdk",
          "npmVersion": "1.0.0",
          "supportsES6": true,
          "typescriptThreePlus": true,
          "withInterfaces": true
        }
      },
      "python-sdk": {
        "generatorName": "python",
        "output": "#{cwd}/sdk/python",
        "inputSpec": "#{cwd}/backend/openapi.json",
        "additionalProperties": {
          "packageName": "genesis_ai_sdk",
          "packageVersion": "1.0.0",
          "projectName": "genesis-ai-sdk"
        }
      }
    }
  }
}
