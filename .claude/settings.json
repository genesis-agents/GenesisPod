{
  "permissions": {
    "allow": ["Bash(npm run:*)", "Bash(npx prisma:*)", "Bash(npx tsc:*)"],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./backend/.env)",
      "Read(./backend/.env.*)",
      "Read(./frontend/.env.*)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  },
  "env": {
    "PRISMA_HIDE_UPDATE_MESSAGE": "true"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm run type-check",
            "timeout": 90000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git push:*)",
        "hooks": [
          {
            "type": "command",
            "command": "npm run test:quick",
            "timeout": 300000
          }
        ]
      }
    ]
  }
}
