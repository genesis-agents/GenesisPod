{
  "enableAllProjectMcpServers": true,
  "env": {
    "PRISMA_HIDE_UPDATE_MESSAGE": "true",
    "FORCE_COLOR": "1",
    "NODE_ENV": "development"
  },
  "attribution": {
    "commit": "\n\n🤖 Generated with [Claude Code](https://claude.com/claude-code)\n\nCo-Authored-By: genesis-agents <hello@gens.team>",
    "pr": "🤖 Generated with [Claude Code](https://claude.com/claude-code)"
  },
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(npx prisma:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx jest:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./backend/.env)",
      "Read(./backend/.env.*)",
      "Read(./frontend/.env.*)",
      "Read(**/*credentials*.{json,env,yaml,yml,key,pem,txt})",
      "Read(**/*secret*.json)",
      "Read(**/*secret*.env)",
      "Read(**/*secret*.yaml)",
      "Read(**/*secret*.yml)",
      "Read(**/*token*.env)",
      "Read(**/*token*.json)",
      "Read(**/*token*.yaml)",
      "Read(**/*token*.yml)",
      "Read(**/*token*.txt)",
      "Read(**/*password*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Write(.github/workflows/*)",
      "Write(.gitignore)",
      "Write(.npmrc)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm run type-check --silent 2>&1 | head -20",
            "timeout": 90000
          }
        ]
      },
      {
        "matcher": "Write(*.test.ts)|Write(*.spec.ts)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Test file created - run npm run test:quick to verify'",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git push:*)",
        "hooks": [
          {
            "type": "command",
            "command": "npm run test:quick",
            "timeout": 300000
          }
        ]
      },
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint",
            "timeout": 120000
          }
        ]
      },
      {
        "matcher": "Edit(backend/prisma/schema.prisma)",
        "hooks": [
          {
            "type": "command",
            "command": "cd backend && npx prisma validate",
            "timeout": 30000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm install --silent 2>&1 | tail -3 && npx prisma generate --silent 2>&1 | tail -3",
            "timeout": 120000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Code review completed - check the review report'"
          }
        ]
      },
      {
        "matcher": "tester",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Testing completed - check test results'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "context7@claude-plugins-official": false
  }
}
