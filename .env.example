# ============================================
# DeepDive Engine - 环境变量示例
# ============================================
# 复制此文件为 .env 并填入实际值
# 所有密钥应从secretManager获取
# ============================================

# ============ AI服务 ============
# Grok API (首选)
GROK_API_KEY=<从secretManager获取>

# OpenAI API (备用)
OPENAI_API_KEY=<从secretManager获取>

# ============ 数据库 ============
# PostgreSQL
DATABASE_URL=postgresql://deepdive:<password>@localhost:5432/deepdive
POSTGRES_PASSWORD=<从secretManager获取>

# Neo4j
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<从secretManager获取>

# MongoDB
MONGO_URL=mongodb://deepdive:<password>@localhost:27017/deepdive
MONGO_PASSWORD=<从secretManager获取>

# Redis
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=<从secretManager获取>

# ============ 应用配置 ============
# 环境
NODE_ENV=development  # development | production | test

# API端口
BACKEND_PORT=4000
AI_SERVICE_PORT=5000

# 前端URL
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# 功能开关
WORKSPACE_AI_V2_ENABLED=false
NEXT_PUBLIC_WORKSPACE_AI_V2_ENABLED=false

# ============ 认证 ============
# JWT密钥
JWT_SECRET=<从secretManager获取>
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ============ 外部API ============
# GitHub API
GITHUB_TOKEN=<从secretManager获取>

# ============ 图片存储（二选一）============

# 方案1: Backblaze B2（推荐，无需信用卡）
# 免费额度：10GB 存储 + 1GB/天出站
# 注册：https://www.backblaze.com/b2/sign-up.html
B2_KEY_ID=<Application Key ID>
B2_APP_KEY=<Application Key>
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_BUCKET_NAME=deepdive-images
B2_PUBLIC_URL=https://f004.backblazeb2.com/file/deepdive-images

# 方案2: Cloudflare R2（需要信用卡）
# 免费额度：10GB 存储 + 无限出站
# R2_ACCOUNT_ID=<Cloudflare Account ID>
# R2_ACCESS_KEY_ID=<R2 API Token Access Key ID>
# R2_SECRET_ACCESS_KEY=<R2 API Token Secret Access Key>
# R2_BUCKET_NAME=deepdive-images
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# arXiv API (通常无需密钥)
# ARXIV_API_KEY=

# ============ 企业微信机器人 ============
# 企业微信配置 (在企业微信管理后台获取)
# 文档: https://developer.work.weixin.qq.com/document/path/90665
WECHAT_WORK_CORP_ID=<企业ID>
WECHAT_WORK_AGENT_ID=<应用AgentId>
WECHAT_WORK_SECRET=<应用Secret>
WECHAT_WORK_TOKEN=<回调Token>
WECHAT_WORK_ENCODING_AES_KEY=<回调EncodingAESKey>

# ============ 其他 ============
# 日志级别
LOG_LEVEL=debug  # debug | info | warn | error

# 前端配置
NEXT_PUBLIC_APP_NAME=DeepDive Engine
NEXT_PUBLIC_APP_URL=http://localhost:3000
