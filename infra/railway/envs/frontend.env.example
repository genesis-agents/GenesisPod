# Railway Frontend Environment Variables
# Copy these to Railway Dashboard -> Frontend Service -> Variables

# ============================================
# Application Settings
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# API Configuration
# ============================================
# Reference to Backend service URL (Railway variable reference)
NEXT_PUBLIC_API_URL=https://${{Backend.RAILWAY_PUBLIC_DOMAIN}}

# Or if you have a custom domain:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ============================================
# Brand Configuration (optional, defaults to Genesis)
# ============================================
# NEXT_PUBLIC_BRAND_NAME=Genesis
# NEXT_PUBLIC_BRAND_FULL_NAME=Genesis.ai
# NEXT_PUBLIC_BRAND_SUBTITLE=
# NEXT_PUBLIC_BRAND_TAGLINE=AI-Powered Research Platform
# NEXT_PUBLIC_RAILWAY_DOMAIN=genesis-ai
# NEXT_PUBLIC_BRAND_LOGO_PATH=/favicon.svg

# ============================================
# Build Settings
# ============================================
NEXT_TELEMETRY_DISABLED=1
