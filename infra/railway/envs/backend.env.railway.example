# Backend Railway public-proxy connection — example.
#
# Used by:
#   - infra/railway/scripts/studio.sh   (Prisma Studio against prod DB)
#   - infra/railway/scripts/db-shell.sh (psql against prod DB)
#   - backend npm script "db:studio:railway" (dotenv -e .env.railway -- prisma studio)
#
# Copy this file to backend/.env.railway and fill in real values.
# backend/.env.railway is gitignored — do NOT commit it.
#
# Where to find the values:
#   1. Railway dashboard → Postgres service → Connect tab
#   2. Pick the "Public Network" connection string (proxy.rlwy.net host)
#   3. Paste as DATABASE_URL below

DATABASE_URL=postgresql://postgres:<PASSWORD>@<HOST>.proxy.rlwy.net:<PORT>/railway

# Optional: only needed if you want a separate read replica or shadow DB.
# DIRECT_URL=postgresql://postgres:<PASSWORD>@<HOST>.proxy.rlwy.net:<PORT>/railway
