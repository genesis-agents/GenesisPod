# GenesisPod 客户离线部署 - 环境变量模板
#
# 复制本文件为 .env.production 并填写下列变量。
# .env.production 包含敏感密码，请勿提交到 git，请勿和镜像 tar 一起明文发送。

# ──────────────────────────────────────────────────────────
# 必填：基础设施密码（首次启动前生成强随机串）
# ──────────────────────────────────────────────────────────

# PostgreSQL 数据库密码（建议 ≥ 24 位，含数字字母符号）
# 生成方式：openssl rand -base64 32
POSTGRES_PASSWORD=

# Redis 密码（同上）
REDIS_PASSWORD=

# ──────────────────────────────────────────────────────────
# 必填：应用密钥（首次启动前生成）
# ──────────────────────────────────────────────────────────

# JWT 签名密钥，≥ 32 字符随机串
# 生成方式：openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# 首次启动时自动创建的管理员账号
# 系统启动后请立即登录 → 修改密码 → 删除此处明文
ADMIN_INITIAL_EMAIL=admin@your-domain.com
ADMIN_INITIAL_PASSWORD=

# ──────────────────────────────────────────────────────────
# 可选：对外暴露
# ──────────────────────────────────────────────────────────

# 客户对外访问的域名 / IP（用于前端浏览器侧 fetch）
# 例：https://genesis.example.com  或  http://192.168.1.100:3000
# 留空 = 同源（适合 nginx 反向代理同域场景）
PUBLIC_BASE_URL=

# frontend 容器在宿主机的端口（默认 3000）
FRONTEND_PORT=3000

# 时区
TZ=Asia/Shanghai

# ──────────────────────────────────────────────────────────
# 可选：品牌定制
# ──────────────────────────────────────────────────────────
# 注：品牌名是 build-time 注入到前端 bundle 的，运行时改这两个变量
# 只会影响后端日志显示，前端 UI 仍是原 build 时的品牌名。
# 如需深度定制品牌，请联系 Genesis 团队重新打包前端镜像。

BRAND_NAME=Genesis
BRAND_FULL_NAME=GenesisPod

# ──────────────────────────────────────────────────────────
# 镜像版本（可选，默认 :latest）
# ──────────────────────────────────────────────────────────
# 私有 registry / 离线 tar 加载后请填明确的 tag 避免误升级

BACKEND_IMAGE=genesis/backend:latest
FRONTEND_IMAGE=genesis/frontend:latest
AI_SERVICE_IMAGE=genesis/ai-service:latest

# ──────────────────────────────────────────────────────────
# !! 关于 LLM API Key 的重要说明 !!
# ──────────────────────────────────────────────────────────
# GenesisPod 走 BYOK（Bring Your Own Key）模式：
#   - 不要在本文件配置 OPENAI_API_KEY / ANTHROPIC_API_KEY 等
#   - 系统启动后用管理员账号登录 → 进入「系统 → AI → 模型 / 工具」
#     用页面表单录入你自己的 LLM API key
#   - 各业务用户可以在「个人设置 → BYOK」录入自己的 key
#   - 这样 LLM 调用成本归属正确，且密钥不会以明文进 .env

# 用户数据加密密钥（BYOK key / settings / secrets 入库加密用）
# !! 一旦设置请妥善保存 !! —— 改 key = 旧密文全部解不开
# 生成方式：openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY=

# 存储管理 API 的访问令牌（admin 后台清理 storage / 重置 quota 时校验）
# 生成方式：openssl rand -hex 32
STORAGE_ADMIN_KEY=

# 管理员邮箱白名单（逗号分隔，授予 admin 角色识别）
ADMIN_EMAILS=admin@your-domain.com

# 前端 URL（backend 发邮件 / 拼跳转链接时拼绝对地址，通常和 PUBLIC_BASE_URL 一致）
FRONTEND_URL=

# ──────────────────────────────────────────────────────────
# Google OAuth 登录（可选, 不填则前端"使用 Google 账户"按钮点击失败）
# ──────────────────────────────────────────────────────────
# 启用步骤:
#   1. https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID, type: Web application
#   3. Authorized redirect URI 填: http://localhost:3000/api/v1/auth/google/callback
#      (生产环境改成 https://your-domain.com/api/v1/auth/google/callback)
#   4. 把生成的 Client ID / Secret 填下方
#   5. docker compose restart backend
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ──────────────────────────────────────────────────────────
# 本地模型 / 慢响应模型友好的 mission liveness 阈值（可选, 默认值偏严）
# ──────────────────────────────────────────────────────────
# Default (frontier model 优化): wall-time 240min, stale 15min, soft-warn 20min。
# 本地 Ollama / LMStudio 一次 LLM 调用动辄 5-20min 不响应 heartbeat, 默认 15min
# stale 会误杀。建议本地模型场景拉高到下方值。
PLAYGROUND_WALL_TIME_CAP_MS=86400000
PLAYGROUND_STALE_THRESHOLD_MIN=90
PLAYGROUND_SOFT_WARN_THRESHOLD_MIN=120
