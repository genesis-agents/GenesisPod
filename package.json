{
  "name": "genesis-ai",
  "version": "50.6.1",
  "description": "GenesisPod - AI驱动的智能研究平台",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "prepare": "node -e \"process.env.CI === 'true' || require('child_process').execSync('husky install', {stdio: 'inherit'})\"",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:ai\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:ai": "cd ai-service && uvicorn main:app --reload --port 5000",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "test": "npm run test:frontend && npm run test:backend",
    "test:quick": "npm run test:ci:frontend && npm run test:quick:backend",
    "test:quick:backend": "cd backend && npm run test:quick",
    "test:ci": "npm run test:ci:frontend && npm run test:ci:backend",
    "test:ci:full": "npm run test:ci:frontend && npm run test:ci:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test",
    "test:ci:frontend": "cd frontend && npm run test:ci",
    "test:ci:backend": "cd backend && npm test",
    "test:coverage": "npm run test:coverage:frontend && npm run test:coverage:backend",
    "test:coverage:frontend": "cd frontend && npm run test:coverage",
    "test:coverage:backend": "cd backend && npm run test:coverage",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "lint:fix": "npm run lint:fix:frontend && npm run lint:fix:backend",
    "lint:fix:frontend": "cd frontend && npm run lint:fix",
    "lint:fix:backend": "cd backend && npm run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "npm run type-check:frontend && npm run type-check:backend",
    "type-check:frontend": "cd frontend && npm run type-check",
    "type-check:backend": "cd backend && npm run type-check",
    "db:setup": "docker-compose up -d",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:seed": "cd backend && npx prisma db seed",
    "db:studio": "cd backend && npx prisma studio",
    "pre-commit": "lint-staged",
    "validate": "npm run format:check && npm run lint && npm run type-check && npm run test",
    "verify:quick": "npm run type-check && npm run test:quick",
    "verify:full": "npm run lint && npm run type-check && npm run test && npm run build",
    "verify:frontend": "cd frontend && npm run type-check && npm run test",
    "verify:backend": "cd backend && npm run type-check && npm run test:quick",
    "verify:changed": "node scripts/utils/verify-changed.js",
    "verify:pre-push": "npm run type-check && npm run build:backend",
    "verify:ci-local": "npm run type-check && npm run lint && npm run build && npm run test:quick",
    "verify:arch": "cd backend && npm run verify:arch",
    "quality-metrics": "node scripts/utils/quality-metrics.js",
    "monitor": "bash scripts/devops/monitor-production.sh",
    "monitor:quiet": "bash scripts/devops/monitor-production.sh --quiet",
    "check:facade": "bash scripts/devops/check-facade-boundary.sh",
    "audit:ui": "npm run audit:ui-discipline && npm run audit:ui-tokens",
    "audit:ui-discipline": "tsx scripts/utils/audit-ui-discipline.ts",
    "audit:ui-tokens": "tsx scripts/utils/audit-ui-tokens.ts",
    "audit:ui-baseline": "tsx scripts/utils/audit-ui-discipline.ts --update-baseline && tsx scripts/utils/audit-ui-tokens.ts --update-baseline",
    "audit:ui-ratchet": "tsx scripts/utils/audit-ui-discipline.ts --ratchet",
    "audit:ui-strict": "tsx scripts/utils/audit-ui-discipline.ts --strict && tsx scripts/utils/audit-ui-tokens.ts --strict",
    "audit:mission-detail": "tsx scripts/utils/audit-mission-detail-discipline.ts",
    "audit:mission-detail-baseline": "tsx scripts/utils/audit-mission-detail-discipline.ts --update-baseline",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:first": "standard-version --first-release --release-as 2.2.0",
    "release:push": "git push --follow-tags origin main",
    "release:gh-sync": "tsx scripts/devops/sync-github-releases.ts",
    "release:gh-sync:dry": "tsx scripts/devops/sync-github-releases.ts --dry-run",
    "onprem:bundle": "bash infra/onprem/scripts/build-bundle.sh",
    "onprem:release": "npm run release && bash infra/onprem/scripts/build-bundle.sh",
    "ui-patrol": "tsx scripts/ui-iteration/index.ts",
    "ui-patrol:critical": "tsx scripts/ui-iteration/index.ts --tier critical",
    "ui-patrol:changed": "tsx scripts/ui-iteration/index.ts --changed",
    "ui-patrol:update-baselines": "tsx scripts/ui-iteration/index.ts --update-baselines",
    "db:seed:ui-patrol": "cd backend && tsx prisma/seed-ui-patrol.ts",
    "db:clean:ui-patrol": "cd backend && tsx prisma/clean-ui-patrol.ts",
    "ui-patrol:journeys": "tsx scripts/ui-iteration/journey-cli.ts",
    "e2e": "cd e2e && npx playwright test",
    "e2e:ui": "cd e2e && npx playwright test --ui",
    "sdk:export-spec": "curl -s http://localhost:3001/api/openapi.json > backend/openapi.json",
    "sdk:generate": "npx @openapitools/openapi-generator-cli generate -g typescript-fetch -i backend/openapi.json -o sdk/typescript",
    "sdk:generate:python": "npx @openapitools/openapi-generator-cli generate -g python -i backend/openapi.json -o sdk/python"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "playwright": "^1.58.2",
    "pm2": "^6.0.14",
    "prettier": "^3.0.0",
    "standard-version": "^9.5.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ai-teams-engine.git"
  },
  "keywords": [
    "AI",
    "knowledge-graph",
    "recommendation",
    "learning",
    "research"
  ],
  "author": "Genesis Team",
  "license": "MIT",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "@nestjs/cache-manager": "^3.1.0",
    "@tiptap/extensions": "^3.20.2",
    "js-yaml": "^4.1.1",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "pdfjs-dist": "^5.4.394"
  }
}
